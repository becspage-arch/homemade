{
  "name": "homemade",
  "private": true,
  "version": "0.0.0",
  "description": "homemade.education — the home of making things yourself",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "pnpm --filter @homemade/web lint",
    "typecheck": "turbo typecheck",
    "voice-check": "pnpm --filter @homemade/db exec tsx scripts/voice-check.ts",
    "voice-check:all": "pnpm --filter @homemade/db exec tsx scripts/voice-check-all.ts",
    "bot-edit": "pnpm --filter @homemade/db exec tsx scripts/bot-edit.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.2"
  }
}
