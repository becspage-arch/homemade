        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Bake the potatoes and make the chilli",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oven to 220°C fan. Prick, oil, and salt the potatoes and place on the oven rack. Bake for 70 to 75 minutes until the skin is crisp and the flesh is tender.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "While the potatoes bake, heat a little oil in a saucepan. Cook the onion for 8 minutes until softened. Add the garlic, chilli powder, and cumin and cook for 1 minute. Add the mince and cook, breaking it up, until browned.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Stir in the tomato puree, then add the tinned tomatoes and kidney beans. Season and simmer for 30 to 40 minutes until the chilli is thick and the sauce has deepened in colour.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Serve",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Cut a cross in each potato and open it up. Spoon a generous ladleful of chilli over each potato. Add a dollop of soured cream and a sprinkle of grated cheddar if you like.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
