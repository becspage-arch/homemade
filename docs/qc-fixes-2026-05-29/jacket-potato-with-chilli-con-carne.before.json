            "items": [
              {
                "fix": "Remove the lid and simmer on a high heat for 10 minutes until thickened. Watery chilli on a baked potato floods the plate.",
                "cause": "Not enough simmering time.",
                "symptom": "The chilli is too watery"
              },
              {
                "fix": "Add a teaspoon of sugar or a squeeze of tomato ketchup. A dollop of soured cream on top also cuts the heat when serving.",
                "cause": "Chilli strength varies widely between brands and types.",
                "symptom": "The chilli is too spicy"
              },
              {
                "fix": "Bake uncovered, without foil, at a high temperature for the full time.",
                "cause": "Foil was used, or the temperature was too low.",
                "symptom": "The potato skin is soft"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Chilli-topped jacket potato is a product of the British love of the jacket potato as a vehicle for anything hot and saucy. The combination became popular in British homes and canteens during the 1980s, when chilli con carne arrived as a weekly dinner staple. A cold dollop of soured cream on top is both practical and perfect.",
              "type": "text"
            }
          ]
        }
      ]
