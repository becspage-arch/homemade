        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Build the risotto",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Keep the fish stock hot in a separate saucepan over a low heat. Heat the olive oil and 20 g of butter in a large saucepan over a medium heat. Add the onion and cook for 8 minutes until soft. Add the garlic and cook for 1 minute.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add the rice and stir for 2 minutes until the grains look slightly translucent at the edges. Pour in the white wine and stir until fully absorbed.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add the squid ink to the rice and stir to coat all the grains. Begin adding the warm stock one ladleful at a time, stirring after each addition and waiting until each ladle is mostly absorbed before adding the next. Continue for 18 to 20 minutes until the rice is just tender with a slight bite.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Finish and serve",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Remove from the heat. Beat in the remaining 40 g of cold butter and the parmesan vigorously. Cover and rest for 2 minutes. The risotto should flow slowly when the pan is tilted. Season with salt. Scatter with parsley if using and serve immediately.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Remove from heat while the rice still has a slight bite. The risotto will continue to thicken as it rests. Add a final splash of warm stock if it tightens too much.",
                "cause": "Overcooked, or not enough stock added.",
                "symptom": "The risotto is too thick and stodgy"
              },
              {
                "fix": "Two 4 g sachets gives a deep black. Add the ink before the stock so it has time to colour the grains.",
                "cause": "Only one sachet was used, or the ink was added too early and lost colour.",
                "symptom": "The squid ink is very faint"
              },
              {
                "fix": "Add each ladleful gradually and taste as you go. 18 to 20 minutes is a guide, not a guarantee.",
                "cause": "Not enough cooking time, or stock added too quickly.",
                "symptom": "The rice is chalky in the middle"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Risotto nero comes from Venice, where cuttlefish and squid have been part of the diet for centuries. The ink was first extracted from fresh cuttlefish and added to the pot; today it is sold in sachets. The dish is one of the most striking in Italian cooking. A completely black plate is entirely correct.",
              "type": "text"
            }
          ]
        }
      ]
    },
