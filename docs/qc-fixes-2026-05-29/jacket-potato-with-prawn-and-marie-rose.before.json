          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Bake the potatoes",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oven to 220°C fan. Prick the potatoes, rub with oil and sea salt, and bake directly on the oven rack for 70 to 75 minutes until the skin is crisp and the flesh is soft all the way through.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Make the Marie Rose sauce and serve",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Mix the mayonnaise, ketchup, Worcestershire sauce, and lemon juice in a bowl. Season with black pepper. Fold in the prawns.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Split the hot potatoes open, squeeze to open up, and spoon the prawn mixture generously over the top.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
