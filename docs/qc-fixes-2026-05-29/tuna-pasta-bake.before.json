        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Make the white sauce",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Melt the butter in a saucepan over a medium heat. Add the flour and stir for 1 minute to cook out the raw taste. This is the beginning of a ",
                      "type": "text",
                      "marks": []
                    },
                    {
                      "text": "béchamel",
                      "type": "text",
                      "marks": [
                        {
                          "type": "glossaryTooltip",
                          "attrs": {
                            "termId": "cmp55wfv60001hgv4ozfcc4tj"
                          }
                        }
                      ]
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add the milk in a steady stream, whisking constantly, until the sauce is smooth. Continue stirring over a medium heat for 5 to 6 minutes until thick enough to coat the back of a spoon. Stir in the mustard and season with salt and pepper.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Assemble and bake",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oven to 190°C fan. Cook the pasta in well-salted boiling water for 2 minutes less than the packet says. Drain and transfer to a large bowl.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Fold the white sauce, tuna, and sweetcorn into the pasta. Taste and adjust the seasoning. Tip into a baking tin and smooth the top.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Cover evenly with the grated cheddar. Bake for 20 to 25 minutes until the cheese is golden and bubbling. Rest for 5 minutes before serving.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Remove from the heat and whisk vigorously. If the lumps persist, pass through a sieve.",
                "cause": "The milk was added too quickly, or the flour and butter weren't fully combined before the milk went in.",
                "symptom": "The sauce has lumps"
              },
              {
                "fix": "Cook pasta 2 minutes less than instructed and make sure the sauce is generously coating everything before it goes in.",
                "cause": "The pasta was overcooked before baking, absorbing all the sauce.",
                "symptom": "The bake is dry inside"
              },
              {
                "fix": "Move to the top shelf. Add another handful of cheddar and bake for 5 more minutes.",
                "cause": "The oven temperature was too low or the shelf was too low.",
                "symptom": "The top is pale"
              },
              {
                "fix": "Break up the tuna roughly with a fork before mixing. It should be flaked throughout, not in lumps.",
                "cause": "It was folded in roughly, or left in large pieces.",
                "symptom": "The tuna is in large dry flakes"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Tuna pasta bake is the sort of dish that nobody thinks of as a recipe, yet almost everyone in Britain knows how to make it. It belongs to the school-dinner and midweek-supper tradition: reliable, filling, and made from things that keep. The sweetcorn is optional in a strict sense but in practice it is the dish's defining characteristic.",
              "type": "text"
            }
          ]
        }
      ]
    },
