        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Cook the pasta and cauliflower",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oven to 200°C fan. Bring a large pot of salted water to the boil. Add the cauliflower florets and cook for 3 minutes. Add the pasta and cook together for 2 minutes less than the pasta packet says. Drain.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Make the sauce and bake",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Melt the butter in the same large pot over a medium heat. Add the flour and stir for 1 minute. Add the milk gradually, whisking to prevent lumps, and cook for 5 to 6 minutes until thickened.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Remove from the heat. Stir in three-quarters of the cheese, the mustard, and a few gratings of nutmeg. Season with salt and pepper. Fold in the drained pasta and cauliflower.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Tip into a baking tin. Scatter the remaining cheese on top. Bake for 20 to 25 minutes until the top is golden and bubbling. Rest for 5 minutes before serving.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
