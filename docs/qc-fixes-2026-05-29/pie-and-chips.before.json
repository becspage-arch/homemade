        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Make the filling",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oil in a large saucepan over a high heat. Brown the beef in batches until dark on all sides. Remove and set aside. Reduce the heat to medium, add the onion, and cook for 8 minutes until softened.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Stir in the flour and cook for 1 minute. Return the beef to the pan with the stock and Worcestershire sauce. Season well. Simmer for 30 minutes until the gravy is thick and the beef is tender. Cool slightly.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Assemble and bake",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oven to 200°C fan. Line a deep baking tin with two-thirds of the pastry, letting it hang over the sides. Spoon in the cooled filling. Lay the remaining pastry over the top, press the edges together, and trim.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Brush the top with beaten egg. Make a small cut in the centre to let steam escape. Chill for 30 minutes if time allows.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Spread the chips on a separate tray. Put both the pie and the chips in the oven. Bake for 30 to 35 minutes until the pastry is deep golden and the chips are crisp. Rest the pie for 5 minutes before cutting.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Allow the filling to cool before assembling. Reduce the filling further if the gravy is very loose.",
                "cause": "Filling was too hot when added, or too wet.",
                "symptom": "The pastry base is soggy"
              },
              {
                "fix": "Rest the assembled pie in the fridge for 30 minutes before baking. This relaxes the gluten and prevents shrinkage.",
                "cause": "Pastry not chilled before baking.",
                "symptom": "The pastry lid shrinks away from the edges"
              },
              {
                "fix": "Press the pastry edges firmly together and crimp. Leave a small gap at the top of the filling rather than packing to the brim.",
                "cause": "Edges not sealed tightly, or filling was overfilled.",
                "symptom": "The pie leaks gravy during baking"
              },
              {
                "fix": "Put both trays in at the same time. Chips at this temperature take 25 to 30 minutes, which matches the pie finishing time.",
                "cause": "Chips placed in the oven at a different time.",
                "symptom": "The chips and pie are not ready at the same time"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Pie and chips is the canonical British pub dinner. Every blackboard menu has a version: pastry, filling, and fried potato on the same plate. The British love of pie is ancient. The pairing with chips dates from the postwar period, when oven-ready chips made it practical at home as well as in the pub.",
              "type": "text"
            }
          ]
        }
      ]
    },
