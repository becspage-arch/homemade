        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Cook the sausages and make the batter",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Cook the sausages in a frying pan over a medium heat for 12 to 15 minutes until cooked through. Allow to cool completely. Pat dry with kitchen paper.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Mix the plain flour, cornflour, baking powder, and salt in a bowl. Whisk in the cold sparkling water or lager until the batter is smooth and drips slowly from the whisk. Do not overmix. Keep the batter cold.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Deep fry",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the vegetable oil in a deep, heavy-based pot to 180°C. Check with a thermometer. The oil should not be more than one-third full.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Dip each sausage into the batter, letting the excess drip off. Lower carefully into the hot oil using tongs. Fry for 3 to 4 minutes, turning once, until the batter is pale golden and crisp.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Drain on kitchen paper. Serve immediately with chips and ketchup.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Pat the sausages completely dry before dipping. The batter should coat thickly.",
                "cause": "Sausage was wet, or the batter was too thin.",
