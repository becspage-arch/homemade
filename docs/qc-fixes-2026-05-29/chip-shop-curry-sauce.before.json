        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Melt the butter in a medium saucepan over a medium heat. Add the onion and cook for 8 minutes until soft and lightly golden. Add the garlic, curry powder, and turmeric and cook for 1 minute.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Stir in the flour and cook for 1 minute. Add the stock gradually, stirring, then add the grated apple. Simmer for 8 to 10 minutes until the sauce has thickened slightly and the apple has broken down.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Blend with a stick blender for a smooth sauce, or leave it as it is for a more textured version. Season with salt. Pour generously over chips to serve.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Add a splash more stock and stir. Chip shop curry sauce should pour easily, not sit in a mound.",
                "cause": "Too much flour or reduced too long.",
                "symptom": "The sauce is too thick"
              },
              {
                "fix": "Use a mild curry powder labelled specifically as mild. Add a small extra pinch of sugar or a bit more grated apple to balance.",
                "cause": "Curry powder was too hot, or too much was used.",
                "symptom": "The sauce tastes too sharp or spicy"
              },
              {
                "fix": "The golden colour comes from turmeric. Add another quarter teaspoon if the sauce looks pale.",
