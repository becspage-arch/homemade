      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat oven to 200C/fan 180C/gas 6.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Boil the potatoes for 5 mins.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Drain and tip into a bowl - they will be slightly underdone.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Toss with the tarragon, lemon zest, butter and seasoning to taste. Pile in the centre of a foil-lined baking tray.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Season salmon with black pepper and wrap the pancetta or prosciutto around the fillets.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place on top of the potatoes and roast for 15-20 mins, or until the fish flakes easily and the pancetta or prosciutto is golden.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Serve with steamed green beans.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Salt a pinch at a time, tasting. A squeeze of lemon or splash of vinegar at the end lifts most savoury dishes.",
              "cause": "Underseasoned or no acid.",
              "symptom": "The dish tastes flat"
            },
            {
              "fix": "Pull off the heat a minute or two before you think it's done. Plate straight away, or transfer to a warmed serving dish.",
              "cause": "Carryover cooking, food keeps cooking on the hot pan after the heat goes off.",
              "symptom": "It's overcooked by the time it reaches the table"
            },
            {
              "fix": "Drop the heat and give it longer. A probe thermometer is the only reliable check for meat.",
              "cause": "Heat too high, browned the outside before the middle warmed through.",
              "symptom": "It's undercooked in the middle"
            },
            {
              "fix": "Reheat covered with a splash of stock or water, on a low heat. Microwave on 60% power if using one, gentler than full blast.",
              "cause": "Reheated uncovered, or no liquid in the pan.",
              "symptom": "The leftovers were dry"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
