  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Salmon Teriyaki. Japanese home cooking that trusts the soy, the dashi, and the patience between them. Serves 2.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A weeknight-friendly recipe: most of the work is the prep, and the cooking takes care of itself.",
            "type": "text"
          }
        ]
      },
      {
