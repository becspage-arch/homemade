        "content": [
          {
            "type": "text",
            "text": "A five-minute tapping practice from Day 2 of MONEY: A 12-Week Tapping Program. The script targets the running-out loop: the background fear that the money will dry up before everything is covered, the tensing up at account checks, the bracing for a surprise expense that hasn't arrived yet."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "New to tapping? Read " },
          { "type": "text", "marks": [{ "type": "link", "attrs": { "href": "/mindset/how-eft-tapping-works" } }], "text": "how EFT tapping works" },
          { "type": "text", "text": " first." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "The practice" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Karate chop" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I worry the money will run out, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I fear there won't be enough for what we need, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I feel unsafe when I look at the bank balance, I deeply and completely accept myself." }] }]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Tapping round" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Eyebrow:" }, { "type": "text", "text": " I'm scared the money will dry up." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Side of eye:" }, { "type": "text", "text": " I think of bills waiting to be paid." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under eye:" }, { "type": "text", "text": " I fear the surprise expense." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under nose:" }, { "type": "text", "text": " I tense up every time I check accounts." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Chin:" }, { "type": "text", "text": " I brace for something to go wrong." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Collarbone:" }, { "type": "text", "text": " I live as if the next crisis is certain." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under arm:" }, { "type": "text", "text": " This fear feels constant." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Top of head:" }, { "type": "text", "text": " I'm tired of carrying it." }] }]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Reframe to positive" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Eyebrow:" }, { "type": "text", "text": " I am safe in this moment." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Side of eye:" }, { "type": "text", "text": " I trust money can flow in many ways." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under eye:" }, { "type": "text", "text": " I let go of the belief that running out is certain." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under nose:" }, { "type": "text", "text": " I welcome ideas and income I haven't seen yet." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Chin:" }, { "type": "text", "text": " I trust that I am provided for." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Collarbone:" }, { "type": "text", "text": " I allow a steady stream of money to support us." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under arm:" }, { "type": "text", "text": " I open to financial ease." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Top of head:" }, { "type": "text", "text": " I feel calmer about the future." }] }]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Tap each round three times, then move to the reframe and tap that three times." }]
      },
