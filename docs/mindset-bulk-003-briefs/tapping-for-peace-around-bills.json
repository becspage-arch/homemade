      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "The practice" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Karate chop" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I feel stressed every time a bill arrives, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I see bills as proof of struggle, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I brace for bad news when I open them, I deeply and completely accept myself." }] }]
          }
        ]
      },
      {
