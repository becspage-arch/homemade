          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Chin:" }, { "type": "text", "text": " I see each payment as part of abundance." }] }]
          },
          {
            "type": "listItem",
