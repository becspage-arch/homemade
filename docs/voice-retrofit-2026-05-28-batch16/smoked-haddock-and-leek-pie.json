              "unit": "each",
              "amount": 1,
              "prepNote": "finely chopped",
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49f59k0042rkv4afimm5ox",
              "ingredientSlug": "onion"
            },
            {
              "name": "Unsalted butter",
              "unit": "g",
              "amount": 50,
              "prepNote": null,
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49f3gf000wrkv4p017cubd",
              "ingredientSlug": "unsalted-butter"
            },
            {
              "name": "Plain flour",
              "unit": "g",
              "amount": 40,
              "prepNote": null,
              "groupLabel": null,
