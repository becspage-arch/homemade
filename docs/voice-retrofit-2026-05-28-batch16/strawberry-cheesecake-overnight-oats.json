            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "In a medium mixing bowl, whisk all ingredients except for strawberries until well-combined.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Mix in half of the chopped strawberries (save the other half for the morning), mashing them a little as you mix.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cover mixture or transfer to an airtight container and place in the fridge overnight.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
