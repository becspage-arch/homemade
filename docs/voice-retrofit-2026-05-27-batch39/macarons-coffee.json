      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Prepare the tant pour tant",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Process the ground almonds, icing sugar, and espresso powder in a food processor until very fine. Sift through a fine sieve, discarding any lumps that don't pass through. Mix with the first 55 g of egg whites until a smooth, stiff paste forms.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the Italian meringue",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the caster sugar and water to 118°C in a small saucepan. Meanwhile, whip the second 55 g of egg whites in the stand mixer to soft peaks. With the mixer running, pour the hot syrup in a thin, steady stream down the inside of the bowl. Whip on high until the meringue is stiff, glossy, and cooled to about 40°C.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Macaronage, pipe, and rest",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Fold the meringue into the almond paste in three additions, pressing the mixture against the sides of the bowl. Continue until the batter falls from the spatula in a slow, continuous ribbon. Do not overwork. Transfer to a piping bag fitted with a 1 cm round nozzle. Pipe 4 cm rounds onto lined baking trays, spacing 3 cm apart. Tap the trays firmly on the work surface to release air bubbles. Leave the shells to rest, uncovered, at room temperature for 30 to 60 minutes until a dry skin forms and the surface is not tacky when touched lightly.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake and fill",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Preheat the oven to 150°C conventional. Bake for 13 to 15 minutes until the shells have feet and lift cleanly off the paper. Open the oven door slightly for the last 5 minutes. Cool completely on the trays. Beat the butter, icing sugar, and dissolved espresso together until pale and smooth. Pipe a round of filling on the flat side of half the shells and sandwich with the remaining shells. Refrigerate overnight before serving.",
            "type": "text"
          }
        ]
      }
    ]
