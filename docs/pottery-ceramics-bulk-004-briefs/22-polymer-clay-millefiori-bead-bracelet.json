  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "millefiori"
                }
              }
            ],
            "text": "millefiori"
          },
          {
            "type": "text",
            "text": " cane is a cylinder of "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "polymer-clay"
                }
              }
            ],
            "text": "polymer clay"
          },
          {
            "type": "text",
            "text": " made from contrasting colour layers. Every slice cut from the cylinder shows the same cross-section pattern. In this tutorial, a simple five-petal flower cane is built and sliced onto round bead bases to make a bracelet."
          }
        ]
      },
      {
        "type": "infoPanel",
        "attrs": {
          "type": "warning",
          "content": "Use a dedicated oven tray. Do not share with food-prep cookware."
        }
      },
      {
        "type": "suppliesCard",
        "attrs": {
          "heading": "What you need",
          "items": [
            {
              "name": "Polymer clay, flower colour (e.g. pink)",
              "quantity": "20 g",
              "substitution": null
            },
            {
              "name": "Polymer clay, background colour (e.g. white)",
              "quantity": "20 g",
              "substitution": null
            },
            {
              "name": "Polymer clay, centre colour (e.g. yellow)",
              "quantity": "10 g",
              "substitution": null
            },
            {
              "name": "Polymer clay, bead base (neutral)",
              "quantity": "30 g",
              "substitution": null
            },
            {
              "name": "Pottery rolling pin",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Fettling knife",
              "quantity": "1",
              "substitution": "Sharp craft knife"
            },
            {
              "name": "Needle tool or skewer",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Oven with dedicated tray",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Elastic bracelet thread",
              "quantity": "1 length",
              "substitution": null
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building the flower cane"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Roll a small cylinder of yellow clay, 8 mm diameter and 40 mm long. This is the flower centre."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Roll five equal logs of pink clay, each 8 mm diameter and 40 mm long. These are the petals."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Arrange the five pink logs around the yellow centre, pressing them firmly together."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fill the gaps between the pink logs with white clay, pressing white clay into all the spaces. The assembly should form a rough cylinder."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Roll a thin sheet of white clay and wrap it around the outside of the whole cane to form a background ring."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Gently roll the assembled cane on the board to consolidate, pressing evenly from the centre outward without distorting the cross-section. The cane should now be a clean cylinder about 25 mm across."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Making and surfacing the beads"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Roll the neutral base clay into balls approximately 12-15 mm diameter. Pierce each ball through the centre with the needle tool or skewer to create the stringing hole. Slice thin (2 mm) rounds from the cane and press them onto the surface of each bead, covering the surface evenly. Roll the bead gently between the palms to set the slices flush."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Curing and stringing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Place beads on a dedicated tray, strung loosely on the skewer so they do not sit flat. "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "curing"
                }
              }
            ],
            "text": "Cure"
          },
          {
            "type": "text",
            "text": " at 130°C for 25 minutes. Cool fully. String the cooled beads on elastic bracelet thread, tie with a secure double knot, and trim the ends."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use the same cane slices on a pendant base or on earring blanks instead of a bracelet."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Reduce the cane by rolling and stretching it to produce smaller-diameter slices for finer beads."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Alternate plain beads in a contrasting colour with the patterned beads for a simple stripe effect."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "Millefiori bracelet problems",
          "intro": null,
          "items": [
            {
              "symptom": "Cane slices distort when pressed onto the bead",
              "cause": "Cane not reduced to the correct final diameter before slicing",
              "fix": "Gently roll the cane on the board to reduce before slicing. Smaller-diameter cane slices distort less when pressed"
            },
            {
              "symptom": "Cane cross-section is blurry rather than sharp",
              "cause": "Petal logs not fully conditioned; soft clay blurred when pressing together",
              "fix": "Condition all clay thoroughly. Chill the assembled cane in the freezer for 15 minutes before slicing for cleaner cuts"
            }
          ]
        }
      }
    ]
  }
}