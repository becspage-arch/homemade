  "glossaryTerms": [
    {
      "slug": "greenware",
      "term": "Greenware",
      "definition": "Unfired clay in any drying stage. For air-dry clay, the piece from forming until fully dry."
    },
    {
      "slug": "leather-hard",
      "term": "Leather-hard",
      "definition": "The drying stage where clay is firm but still damp. Most repairs are easiest at leather-hard."
    },
    {
      "slug": "bone-dry",
      "term": "Bone-dry",
      "definition": "Fully air-dried. Cracks at this stage are harder to repair and may recur on drying."
    }
  ],
