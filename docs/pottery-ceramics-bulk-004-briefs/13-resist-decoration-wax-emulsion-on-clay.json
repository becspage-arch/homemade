      "slug": "resist",
      "term": "Resist",
      "definition": "A material applied to a surface to prevent a subsequent layer (slip, glaze, paint) from adhering to the masked area."
    },
    {
      "slug": "bone-dry",
      "term": "Bone-dry",
      "definition": "Fully air-dried. The stage at which air-dry clay is ready for surface decoration."
    }
  ],
