  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The tea bowl is one of the most studied forms in wheel pottery. At 250-350 ml capacity and 80-90 mm in diameter, it is small enough to hold in both hands. It needs the same skills as larger forms but with less room for error. The aim is a wall of consistent thickness throughout (roughly 6-8 mm), with a base that tapers slightly toward the foot ring."
          }
        ]
      },
      {
        "type": "infoPanel",
        "attrs": {
          "type": "warning",
          "content": "Wear an N95 mask when trimming leather-hard stoneware. Trimming generates fine silica-bearing dust. Fire kilns in a well-ventilated space away from living areas."
        }
      },
      {
        "type": "suppliesCard",
        "attrs": {
          "heading": "What you need",
          "items": [
            {
              "name": "Stoneware clay, smooth",
              "quantity": "350 g",
              "substitution": null
            },
            {
              "name": "Electric potter's wheel",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Wire cutter",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Needle tool",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Pottery sponge",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Wooden rib",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Loop tool",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Pottery chamois (optional, for rim)",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "N95 mask",
              "quantity": "1",
              "substitution": null
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Steps"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Centre 300 g of clay, open to 50 mm diameter, and leave an 8 mm floor."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pull the walls in two passes to a consistent 6-8 mm thickness throughout."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Allow the upper wall to flare outward and compress the rim."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cut off with a wire and allow to dry to leather-hard on a bat."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Trim a 35-40 mm foot ring with a loop tool."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Centring and opening"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": ""
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "centring"
                }
              }
            ],
            "text": "Centre"
          },
          {
            "type": "text",
            "text": " the clay as a compact dome. Open downward with both thumbs, leaving an 8 mm floor. Sweep the floor outward to 50 mm diameter. For a tea bowl, the opening is relatively small. The walls fan outward during pulling rather than being opened wide at the base."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Pulling the walls"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": ""
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "pulling"
                }
              }
            ],
            "text": "Pull"
          },
          {
            "type": "text",
            "text": " in two passes. First pass: inner finger at the base, outer hand supporting, draw upward slowly. Second pass: thin the walls to 6-8 mm throughout, allowing them to curve outward slightly as they rise. The top third of the wall should flare gently outward. Keep the rim consistent in thickness; it will be the most-handled surface."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Shaping with the rib"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Hold the wooden rib against the outside of the wall at mid-height and draw it upward and outward in a slow arc to refine the curve. The rib smooths throwing lines and compresses the clay surface. A slight outward flare at the rim makes the bowl comfortable to drink from. Finish the rim by folding the pottery chamois over it and running it around once, or compress it gently between thumb and forefinger."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Cutting off and trimming"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Cut the tea bowl free with the wire cutter and carry it to a drying board on a small bat or slab. When "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "leather-hard"
                }
              }
            ],
            "text": "leather-hard"
          },
          {
            "type": "text",
            "text": ", invert onto the wheel head, centre by tapping, and trim a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "foot-ring"
                }
              }
            ],
            "text": "foot ring"
          },
          {
            "type": "text",
            "text": " with the loop tool. The foot ring should be 35-40 mm in diameter and 5-6 mm tall. Wear the N95 mask throughout trimming."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Throw a taller, straighter-sided yunomi form by pulling more upward than outward."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Make a set of four using the same clay weight and the same opening measurement for consistency."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "Tea bowl problems",
          "intro": null,
          "items": [
            {
              "symptom": "Walls too thick at the base and thin at the rim",
              "cause": "The pulling motion starts too high; the base clay is not being thinned",
              "fix": "Begin each pull from just above the floor and move the inner finger and outer hand upward together, thinning the full wall from base to rim"
            },
            {
              "symptom": "Rim becomes uneven and wobbly",
              "cause": "Wheel speed dropping during pulling; uneven pressure",
              "fix": "Keep the wheel at a consistent medium speed throughout. Level the rim with the needle tool at the end of the final pull before shaping"
            }
          ]
        }
      }
    ]
  }
}