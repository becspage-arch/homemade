  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Translucent "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "polymer-clay"
                }
              }
            ],
            "text": "polymer clay"
          },
          {
            "type": "text",
            "text": " does not become fully clear when cured. It stays slightly milky. Small botanical materials pressed into a thin sheet and sandwiched between two layers show clearly through the clay. Use pressed and dried botanicals only; fresh plant material contains moisture that creates bubbles during curing."
          }
        ]
      },
      {
        "type": "infoPanel",
        "attrs": {
          "type": "warning",
          "content": "Use fully dried, pressed botanicals only. Fresh plant material releases moisture during curing and creates bubbles or discolouration. Use a dedicated oven tray."
        }
      },
      {
        "type": "suppliesCard",
        "attrs": {
          "heading": "What you need",
          "items": [
            {
              "name": "Translucent polymer clay",
              "quantity": "30 g per pendant",
              "substitution": null
            },
            {
              "name": "Pressed, dried botanical material (small leaves, petals, fern fronds)",
              "quantity": "3-5 pieces",
              "substitution": null
            },
            {
              "name": "Pottery rolling pin",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Fettling knife or cookie cutter",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Needle tool",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Oven with dedicated tray",
              "quantity": "1",
              "substitution": null
            },
            {
              "name": "Pendant bail or jump ring",
              "quantity": "1",
              "substitution": null
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Preparing the botanicals"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Press plant material between sheets of absorbent paper under a heavy book for at least one week before use. The material must be completely flat and dry. Small fern fronds, individual leaf shapes, single petals, and small flower heads all work well. Avoid thick stems or seed pods that cannot be fully pressed flat."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building the pendant"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Condition the translucent clay thoroughly and roll out two sheets of equal size, each 2 mm thick."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lay the first sheet on the board and arrange the pressed botanicals on the surface in the desired composition."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lay the second sheet directly on top of the first, covering the botanicals. Press lightly with the rolling pin across the surface once to bond the two sheets and fully embed the botanicals."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cut the pendant shape with a cookie cutter or fettling knife. An oval or rounded rectangle works well for botanical compositions."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pierce the hanging hole with the needle tool."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Curing and finishing"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Preheat the oven to 130°C and "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "curing"
                }
              }
            ],
            "text": "cure"
          },
          {
            "type": "text",
            "text": " for 20 minutes. The pendant will appear slightly milky immediately after curing; once cooled, sand with 600-grit wet-and-dry sandpaper under running water to reduce the milky surface and improve translucency. The botanical material shows through as green, dried-herb tones against the translucent clay."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add a very thin layer of gold or pearl clay between the botanical and the top sheet for a gilded background effect."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use different botanical species in a matching set of three pendants from the same garden walk."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "Translucent pendant problems",
          "intro": null,
          "items": [
            {
              "symptom": "Bubbles form around the botanical during curing",
              "cause": "Botanical was not fully dried before embedding",
              "fix": "Press botanicals for a full week and check they are papery-dry before use"
            },
            {
              "symptom": "Botanical shows as a brown smear rather than clear detail",
              "cause": "Plant material scorched during curing",
              "fix": "Cure at the lower end of the recommended range (120°C rather than 130°C) for botanical-embedded pieces"
            }
          ]
        }
      }
    ]
  }
}