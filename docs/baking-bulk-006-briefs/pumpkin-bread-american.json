      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Prepare" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Heat the oven to 160°C fan. Grease and line a 900 g loaf tin." }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Mix wet ingredients" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Whisk together the {{pumpkin-puree}}, {{light-brown-sugar}}, {{vegetable-oil}}, {{free-range-eggs}}, and {{vanilla-extract}} in a large bowl until smooth." }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Add dry ingredients" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Add the {{plain-flour}}, {{bicarbonate-of-soda}}, {{baking-powder}}, {{fine-sea-salt}}, {{ground-cinnamon}}, {{ground-ginger}}, {{ground-nutmeg}}, and {{ground-cloves}}. Stir until just combined." }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Bake, 55–65 minutes" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Pour into the tin. Bake for 55–65 minutes until a skewer inserted in the centre comes out clean. The top will crack along the centre. Cool in the tin for 20 minutes before turning out." }]
      }
