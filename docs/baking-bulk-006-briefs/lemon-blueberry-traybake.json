  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "A simple butter sponge technique: cream, add eggs, fold in flour, stir in the berries. " },
          { "type": "text", "marks": [{ "type": "glossaryTooltip", "attrs": { "termSlug": "fresh-or-frozen-berries" } }], "text": "Fresh or frozen blueberries" },
          { "type": "text", "text": " both work; if using frozen, don't thaw them. Toss the berries in a tablespoon of flour before folding in to help prevent them sinking." }
        ]
      },
      {
        "type": "ingredientsList",
        "content": [
          {
            "type": "ingredientsGroup",
            "attrs": { "title": "Sponge" },
            "content": [
              { "type": "ingredient", "attrs": { "slug": "unsalted-butter", "quantity": 175, "unit": "g", "prepNote": "softened", "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "caster-sugar", "quantity": 175, "unit": "g", "prepNote": null, "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "free-range-eggs", "quantity": 3, "unit": null, "prepNote": "large", "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "lemons", "quantity": 2, "unit": null, "prepNote": "zest only (reserve the juice for the icing)", "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "plain-flour", "quantity": 225, "unit": "g", "prepNote": null, "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "baking-powder", "quantity": 2, "unit": "tsp", "prepNote": null, "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "fine-sea-salt", "quantity": 0.25, "unit": "tsp", "prepNote": null, "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "whole-milk", "quantity": 3, "unit": "tbsp", "prepNote": null, "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "blueberries", "quantity": 200, "unit": "g", "prepNote": "fresh or frozen", "isOptional": false } }
            ]
          },
          {
            "type": "ingredientsGroup",
            "attrs": { "title": "Lemon icing" },
            "content": [
              { "type": "ingredient", "attrs": { "slug": "icing-sugar", "quantity": 150, "unit": "g", "prepNote": "sifted", "isOptional": false } },
              { "type": "ingredient", "attrs": { "slug": "lemons", "quantity": 1, "unit": null, "prepNote": "juice (about 2 tbsp)", "isOptional": false } }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "Method" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Prepare" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Heat the oven to 160°C fan. Grease a 20×30 cm tin and line with baking paper." }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Make the batter" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Beat the {{unsalted-butter}} and {{caster-sugar}} until pale and fluffy. Beat in the {{free-range-eggs}} one at a time, then the lemon zest from the {{lemons}}. Fold in the {{plain-flour}}, {{baking-powder}}, and {{fine-sea-salt}}, then stir in the {{whole-milk}}. Toss the {{blueberries}} in 1 tablespoon of flour, then fold into the batter." }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Bake, 28–32 minutes" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Spread the batter into the tin. Bake for 28–32 minutes until a skewer comes out clean and the cake has pulled slightly from the sides. Cool in the tin for 20 minutes." }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Ice and cut" }]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Mix the {{icing-sugar}} with enough lemon juice from the {{lemons}} to make a thick, pourable icing. Pour over the still-warm cake and spread to the edges. Leave to set for 20 minutes before cutting into squares." }]
      }
    ]
  }
}
