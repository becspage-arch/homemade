      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake the base, 20 to 22 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 170°C fan. Grease and line a 20 x 20 cm square tin. Melt the {{unsalted-butter}}, {{golden-syrup}}, and {{demerara-sugar}} together in a large saucepan over a medium heat, stirring until the sugar dissolves. Remove from the heat and stir in the {{rolled-oats}} and {{fine-sea-salt}}. Press the mixture firmly and evenly into the tin using the back of a spoon. Bake for 20 to 22 minutes until the edges are golden and the centre is just set. Cool in the tin.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the caramel and layer",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt the caramel {{unsalted-butter}} with the {{light-brown-sugar}} in a small saucepan over a medium heat. Once the sugar dissolves, add the {{double-cream}} and {{fine-sea-salt}} and stir for 3 minutes until the caramel thickens slightly. Remove from the heat and leave to cool for 10 minutes, then pour over the cooled flapjack base. Leave to set at room temperature for 30 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Add the chocolate and cut",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt the {{dark-chocolate}} in a heatproof bowl over barely simmering water. Pour over the set caramel and spread to the edges with a spatula. Refrigerate for 30 minutes until the chocolate is firm. Lift from the tin using the lining paper and cut into 16 squares with a sharp knife.",
            "type": "text"
          }
        ]
      }
    ]
  },
