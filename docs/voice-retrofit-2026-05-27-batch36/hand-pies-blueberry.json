      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine the {{blueberries}}, {{caster-sugar}}, {{cornflour}}, {{lemon-juice}}, and {{lemon}} zest in a small saucepan. Cook over a medium heat for 5 minutes, stirring, until the berries have burst and the mixture has thickened to a jammy consistency. Spread on a plate and refrigerate until completely cold.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry, chill, and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Rub the cold {{unsalted-butter}} into the {{plain-flour}}, {{caster-sugar}}, and {{fine-sea-salt}} until it resembles coarse crumbs. Add 4 to 6 tablespoons of ice-cold water until the dough comes together. Refrigerate for 1 hour. Roll to about 3 mm thick and cut into 16 circles of about 12 cm diameter. Place a heaped tablespoon of the cold blueberry filling on one half of each circle, leaving a 1.5 cm border. Fold the plain half over the filling, press the edges firmly together, and seal with a fork. Place on lined baking trays.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake, 18 to 22 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 200°C fan. Brush the assembled hand pies with the {{eggs}} wash and scatter {{demerara-sugar}} over. Cut a small slit in the top of each pie. Bake for 18 to 22 minutes until deep golden and the filling is just beginning to bubble through the vents. Cool on a rack for 15 minutes before eating; the filling will be hot.",
            "type": "text"
          }
        ]
      }
    ]
  },
