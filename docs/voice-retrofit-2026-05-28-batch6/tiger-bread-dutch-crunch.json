      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the bread dough and bulk ferment, 75 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine the {{strong-bread-flour}} (bread amount), {{sea-salt-fine}} (bread amount), and {{yeast-dried}} (bread amount) in a large bowl. Add 260 ml warm water and the {{vegetable-oil}} (bread amount). Mix to a smooth dough and knead for 8 to 10 minutes until soft and elastic. Cover and leave for 75 minutes until doubled.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Shape, coat, and prove, 45 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Shape the dough into an oval and place in a greased 900 g loaf tin. Mix the {{rice-flour}}, {{yeast-dried}} (topping amount), {{vegetable-oil}} (topping amount), {{caster-sugar}}, {{sea-salt-fine}} (topping amount), and 80 ml warm water in a bowl to make a thick paste. Leave for 5 minutes, then spread generously over the top and sides of the shaped loaf. Leave to prove for 45 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake, 28 to 32 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Preheat the oven to 220°C fan. Bake for 28 to 32 minutes, until the topping is deep amber and crackled and the base sounds hollow when tapped. Cool on a rack for at least 20 minutes before slicing.",
            "type": "text"
          }
        ]
      }
    ]
  },
