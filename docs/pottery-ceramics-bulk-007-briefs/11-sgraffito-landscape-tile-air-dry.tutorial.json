  "glossaryTerms": [
    {
      "slug": "sgraffito",
      "term": "Sgraffito",
      "definition": "A surface decoration technique in which a layer of slip or coating is applied to clay and then scratched away to reveal the contrasting colour beneath"
    },
    {
      "slug": "slip",
      "term": "Slip",
      "definition": "Liquid clay, usually thinned to a creamy consistency, used to coat surfaces or join clay pieces together"
    },
    {
      "slug": "leather-hard",
      "term": "Leather-hard",
      "definition": "The stage at which clay holds its shape and no longer sticks to your hands, but still contains moisture; the ideal state for applying slip and then sgraffito carving"
    },
    {
      "slug": "slab",
      "term": "Slab",
      "definition": "A flat sheet of clay rolled to an even thickness, used here as the tile base"
    }
  ],
