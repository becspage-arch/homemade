    },
    {
      "slug": "leather-hard",
      "term": "Leather-hard",
      "definition": "The stage at which clay holds its shape and no longer sticks to your hands, but still contains moisture and can be carved or smoothed"
    },
    {
      "slug": "template",
      "term": "Template",
      "definition": "A cut-out shape made from card or stiff paper used as a guide for cutting identical forms from clay"
    }
  ],
