  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A rolled "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "slab",
                  "label": "slab"
                }
              }
            ],
            "text": "slab"
          },
          {
            "type": "text",
            "text": " of air-dry clay is all you need for this wall letter. You draw or print your chosen letter onto card to make a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "template",
                  "label": "template"
                }
              }
            ],
            "text": "template"
          },
          {
            "type": "text",
            "text": ", cut around it in the clay, pierce two holes for hanging, and leave to dry. The result is a sturdy, personalised wall sign that works well in a bedroom, nursery, or hallway. No kiln or wheel needed."
          }
        ]
      },
      {
        "type": "suppliesCard",
        "attrs": {
          "materials": [
            {
              "name": "Air-dry clay",
              "quantity": "400 g",
              "slug": "air-dry-clay",
              "isOptional": false
            },
            {
              "name": "Card or thick paper for template",
              "quantity": "1 A4 sheet",
              "slug": null,
              "isOptional": false
            },
            {
              "name": "PVA glue",
              "quantity": "small bottle",
              "slug": null,
              "isOptional": false
            },
            {
              "name": "Two guide sticks or wooden rulers, 6 mm thick",
              "quantity": "2",
              "slug": null,
              "isOptional": false
            },
            {
              "name": "Non-stick baking paper",
              "quantity": "2 sheets",
              "slug": null,
              "isOptional": false
            },
            {
              "name": "Pencil and scissors (for card template)",
              "quantity": "1 each",
              "slug": null,
              "isOptional": false
            },
            {
              "name": "Acrylic paint (optional)",
              "quantity": "small amount",
              "slug": null,
              "isOptional": true
            }
          ],
          "tools": [
            {
              "name": "Pottery rolling pin",
              "slug": "pottery-rolling-pin",
              "isOptional": false
            },
            {
              "name": "Fettling knife",
              "slug": "fettling-knife",
              "isOptional": false
            },
            {
              "name": "Needle tool",
              "slug": "needle-tool",
              "isOptional": false
            },
            {
              "name": "Mop brush",
              "slug": "pottery-brush-mop",
              "isOptional": false
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Preparation"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Draw or print your chosen letter at the size you want the finished sign to be. A letter 12-15 cm tall works well as a first project. Cut it out carefully from the card to make your template."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Choose a simple, bold font with thick lines. Thin serifs or very narrow strokes are fragile in clay at this scale."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Knead the clay for 2 minutes until smooth and soft. Keep unused clay in its packaging."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Rolling the slab"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place the clay on a sheet of non-stick baking paper. Lay a 6 mm guide stick on each side. Roll with the pottery rolling pin, resting the pin ends on the guide sticks, until the "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termSlug": "slab",
                          "label": "slab"
                        }
                      }
                    ],
                    "text": "slab"
                  },
                  {
                    "type": "text",
                    "text": " is an even 6 mm thick. A consistent 6 mm gives enough strength to resist cracking once cut."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Roll the slab slightly larger than your card template so you have room to manoeuvre the template on the surface."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Cutting the letter"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lay the card "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termSlug": "template",
                          "label": "template"
                        }
                      }
                    ],
                    "text": "template"
                  },
                  {
                    "type": "text",
                    "text": " onto the slab and hold it lightly in place. Use the fettling knife to cut around the outside edge of the card with a single, smooth stroke per straight section. For curves, use short, careful strokes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove the card template and lift away the surrounding clay scraps. Clean up the cut edges by running the flat side of the fettling knife along them."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "For letters with an enclosed hole (such as O, D, or A), pierce the inside area with the needle tool tip, then cut around it with the fettling knife."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Piercing for hanging"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use the needle tool to pierce two hanging holes through the clay while it is still soft. Place them near the top of the letter, symmetrically, at least 8 mm from any edge to avoid cracking."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Make each hole about 4 mm in diameter so a hanging cord or picture wire can pass through once dry."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Smooth the clay around each hole on both sides with a damp fingertip."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Drying and finishing"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Leave the letter flat on its baking paper at room temperature. Cover it loosely with a plastic bag for the first 6 hours to slow drying. Once at "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termSlug": "leather-hard",
                          "label": "leather-hard"
                        }
                      }
                    ],
                    "text": "leather-hard"
                  },
                  {
                    "type": "text",
                    "text": " stage, remove the bag and allow it to dry fully. Allow 2 days for a 6 mm slab; 3 days in humid conditions."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Once dry, sand any rough edges very lightly with fine sandpaper if needed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Paint with acrylic if desired, then seal all surfaces with two coats of diluted PVA (1:1 with water), allowing 1 hour between coats."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Press texture into the slab before cutting (lace, leaves, or a stamp) for an embossed letter."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cut two or three initials from a single slab and hang them as a row."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add a border by cutting a slightly larger backing rectangle, scoring and slipping the letter on top before drying."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use the same method to cut simple silhouettes: a house, star, or heart."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "problem": "Letter cracked along a thin section while drying",
              "cause": "The stroke was too narrow for the 6 mm thickness, or the clay dried unevenly",
              "fix": "Slow drying with a plastic bag cover for the first 12 hours. Use a bold, thick font; avoid letters with strokes narrower than 10 mm."
            },
            {
              "problem": "Cut edge is ragged or jagged",
              "cause": "The fettling knife was dragged rather than sliced",
              "fix": "Hold the knife vertical and use a smooth, single downward stroke per section. Damp the blade lightly if the clay is sticking."
            },
            {
              "problem": "Hanging hole cracked around the edge",
              "cause": "Hole was too close to the edge or made when clay was drying",
              "fix": "Pierce holes immediately after cutting while clay is still soft. Keep holes at least 8 mm from all edges."
            },
            {
              "problem": "Letter warped or bent during drying",
              "cause": "One face dried faster than the other",
              "fix": "Flip the letter carefully after 12 hours so both faces dry at a similar rate. Keep it on a flat surface throughout."
            }
          ]
        }
      }
    ]
  }
}
