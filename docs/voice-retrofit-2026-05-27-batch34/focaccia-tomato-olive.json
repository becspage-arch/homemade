                "attrs": {
                  "slug": "strong-white-flour",
                  "unit": "g",
                  "prepNote": null,
                  "quantity": 500,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "fine-sea-salt",
                  "unit": "g",
                  "prepNote": null,
                  "quantity": 10,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "instant-yeast",
