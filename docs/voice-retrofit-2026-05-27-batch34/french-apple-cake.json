            },
            "content": [
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "eating-apples",
                  "unit": null,
                  "prepNote": "medium (about 700 g peeled weight), peeled, cored, sliced 3 to 4 mm thin",
                  "quantity": 4,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "caster-sugar",
                  "unit": "g",
                  "prepNote": "50 g for the apples, 100 g for the batter",
