    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Chicken Wrapped in Parma Ham. A British home-cook's dish, the kind of recipe families adjust across generations. Serves 2.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A weeknight-friendly recipe: most of the work is the prep, and the cooking takes care of itself.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "What you need",
            "type": "text"
          }
        ]
      },
      {
        "type": "ingredientsList",
        "attrs": {
          "items": [
            {
              "name": "Chicken breast",
