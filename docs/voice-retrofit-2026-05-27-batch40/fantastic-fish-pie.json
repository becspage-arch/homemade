      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to 230°C."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Peel and dice the potatoes into 2.5 cm chunks. Put into boiling salted water and bring back to the boil for 2 minutes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Carefully lower the eggs into the pan and cook for a further 8 minutes until hard-boiled. By this point the potatoes should also be cooked."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "At the same time, steam the spinach in a colander above the pan for about 1 minute until wilted. Remove and squeeze out any excess moisture."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Drain the potatoes into the colander. Remove the eggs, cool under cold water, then peel and quarter them. Set aside."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Peel and finely chop the onion. Peel, halve, and finely chop the carrot."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a separate pan, fry the onion and carrot gently in a little oil for about 5 minutes, then add the double cream and bring just to the boil."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove from the heat and grate in two good handfuls of cheddar. Squeeze in the lemon juice and stir through the mustard."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pick and finely chop the parsley and stir it into the cream mixture."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Slice the fish into strips and place in an earthenware dish with the spinach and eggs. Pour the cream sauce over and mix gently."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mash the drained potatoes with a little olive oil, salt, black pepper, and a grating of nutmeg if using. Spread over the fish in a rough layer."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake for 25 to 30 minutes until the potato is golden. Serve with peas or greens."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Squeeze the spinach very dry before adding and pat the fish strips with kitchen paper. Too much moisture in the filling makes the sauce watery.",
              "cause": "Wet spinach or undried fish.",
              "symptom": "Sauce is watery after baking"
            },
            {
              "fix": "The sauce should be well seasoned before going into the dish. Taste and adjust before you add the fish.",
              "cause": "Not enough salt, cheese, or mustard in the sauce.",
              "symptom": "The pie tastes bland"
            },
            {
              "fix": "The fish goes in raw. Use thick cod fillets rather than thin; they will be perfectly cooked in 25 minutes at 230°C.",
              "cause": "Fillets too thin or oven temperature too low.",
              "symptom": "Fish is dry and overcooked"
            },
            {
              "fix": "Reheat covered with foil at 180°C for 20 minutes, or in individual portions in the microwave on 60% power.",
              "cause": "Reheated uncovered or at too high a temperature.",
              "symptom": "Leftovers dried out"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mixed fish: use a combination of cod, smoked haddock, and raw prawns for a more complex filling."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lighter topping: replace half the mashed potato with celeriac or use a mix of potato and sweet potato."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Assemble the pie up to a day ahead and keep covered in the fridge; add five minutes to the baking time. Leftovers keep two days in the fridge. Freezes well before baking; defrost overnight in the fridge before cooking."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "From Rebecca's kitchen. A British fish pie in the classic mould: cream sauce, hard-boiled eggs, mashed potato on top. The kind that gets made on a weeknight and eaten from the dish."
          }
        ]
      }
    ]
