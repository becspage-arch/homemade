      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Shortbread base",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 160°C fan. Line a 20 cm square tin with baking paper, leaving overhang on two sides.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat the {{unsalted-butter}} and {{caster-sugar}} until pale and creamed. Sift in the {{plain-flour}} and {{sea-salt-fine}} and bring together to a soft dough. Press evenly into the tin. Prick all over with a fork.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 20 minutes until pale gold all over. Cool completely in the tin before moving on.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Caramel layer",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Put the second portion of {{unsalted-butter}}, the {{soft-brown-sugar}}, the {{golden-syrup}}, and the {{condensed-milk}} into a heavy saucepan over a low heat. Stir constantly with a wooden spoon.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "As the mixture comes together, increase the heat to medium-low and continue stirring. The caramel will burn on the base of the pan if you stop. Cook for about 8 to 10 minutes until the caramel darkens from cream to a deep amber-tan and feels thicker on the spoon. This is the ",
                    "type": "text"
                  },
                  {
                    "text": "condensed-milk caramel",
                    "type": "text",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termId": "cmp99c4az0000vov4w13rm6yl"
                        }
                      }
                    ]
                  },
                  {
                    "text": " stage.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour the hot caramel over the cooled shortbread base, level with a palette knife, and cool to room temperature. Chill in the fridge until firm, about 45 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Chocolate top, score, cut",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Melt the {{dark-chocolate}} in a heatproof bowl over barely simmering water. Pour over the firm caramel and tilt the tin to level.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Leave at cool room temperature until the chocolate is almost set but still slightly soft on top, about 15 minutes. Score into a 4x5 grid with a long sharp knife pressed lightly into the surface.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Once fully set, lift the slab from the tin using the paper overhang and cut along the score lines for twenty clean squares.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
