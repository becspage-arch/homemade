          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Side of eye:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I don't need to finish every thought.",
                    "type": "text"
                  }
                ]
