                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I'm allowed to let a thought pass unanswered.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Top of head:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I reclaim my attention from the loop.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
