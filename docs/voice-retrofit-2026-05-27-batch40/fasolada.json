      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Sweat the vegetables",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Warm 30 ml of the olive oil in a large saucepan over medium heat. Add the onion, carrot, and celery with a pinch of salt. Cook, stirring occasionally, for 12 to 15 minutes until softened and beginning to colour. Add the garlic and tomato purée and stir for 2 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Build the soup",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Add the tinned tomatoes, stock, beans, oregano, and bay leaves. Bring to a boil, then reduce to a steady simmer. Cook for 25 to 30 minutes (tinned beans) or 60 to 90 minutes (pre-cooked dried beans) until the beans are very tender and the broth has thickened. Crush a few beans against the side of the pan with a spoon to add body. Season and remove the bay leaves.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Finish with oil",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Remove from the heat. Pour the remaining 50 ml of olive oil into the soup and stir once. Ladle into bowls, scatter with parsley if using, and add another drizzle of olive oil at the table. Serve with good bread for tearing and dipping.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "Continue simmering uncovered for another 15 minutes; crush more beans against the pot wall",
              "cause": "Not enough simmering time or the beans weren't crushed for body",
              "symptom": "Soup is thin and watery"
            },
            {
              "fix": "Soak overnight and discard the soaking water; very old beans may need up to 2 hours of simmering",
              "cause": "Old dried beans or soaking water was hard",
              "symptom": "Dried beans remain hard after 90 minutes"
            },
            {
              "fix": "Season well and finish with a good pour of olive oil off the heat",
              "cause": "Insufficient salt or oil not added at the end",
              "symptom": "Soup tastes flat"
            },
            {
              "fix": "Add a pinch of sugar and simmer for another 10 minutes to soften the acidity",
              "cause": "Tinned tomatoes vary in acidity",
              "symptom": "Tomato flavour is too acidic"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Fasolada is eaten on cold winter evenings alongside olives, pickled vegetables, and a chunk of feta. The soup tastes better the next day, when the beans have had time to absorb the broth."
          }
        ]
      }
    ]
