      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry and chill, 1 hour",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub the cold {{unsalted-butter}} into the {{plain-flour}}, {{caster-sugar}}, and {{fine-sea-salt}}. Stop when the mixture looks like coarse crumbs.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add 5 to 7 tablespoons of ice-cold water, a tablespoon at a time, until the dough just comes together. Divide into two discs (one slightly larger). Wrap and refrigerate for at least 1 hour.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Toss the {{blueberries}}, halved {{strawberries}}, and {{raspberries}} with the {{caster-sugar}}, {{cornflour}}, {{lemon-juice}}, and {{lemon}} zest. Leave to sit for 10 minutes so the fruit releases some juice.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the larger pastry disc to a 30 cm circle and line the pie dish. Fill with the berry mixture.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the second disc and lay it over the top, or cut into strips for a lattice. Trim to 2 cm overhang and crimp the edges. Cut vents if using a solid top.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake, 50 to 55 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 200°C fan. Brush the top crust with {{eggs}} wash and scatter {{demerara-sugar}} over.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 20 minutes at 200°C. Reduce to 180°C and bake for a further 30 to 35 minutes. The crust should be deep golden and the filling bubbling through the vents.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cool on a rack for at least 1 hour before cutting.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
