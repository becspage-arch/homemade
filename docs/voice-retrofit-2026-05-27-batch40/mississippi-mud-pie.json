              "unit": "ml",
              "amount": 300,
              "prepNote": "whipped to soft peaks"
            }
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the base",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Preheat the oven to 175°C conventional (155°C fan). Crush the biscuits to fine crumbs in a food processor or in a sealed bag with a rolling pin.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Stir in the melted butter until the crumbs clump when pressed. Press firmly into the base and up the sides of a 23 cm springform tin. Refrigerate while you make the filling.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Melt the chocolate and butter together in a saucepan over low heat, stirring until smooth. Remove from the heat.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Whisk in the sugar, then beat in the eggs one at a time. Sift in the flour, cocoa, and salt and fold until combined and smooth.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake and chill",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour the filling over the crumb base. Bake for 30 to 35 minutes. The edges should be set and pulling away slightly from the tin; the centre should still wobble when gently shaken. A skewer inserted 3 cm from the edge will come out clean. One in the centre will still be wet. This is correct.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cool completely in the tin, then refrigerate for at least 2 hours. Run a knife around the edge and release the springform. Pile whipped cream on top and serve cold.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
