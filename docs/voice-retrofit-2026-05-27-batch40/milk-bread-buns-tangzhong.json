      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook the tangzhong",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Whisk 25 g {{strong-white-flour}}, 100 ml {{whole-milk}}, and 25 ml {{water}} in a small saucepan until smooth. Cook over medium-low heat, stirring constantly, until it thickens to a glossy paste that leaves a trail when you draw a line through it (about 65°C). Cool to room temperature.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Mix, knead, and bulk ferment, 1 hour",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine 315 g {{strong-white-flour}}, {{fast-action-yeast}}, {{fine-salt}}, and {{caster-sugar}}. Add the cooled tangzhong, lukewarm {{whole-milk}}, and {{whole-eggs}}. Mix to a rough dough, then add the {{unsalted-butter}} and knead for 10-12 minutes by hand or 7-8 minutes in a stand mixer until smooth and very elastic. The dough should be soft and slightly tacky but come away from the sides of the bowl. Cover and leave to bulk ferment until doubled, about 1 hour.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Shape and prove, 45 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Line a baking tray with baking paper. Divide the dough into 12 equal pieces. Shape each into a tight ball by pulling the surface down and pinching underneath. Arrange in a 3 x 4 grid on the lined tray, touching. Cover with oiled cling film and prove until doubled and the buns are visibly puffy and touching, about 45 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 190°C (170°C fan). Brush the buns gently with milk or beaten egg. Bake for 16-18 minutes until deep golden. Cool on the tray for 5 minutes, then transfer to a rack. Serve warm or at room temperature.",
            "type": "text"
          }
        ]
      }
    ]
