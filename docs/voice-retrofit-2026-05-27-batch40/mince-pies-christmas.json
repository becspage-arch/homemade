      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry, chill 30 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub the cold {{unsalted-butter}} into the {{plain-flour}} with your fingertips until the mixture resembles fine breadcrumbs. Stir in the {{icing-sugar}}.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat the {{egg-yolks}} with 1 tablespoon of cold water and add to the flour. Bring together into a smooth dough without overworking it. Wrap in cling film and refrigerate for 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the quick filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Combine the {{dried-currants}}, {{raisins}}, {{mixed-peel}}, grated {{apple-eating}}, {{dark-brown-sugar}}, {{unsalted-butter}}, {{mixed-spice}}, {{brandy}}, and the zest and juice of the {{lemon}} in a bowl. Stir well. The filling can be used straight away or left overnight to let the fruit absorb the brandy.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Line the tin, fill, add lids",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Preheat the oven to 190°C fan. Grease a 12-hole bun tin. Roll the pastry to 3 mm and cut circles to line the holes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Fill each case with a heaped teaspoon of filling, just below the rim. Cut lids or stars from the remaining pastry (see the ",
                    "type": "text"
                  },
                  {
                    "text": "mince pie lid options",
                    "type": "text",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termId": "cmpa2eeky0000e8v45xi026b8"
                        }
                      }
                    ]
                  },
                  {
                    "text": "). Press on firmly and chill the assembled pies for 15 minutes before baking.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake 18 to 20 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 18 to 20 minutes until the pastry is pale gold. Leave to cool in the tin for 5 minutes before lifting out. Dust generously with icing sugar while still warm.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
