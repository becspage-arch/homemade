        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "The shortcrust pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "ingredientsList",
        "content": [
          {
            "type": "ingredientItem",
            "attrs": {
