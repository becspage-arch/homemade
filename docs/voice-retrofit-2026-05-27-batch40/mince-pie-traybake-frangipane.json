              "unit": "g",
              "amount": 30,
              "prepNote": "for the top"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "slug": "icing-sugar",
              "unit": "tbsp",
              "amount": 2,
              "prepNote": "to dust, after baking"
            }
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and rest the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub the cold butter into the flour and icing sugar until the mixture resembles fine breadcrumbs. Mix in the egg yolk and enough cold water to bring the dough together, adding 1 to 2 tablespoons by the spoonful.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Press into a disc, wrap, and refrigerate for 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Line and chill",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "On a lightly floured surface, roll the pastry to about 3 mm thick and large enough to line a 30 x 20 cm baking tin with a little overhang. Press into the tin, including up the sides, and trim neatly.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Refrigerate for 15 minutes. Preheat the oven to 190°C conventional (170°C fan).",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fill and top",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Spread the mincemeat evenly over the pastry base.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Make the frangipane: beat the softened butter and caster sugar together until creamy. Beat in the eggs one at a time, then fold in the ground almonds, flour, and almond extract.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Spread the frangipane evenly over the mincemeat and scatter the flaked almonds over the top.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 30 to 35 minutes until the frangipane is deep golden brown, the sides have pulled slightly from the tin, and a skewer through the frangipane layer comes out clean.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cool in the tin, then dust generously with icing sugar and cut into fingers. Serve warm or at room temperature.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
