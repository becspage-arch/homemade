        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "The filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "ingredientsList",
        "content": [
          {
            "type": "ingredientItem",
            "attrs": {
              "slug": "mincemeat",
              "unit": "g",
              "amount": 400,
              "prepNote": "1 jar, good quality"
            }
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and chill the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub the cold butter into the flour and icing sugar until the mixture resembles fine breadcrumbs. Mix in the egg yolk and lemon zest.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add 1 to 2 tablespoons of cold water and mix until the dough just comes together. Flatten into a disc, wrap, and refrigerate for 20 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Preheat the oven to 200°C conventional.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cut, fill, and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the pastry to 3 mm thick on a lightly floured surface. Using a round cutter slightly larger than the holes in a 12-hole bun tin, cut 12 base rounds and press gently into the tin.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Fill each case with a heaped teaspoon of mincemeat, leaving room at the top for the lid. Cut star shapes or smaller round lids from the remaining pastry.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place the lids on top of the filled cases. If using a full round lid, brush the pastry rim with beaten egg first and press to seal. Brush the tops with beaten egg.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 12 to 15 minutes until pale golden. Cool in the tin for 5 minutes before easing out onto a rack. Dust with icing sugar before serving.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
