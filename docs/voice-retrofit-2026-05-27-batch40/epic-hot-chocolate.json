      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add all the chocolate mix ingredients to a large jar and shake well to combine."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pour the milk into a large pan and bring almost to the boil over a medium heat."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spoon around ten heaped tablespoons of the chocolate mix into the hot milk. Whisk well and leave to bubble gently for a few minutes until thick and glossy."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Salt a pinch at a time, tasting. A small splash of vanilla extract lifts the chocolate flavour.",
              "cause": "Underseasoned.",
              "symptom": "The drink tastes flat"
            },
            {
              "fix": "Whisk the mix into the milk before it fully boils. Keep the heat at medium and whisk continuously for the first minute.",
              "cause": "Mix added to boiling milk without whisking, or heat too high.",
              "symptom": "Lumps in the chocolate"
            },
            {
              "fix": "Simmer for another two or three minutes, whisking. The cornflour needs heat to thicken.",
              "cause": "Not cooked long enough after the mix went in.",
              "symptom": "Drink is thin rather than thick"
            },
            {
              "fix": "Reheat gently over low heat, whisking as it warms.",
              "cause": "Left standing too long.",
              "symptom": "Skin formed on top"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spiced: add a pinch of cayenne or cardamom to the dry mix for a warming edge."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Richer: use whole milk or swap half the milk for single cream."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The dry mix keeps in a sealed jar for up to two months. Made hot chocolate is best drunk fresh; reheat gently on the hob, whisking, if needed."
          }
        ]
      }
    ]
