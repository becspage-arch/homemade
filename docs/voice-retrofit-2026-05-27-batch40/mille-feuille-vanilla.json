              "quantity": 175,
              "isOptional": false,
              "ingredientSlug": "unsalted-butter"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "unit": "g",
              "prepNote": "for the pastry",
              "quantity": 3,
              "isOptional": false,
              "ingredientSlug": "sea-salt-fine"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "unit": "ml",
              "prepNote": "for the pastry cream",
              "quantity": 500,
              "isOptional": false,
              "ingredientSlug": "whole-milk"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "unit": "each",
              "prepNote": "large, for the pastry cream",
              "quantity": 5,
              "isOptional": false,
              "ingredientSlug": "egg-yolks"
            }
          },
          {
            "type": "ingredientItem",
