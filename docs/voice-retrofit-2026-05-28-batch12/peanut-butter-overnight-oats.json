  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Peanut Butter Overnight Oats. A British home-cook's dish, the kind of recipe families adjust across generations. Adjustable for what you need.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Made the night before; ready when you wake up. Adjust the liquid to suit your usual breakfast bowl.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "What you need",
            "type": "text"
          }
        ]
      },
      {
        "type": "ingredientsList",
        "attrs": {
          "items": [
            {
              "name": "Almond milk",
              "unit": "cup",
              "amount": 0.5,
              "prepNote": null,
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp5mo1tw0000wwv4ul001tao",
              "ingredientSlug": "almond-milk"
            },
            {
              "name": "Porridge oats",
              "unit": "cup",
              "amount": 0.3333333333333333,
              "prepNote": "I used gluten-free",
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49fa5p00cqrkv4r132ho8v",
              "ingredientSlug": "porridge-oats"
            },
            {
              "name": "Honey",
              "unit": "tsp",
              "amount": 1,
              "prepNote": "or sweetener of choice",
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49fazr00e4rkv4zukxsq02",
              "ingredientSlug": "honey"
            },
            {
              "name": "Peanut butter",
              "unit": "tbsp",
              "amount": 1,
