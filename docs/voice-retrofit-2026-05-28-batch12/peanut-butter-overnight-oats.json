              "ingredientId": "cmp49fafa00d7rkv4wo2ahave",
              "ingredientSlug": "peanut-butter"
            }
          ],
          "defaultServings": 4
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Mix all of the ingredients together in a small mason jar or bowl. Do not cook the oats, add them dry (they will soak up the liquid overnight).",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Close the jar with a lid or cover bowl with plastic wrap.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place in the fridge overnight.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "The next morning, top with sliced bananas or berries, peanut butter, honey and chocolate chips if desired. Serve cold.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Notes",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Overnight oats will keep in the fridge for up to 1 week.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Right before enjoying it, I like to add an extra splash of almond milk to keep oats creamy and moist.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Greek yoghurt",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Berries",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Loosen with a splash of cold milk in the morning. Jumbo oats hold their texture better than instant.",
              "cause": "Liquid soaked in fully, or oats were finer than rolled.",
              "symptom": "Oats too thick when chilled"
            },
            {
              "fix": "Soak for at least four hours or overnight. Stir in chia or ground flax before chilling. They thicken as they sit.",
              "cause": "Liquid ratio too high, or not enough soaking time.",
              "symptom": "Oats too runny"
            },
            {
              "fix": "A pinch of salt brings out the sweetness. Mash banana or stir in jam at the soaking stage so the flavour goes through.",
              "cause": "No salt, or fruit added in the morning, not the night before.",
              "symptom": "Tastes bland"
            },
            {
              "fix": "Eat within two days. Beyond that the oats turn pasty, better to mix a fresh batch.",
              "cause": "Mixture sat for more than 48 hours.",
              "symptom": "Texture is slimy"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Variations",
            "type": "text"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Chocolate version: stir a tablespoon of cocoa powder and a teaspoon of honey through with the oats.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Tropical: layer with diced mango and toasted coconut flakes in the morning.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Make ahead, freezing, leftovers",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Sits well in the fridge overnight; see the method for the chilling step. Designed as a make-ahead: assemble the night before, eat in the morning.",
            "type": "text"
          }
        ]
      },
