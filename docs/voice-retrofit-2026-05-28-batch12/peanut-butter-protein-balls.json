      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Put the no-stir peanut butter, honey, rolled oats, vanilla protein powder, salt, and mini dark chocolate chips into a mixing bowl. Use a rubber spatula to mix. Stop when the batter holds together.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Use a mini cookie scoop or a spoon to drop energy balls with a spoon onto a wax paper covered cookie sheet. They should be around 1 inch in size.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the energy balls with your hands to form the shape",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place cookie sheet with the energy bites on it in the fridge for 1 hour, or until the balls are hardened",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Transfer energy balls to a ziploc bag and store in the freezer",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Salt a pinch at a time, tasting. A squeeze of lemon or splash of vinegar at the end lifts most savoury dishes.",
              "cause": "Underseasoned or no acid.",
              "symptom": "The dish tastes flat"
            },
            {
              "fix": "Pull off the heat a minute or two before you think it's done. Plate straight away, or transfer to a warmed serving dish.",
              "cause": "Carryover cooking, food keeps cooking on the hot pan after the heat goes off.",
              "symptom": "It's overcooked by the time it reaches the table"
            },
            {
              "fix": "Drop the heat and give it longer. A probe thermometer is the only reliable check for meat.",
              "cause": "Heat too high, browned the outside before the middle warmed through.",
              "symptom": "It's undercooked in the middle"
            },
            {
              "fix": "Reheat covered with a splash of stock or water, on a low heat. Microwave on 60% power if using one, gentler than full blast.",
              "cause": "Reheated uncovered, or no liquid in the pan.",
              "symptom": "The leftovers were dry"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
