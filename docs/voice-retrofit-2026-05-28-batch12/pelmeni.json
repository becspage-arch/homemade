      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Mix the flour, salt, egg, and warm water in a bowl until a shaggy dough forms. Turn out and knead for 8 minutes until smooth and elastic. Wrap and rest for 30 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling and shape",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Mix the pork mince, onion, garlic, salt, and pepper. Keep cold. Roll the dough very thin on a floured surface, about 2 mm. Cut into circles using a 7 to 8 cm cutter or glass. Place a scant teaspoon of filling in the centre of each circle. Fold in half and press the edge firmly to seal, then bring the two corners of the half-moon together and press to form the bonnet shape. Set on a floured tray. Repeat with remaining dough and filling.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Boil and serve",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Bring a large pot of salted water to a boil. Cook the pelmeni in batches of 12 to 15 for 5 to 6 minutes until they float and the dough is tender. Drain and toss with butter. Serve with soured cream and a grinding of black pepper.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "Press the edges firmly and ensure no filling touches the border; a little water on the edge before sealing helps it stick",
              "cause": "Edges not sealed properly, or too much filling",
              "symptom": "Pelmeni burst open during boiling"
            },
            {
              "fix": "Roll to 2 mm and cook for no more than 6 minutes from fresh; from frozen allow 8 to 10",
              "cause": "Rolled too thick or overcooked",
              "symptom": "Dough is chewy and tough"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Pelmeni come from Siberia. They sit in the wider Ural-Altaic family of filled dumplings, alongside Chinese jiaozi, Mongolian buuz, and Georgian khinkali. In Siberia they were made at the start of winter and frozen outdoors in their thousands. They were fast food through the cold months. Today they are eaten across Russia and sold in every supermarket freezer. The homemade version, eaten fresh with butter, is another thing entirely.",
            "type": "text"
          }
        ]
      }
    ]
  },
