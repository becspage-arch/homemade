    "practiceTargets": [
      "JOY",
      "SELF_WORTH"
    ],
    "timeBand": "FIVE_MIN",
    "bestTime": "AS_NEEDED",
    "practiceDepth": "BEGINNER",
    "whenToUse": "When enjoyment or rest is immediately followed by guilt, the sense that you should be doing something useful instead",
    "whenNotToUse": null,
