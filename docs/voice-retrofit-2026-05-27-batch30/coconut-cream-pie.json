      {
        "type": "paragraph",
        "content": [
          {
            "text": "The filling here is a ",
            "type": "text"
          },
          {
            "text": "coconut pastry cream",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "term": "coconut pastry cream",
                  "termId": "cmpbcyj6s0000mkv4hi6elyxf"
                }
              }
            ]
          },
          {
            "text": " made entirely with coconut milk, no dairy. The result is firm, sliceable, and deeply flavoured. The ",
