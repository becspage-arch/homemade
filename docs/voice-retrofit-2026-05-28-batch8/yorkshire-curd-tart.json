            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "unit": "each",
              "prepNote": "freshly grated; or about 1 tsp pre-ground",
              "quantity": 0.5,
              "isOptional": false,
              "ingredientSlug": "nutmeg-whole"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "unit": "each",
