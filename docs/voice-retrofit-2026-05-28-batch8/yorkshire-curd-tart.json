            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "unit": "g",
              "prepNote": "or ricotta, well drained",
              "quantity": 300,
              "isOptional": false,
              "ingredientSlug": "cream-cheese"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "unit": "g",
              "prepNote": "for the filling",
              "quantity": 100,
              "isOptional": false,
