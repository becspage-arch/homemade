      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Prepare and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Preheat the oven to 170°C conventional. Grease and line a 23 cm round tin. Process the pistachios in a food processor until they reach a fine, dry crumb, stop before the oils release. Beat the butter and sugar until pale and fluffy. Add the eggs one at a time, beating well after each. Fold in the ground pistachios, flour, and baking powder in two additions, then the almond extract.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake and cool",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Pour the batter into the prepared tin and smooth the top. Bake for 35 to 40 minutes until the top is set and a skewer comes out with just a few moist crumbs. The cake will be pale on top. Cool in the tin for 20 minutes, then transfer to a rack. It sinks very slightly in the centre as it cools; this is normal.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Finish and serve",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Beat the mascarpone and sifted icing sugar together until smooth. Spread over the top of the completely cool cake and scatter the chopped pistachios over the cream. Serve at room temperature; the mascarpone cream softens if the cake is refrigerated for more than an hour.",
            "type": "text"
          }
        ]
      }
    ]
