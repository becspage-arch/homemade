      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Soften the onion",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt {{unsalted-butter}} of butter in a saucepan over a low heat. Add the {{onion}} onion and cook gently for 10 to 12 minutes until soft. Remove from the heat and allow to cool.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Mix and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 180°C (160°C fan). Combine the {{sausagemeat}}, {{chestnut-cooked}}, cooled onion mixture, {{sage}}, thyme leaves, {{breadcrumbs-fresh}}, {{eggs}}, {{sea-salt-flakes}}, and {{black-pepper}} in a large bowl. Mix thoroughly with your hands until evenly combined. Press into a buttered baking dish in an even layer. Bake for 40 to 45 minutes until the top is well browned and the stuffing is cooked through to 75°C at the centre.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "rows": [
            {
              "fix": "Pour off any excess fat at the 30-minute mark and continue baking. Use a good-quality pork sausagemeat with a reasonable fat-to-meat ratio.",
              "cause": "High fat content sausagemeat releasing excess fat during baking",
              "symptom": "Stuffing greasy on top"
            },
            {
              "fix": "The sausagemeat provides most of the binding; if it is very lean, add another beaten egg or a little more butter when mixing.",
              "cause": "Insufficient fat or egg in the mix",
              "symptom": "Dry and crumbly texture"
            }
          ]
        },
        "content": []
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Chestnut and sausagemeat stuffing is the stuffing for the British Christmas table, appearing alongside the turkey as reliably as Brussels sprouts. It also works well with a large roast chicken or a brace of pheasants. The chestnut season in Britain runs from October through to December, which is why the stuffing is so strongly associated with the autumn and Christmas period.",
            "type": "text"
          }
        ]
      }
    ]
