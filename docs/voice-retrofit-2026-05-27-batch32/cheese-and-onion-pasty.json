      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Grate the potato on a coarse grater and immediately wrap in a clean cloth. Squeeze out as much moisture as possible. Combine with the ",
            "type": "text"
          },
          {
            "text": "{{cheddar}} of grated cheddar",
            "type": "text"
          },
          {
            "text": ", ",
            "type": "text"
          },
          {
            "text": "{{onion}} finely chopped onion",
            "type": "text"
          },
          {
            "text": ", ",
            "type": "text"
          },
          {
            "text": "{{sea-salt-flakes}}",
            "type": "text"
          },
          {
            "text": ", ",
            "type": "text"
          },
          {
            "text": "{{black-pepper}}",
            "type": "text"
          },
          {
            "text": " and mustard powder if using. The filling should be dry enough to hold its shape when squeezed.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Shape and seal",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Divide the ",
            "type": "text"
          },
          {
            "text": "{{shortcrust-pastry}} of shortcrust pastry",
            "type": "text"
          },
          {
            "text": " into 4 pieces. Roll each into a rough circle about 22 cm across and 3 mm thick. Place a quarter of the filling on one half of each circle, leaving a 2 cm border. Moisten the border with water, fold the empty half over, and press firmly to seal. Crimp along the top curved edge with a fork or use a rope twist. Place on a lined baking tray and chill for 20 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 200°C (180°C fan). Brush all surfaces with beaten egg. Make a small vent hole in the top of each pasty. Bake for 40-45 minutes until deep golden. The potato is cooked when a skewer pushed through the vent meets no resistance.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "rows": [
            {
              "fix": "Aim for no more than 2 cm of filling depth. Pierce with a skewer to test: the potato should feel soft.",
              "cause": "Filling too thick, or bake time too short",
              "symptom": "Potato is still hard in the centre"
            },
            {
              "fix": "Squeeze out as much water as possible; a cloth works better than kitchen paper for this.",
              "cause": "Grated potato was too wet",
              "symptom": "Pastry is soggy from the inside"
            },
            {
              "fix": "Moisten the pastry border thoroughly before pressing. Do not overfill.",
              "cause": "Seam not well sealed, or too much filling",
              "symptom": "Filling spills out during baking"
            },
            {
              "fix": "Keep cheese away from the very edge of the filling. Check for thin spots in the pastry before sealing.",
              "cause": "A crack in the pastry, or cheese was placed near the seam edge",
              "symptom": "Cheese has oozed out and burned on the tray"
            }
          ]
        },
        "content": []
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cheese and onion pasties are the vegetarian companion to the Cornish pasty. They are bakery food, school lunch food, and the thing to make when you need something satisfying with minimal fuss. Eaten hot they are savoury and comforting; cold from the fridge the next day, they are just as good.",
            "type": "text"
          }
        ]
      }
    ]
