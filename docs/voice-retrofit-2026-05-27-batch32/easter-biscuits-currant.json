      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Prepare",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 180°C fan. Line two baking trays with baking paper.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Beat the {{unsalted-butter}} and {{caster-sugar}} together until pale. Beat in the egg yolk and the zest of the {{lemons}}. Mix in the {{plain-flour}}, {{mixed-spice}}, and {{fine-sea-salt}} until a dough forms. Stir in the {{currants}}. If the dough feels soft, refrigerate for 15 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Roll and cut",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Roll the dough on a lightly floured surface to 5 mm thick. Cut rounds with a 6 cm cutter. Place on the lined trays with 3 cm between them.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake, 10 to 12 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Bake for 5 minutes. Remove from the oven and brush the surfaces lightly with the reserved egg white. Sprinkle with a little extra {{caster-sugar}}. Return to the oven for a further 5 to 7 minutes until pale golden and the sugar has set to a gloss. Cool on a rack.",
            "type": "text"
          }
        ]
      }
    ]
  },
