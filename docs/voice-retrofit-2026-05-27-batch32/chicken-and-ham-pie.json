      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt ",
            "type": "text"
          },
          {
            "text": "{{unsalted-butter}} of butter",
            "type": "text"
          },
          {
            "text": " in a large saucepan over medium heat. Add the ",
            "type": "text"
          },
          {
            "text": "{{onion}} finely chopped onion",
            "type": "text"
          },
          {
            "text": " and cook gently for 8 minutes until soft. Add the leeks and cook for 3 minutes. Stir in ",
            "type": "text"
          },
          {
            "text": "{{plain-flour}} of flour",
            "type": "text"
          },
          {
            "text": " and cook for 2 minutes. Gradually add ",
            "type": "text"
          },
          {
            "text": "{{stock-chicken}} of chicken stock",
            "type": "text"
          },
          {
            "text": ", stirring constantly. Add the ",
            "type": "text"
          },
          {
            "text": "{{double-cream}} of cream",
            "type": "text"
          },
          {
            "text": " and thyme leaves. Simmer for 5 minutes until the sauce is thick enough to coat the back of a spoon. Season generously. Off the heat, stir in the pulled chicken and ham. Cool completely before filling the pie.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Line the dish and fill",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "On a lightly floured surface, roll out two thirds of the ",
            "type": "text"
          },
          {
            "text": "{{shortcrust-pastry}} of shortcrust pastry",
            "type": "text"
          },
          {
            "text": " to 4 mm thickness. Use it to line a deep 23-24 cm pie dish, leaving an overhang. Chill for 30 minutes. Spoon in the cooled filling. Roll the remaining pastry for the lid. Dampen the pastry rim with water and lay the lid on top. Press the edges to seal and trim. Cut a steam vent in the centre. Brush the lid with beaten egg.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 200°C (180°C fan). Bake for 50-55 minutes until the lid is deep golden and the filling is bubbling through the steam vent. If the pastry colours before the filling heats through, cover loosely with foil. Rest for 10 minutes before cutting.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "rows": [
            {
              "fix": "Cool the filling completely before assembling. A slightly thicker sauce (reduce by an extra 2 minutes) helps. The bottom pastry will always be softer than the top; this is normal for a fully enclosed pie.",
              "cause": "Filling was too wet, or the pie was assembled while the filling was still warm",
              "symptom": "Pastry base is soggy"
            },
            {
              "fix": "Press the edges firmly and crimp with a fork. Do not overfill; leave 1 cm of headspace.",
              "cause": "Edges not properly sealed, or filling was overfilled",
              "symptom": "Filling leaks through the lid seams during baking"
            },
            {
              "fix": "Use undiluted beaten egg for a darker finish. Increase the temperature to 210°C for the last 10 minutes.",
              "cause": "Egg wash was too thin, or the oven temperature was too low",
              "symptom": "Pastry lid is pale despite egg wash"
            },
            {
              "fix": "Make the sauce thicker: it should look slightly over-sauced before going into the dish.",
              "cause": "Sauce was too thin before baking, and absorbed fully into the pastry",
              "symptom": "Sauce has disappeared and the filling is dry"
            }
          ]
        },
        "content": []
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Chicken and ham pie is the archetypal British savoury pie: a two-crust, deep-filled pastry that turns leftover roast chicken into something that feels like occasion cooking. It has appeared in British households for centuries under various names, and its appeal has not diminished. Cold from the fridge the next day, it is arguably better than when it was first cut.",
            "type": "text"
          }
        ]
      }
    ]
