            "marks": [
              {
                "type": "link",
                "attrs": {
                  "href": "/mindset/how-energy-statements-work"
                }
              }
            ]
          },
          {
            "text": ", the principles overlap.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "The practice",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "\"In this family\" is load-bearing. It places the claim in a group, not just in you, which makes it feel both broader and more real.",
            "type": "text"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "In this family we hold money well.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "How to use it",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Say it three times in the morning, hand on heart. Let the word \"family\" bring whoever comes to mind, present family, future family, or the family you choose. If a phrase doesn't feel like you, change it.",
            "type": "text"
          }
        ]
