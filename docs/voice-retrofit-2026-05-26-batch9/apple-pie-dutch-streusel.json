      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and rest the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Rub the cold butter into the flour and icing sugar until the mixture resembles fine breadcrumbs. Add the egg yolk and enough cold water to bring the dough together. Press into a disc, wrap, and refrigerate for 30 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Line and blind-bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Preheat the oven to 190°C conventional (170°C fan). Roll the pastry to 3 mm thick and line a 23 cm round cake tin or pie dish. Trim and crimp the edge. Line with baking paper, fill with baking beans, and blind-bake for 15 minutes. Remove the beans and paper and bake for a further 5 minutes until the base is pale and matte.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fill",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Toss the apple slices with the sugar, cinnamon, lemon juice, and cornflour. Pile into the pastry case, the filling should mound above the tin rim as the apples compress during baking.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Streusel and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Make the streusel by rubbing the cold butter into the flour, oats, sugar, and cinnamon until the mixture forms clumps. Scatter evenly over the apple filling. Bake for 45 to 50 minutes until the streusel is deep golden and the filling is bubbling at the edges. If the streusel browns too quickly, cover loosely with foil. Cool for 20 minutes before slicing; the filling needs to set slightly.",
            "type": "text"
          }
        ]
      }
    ]
