        "content": [
          {
            "type": "text",
            "text": "A short energy statement for the morning after easy income arrived. It also works in the moment you notice the guilt or the suspicion about it."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "New to energy statements? Read ",
            "type": "text"
          },
          {
            "text": "how energy statements work",
            "type": "text",
            "marks": [
              {
                "type": "link",
                "attrs": {
                  "href": "/mindset/how-energy-statements-work"
                }
              }
            ]
          },
          {
            "text": " first.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "The practice",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Release (repeat x3)",
            "type": "text"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I am ready to release the belief that money must be hard to earn. I release it now. I release it now. I release it now.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Allow (repeat x3)",
            "type": "text"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I am ready to align with and allow money coming to me with ease. I allow it now. I allow it now. I allow it now.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Say each three times, slow, out loud or in your mind.",
            "type": "text"
          }
        ]
      },
