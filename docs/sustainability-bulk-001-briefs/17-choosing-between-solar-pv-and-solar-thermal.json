    {
      "slug": "solar-pv",
      "term": "Solar PV",
      "definition": "Photovoltaic solar panels that convert sunlight to electricity. Versatile output — can power any electrical load, charge a battery, or export to the grid."
    },
    {
      "slug": "solar-thermal",
      "term": "Solar thermal",
      "definition": "Solar panels that heat a fluid (water or glycol) directly using the sun's heat. Higher thermal efficiency than PV per m² but limited to producing hot water."
    },
    {
      "slug": "kwp",
      "term": "kWp",
      "definition": "Kilowatt-peak. The rated electrical output of a solar PV system under standard test conditions."
    }
