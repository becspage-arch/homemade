  "glossaryTerms": [
    {
      "slug": "cn-ratio",
      "term": "C:N ratio",
      "definition": "Carbon-to-nitrogen ratio. The proportion of carbon to nitrogen in compost material, measured by mass. Target for active composting: 25–30:1. Too high (carbon excess): slow decomposition. Too low (nitrogen excess): ammonia smell."
    },
    {
      "slug": "browns-and-greens",
      "term": "Browns and greens",
      "definition": "Practical categories for compost materials. Browns (high C:N): cardboard, straw, wood chip, dry leaves. Greens (low C:N): grass clippings, food scraps, fresh plant material, coffee grounds."
    }
  ],
