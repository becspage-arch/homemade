    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Five affirmations for the age you are, not the one you are waiting to be young enough to return to."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {"level": 2},
        "content": [{"type": "text", "text": "The practice"}]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "My age is mine. I am not behind it or ahead of it."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I have earned what I know."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "The version of me that is here took everything that came before to build."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I am allowed to take up space at this age."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I am not finished. I am here."}]}]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {"level": 2},
        "content": [{"type": "text", "text": "Where this practice comes from"}]
