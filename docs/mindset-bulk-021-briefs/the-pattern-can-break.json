            "text": "Five affirmations for the person working to shift a pattern in a relationship. Read them before the conversation you are most likely to get wrong."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {"level": 2},
        "content": [{"type": "text", "text": "The practice"}]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "This pattern is not permanent."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I can respond differently and that changes the shape of what comes next."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Connection is still possible here."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I stay curious about us rather than certain."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Small moves in me change the whole direction."}]}]
