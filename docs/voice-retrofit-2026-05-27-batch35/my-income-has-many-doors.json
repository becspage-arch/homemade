        },
        "content": [
          {
            "text": "The practice",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Release (repeat x3)",
            "type": "text"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I am ready to release the belief that income can only come from one source. I release it now. I release it now. I release it now.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Allow (repeat x3)",
            "type": "text"
          }
        ]
      },
      {
        "type": "blockquote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I am ready to align with and allow income through many doors. I allow it now. I allow it now. I allow it now.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Say each three times, slow, out loud or in your mind.",
            "type": "text"
          }
        ]
