      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake the sponge layers",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan. Grease and line three 20 cm round tins (or bake in batches).",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat {{unsalted-butter}} and {{caster-sugar}} until pale and fluffy. Beat in {{eggs}} one at a time. Fold in {{self-raising-flour}}, {{cocoa-powder}}, and {{whole-milk}} until combined.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Divide the batter equally between three tins. Bake for 22 to 25 minutes each. Cool completely on racks before filling.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the fillings",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "White chocolate cream: heat {{double-cream}} to a simmer, pour over {{white-chocolate}}, stir until melted. Cool to room temperature, then chill for 30 minutes until the consistency of thick cream. Whisk briefly before using.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Milk chocolate buttercream: beat {{unsalted-butter}} until pale and creamy. Add {{icing-sugar}} in two additions. Beat in {{milk-chocolate}} until smooth. Continue beating until light and fluffy.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Dark ganache: heat {{double-cream}} to a simmer, pour over {{dark-chocolate}}, stir until completely smooth. Leave to cool to a pourable but not hot consistency, about 20 to 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place the first sponge layer on a board. Spread with the white chocolate cream. Add the second layer and spread with the milk chocolate buttercream. Add the third layer. Smooth any buttercream around the sides to seal the edges.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour the dark ganache over the top of the assembled cake, letting it drip down the sides. Leave at room temperature for at least 20 minutes for the ganache to set before serving.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
