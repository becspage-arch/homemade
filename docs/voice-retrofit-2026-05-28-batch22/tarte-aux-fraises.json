      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and blind-bake the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub {{plain-flour}}, {{icing-sugar}}, and {{unsalted-butter}} (the pastry quantity) together until the mixture resembles fine breadcrumbs. Add the egg yolk and {{vanilla-extract}} and mix to a firm dough, adding a teaspoon of cold water if needed. Flatten, wrap, and refrigerate for 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan (190°C conventional). Roll the pastry to 3 mm thick on a floured surface and line the tart tin. Press into the edges and trim the overhang. Refrigerate for 15 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Line the pastry case with baking paper and fill with baking beans. Bake for 15 minutes, then remove the paper and beans and bake for a further 8 to 10 minutes until pale golden and dry to the touch. Cool completely.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry cream",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat {{whole-milk}} and {{vanilla-extract}} in a saucepan until steaming. Whisk the egg yolks, {{caster-sugar}}, and {{cornflour}} together in a bowl until smooth.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour the hot milk slowly over the egg mixture, whisking constantly. Return everything to the pan and cook over medium heat, stirring constantly with a wooden spoon or spatula, until the cream thickens and bubbles. Cook for 1 minute more, then remove from the heat.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Stir in the butter quantity of {{unsalted-butter}} until melted. Press a sheet of cling film directly onto the surface to prevent a skin forming. Refrigerate until cold, at least 1 hour.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Whisk the chilled pastry cream briefly until smooth. Spread it into the cooled pastry case in an even layer.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Arrange {{strawberries}} on top, standing them cut-side down or halved, working from the outside in. Brush gently with the warmed {{jam}} glaze.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "The pastry cream is the part most people find difficult the first time.",
          "items": [
            {
              "fix": "Pass through a fine sieve while still warm. If it has scrambled, it cannot be recovered; make it again. Medium heat and constant stirring prevents this.",
              "cause": "Heat too high, or not stirred constantly.",
              "symptom": "Pastry cream lumpy after cooking."
            },
            {
              "fix": "Always chill the lined case before blind baking. The 15-minute refrigeration is not optional.",
              "cause": "Pastry stretched into the tin rather than pressed, or not chilled before baking.",
              "symptom": "Pastry case shrinking during blind baking."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
  },
