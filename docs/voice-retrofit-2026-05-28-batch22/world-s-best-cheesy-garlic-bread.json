      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Preheat oven to 400 degrees",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "In a small bowl, mix together butter, minced garlic, garlic powder, parsley, and parmesan cheese.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Slice the Italian bread into 1/2 inch slices, and spread the butter mixture over each piece.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place on a baking tray.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Sprinkle with a little paprika.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 10 minutes until the butter mixture is melted, and the bread is slightly toasted.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Remove from oven, and sprinkle with mozzarella cheese",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Turn oven to broil, and return bread to oven, broiling until cheese is melted, and edges are golden brown (1-2 minutes)",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Check yeast in warm water with a pinch of sugar. It should froth in five minutes. Prove in a warm spot (airing cupboard or oven with the light on).",
              "cause": "Yeast was stale, or the dough was too cold.",
              "symptom": "Bread is dense and didn't rise"
            },
            {
              "fix": "Preheat to 220°C with a tray on the bottom. Throw a cup of water into the tray when the loaf goes in, steam gives crust.",
              "cause": "Oven not hot enough, or no steam.",
              "symptom": "Crust is pale and soft"
            },
            {
              "fix": "Give it longer, until the dough doesn't spring back when poked. Shape gently so the bubbles survive.",
              "cause": "Underproved, or the dough was knocked back too hard.",
              "symptom": "Open crumb wasn't open"
            },
            {
              "fix": "Bake on a heavier tray on the middle shelf. Lining with baking paper helps.",
              "cause": "Tray was too thin, or rack too low.",
              "symptom": "Bottom burnt before top browned"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Variations",
            "type": "text"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Seeded crust: brush the top with water and roll in mixed seeds before the final prove.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Wholemeal: replace 100 g of the flour with wholemeal for a denser, nuttier loaf.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Make ahead, freezing, leftovers",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A British home cook's dish. It sits among the recipes families remember without thinking about, the kind that gets adjusted across generations and never quite the same twice.",
            "type": "text"
          }
        ]
      }
    ]
