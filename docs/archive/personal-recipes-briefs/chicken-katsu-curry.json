  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Chicken katsu curry. Built in the way Chinese home kitchens cook: fast at the wok, balance at the bowl. Adjustable for what you need."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Spices in hot oil first; aromatics second; everything else third. The order matters — it builds the layers that show up at the bowl."
          }
        ]
      },
