        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "1. Preheat the oven to 130C/110Cfan/gas1. Put 2-3 200g jam jars in the oven for 15 minutes to sterilise them. 2. Add the lemon juice, lemon zest, butter and sugar to a heatproof bowl placed over a pan of simmering water. 3. Once the butter has melted – the mixture will be thick and glossy –, add the beaten egg through a sieve and whisk with a balloon whisk or wooden spoon until the curd is thick and creamy, approx ten minutes. It should coat the back of a spoon. When you’re ready to pot add the limoncello to the curd and then straight into the jars."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cooks Tips..."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "On no account must the fruit mixture boil or it may curdle. Store in a cool, dark place and use within 4 weeks."
                  }
                ]
              }
            ]
          }
        ]
      },
