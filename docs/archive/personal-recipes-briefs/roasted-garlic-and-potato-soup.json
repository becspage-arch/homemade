      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove white papery skin from each garlic head (do not peel or separate cloves). Wrap each head separately in aluminium foil. Bake at 350° for 1 hour; let cool for 10 minutes. Separate cloves, and squeeze to extract 1/4 cup of garlic pulp; discard the skins."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cook bacon in a large saucepan over medium-high heat until crisp. Add onion, carrot, and minced garlic, and sauté 5 minutes. Add potato, broth, salt, pepper, and bay leaf; bring to a boil. Cover, reduce heat, and simmer for 20 minutes or until potato is tender; remove bay leaf."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Combine garlic pulp and 2 cups potato mixture in a blender or food processor, and process until smooth. Return purée to pan; stir in milk, and cook over low heat until thoroughly heated. Remove from heat, and stir in chopped parsley."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "If something goes wrong",
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "symptom": "The soup tastes flat",
              "cause": "Underseasoned, or the aromatics weren't sweated long enough.",
              "fix": "Add salt a pinch at a time, tasting. If still flat, finish with a squeeze of lemon or a splash of vinegar to lift it."
            },
            {
              "symptom": "Cream-based soup splits",
              "cause": "Dairy added at too high a heat, or left to simmer after.",
              "fix": "Stir cream in off the heat, or use crème fraîche, which doesn't split. Don't reboil after adding."
            },
            {
              "symptom": "Blended soup is too thick",
              "cause": "Reduced too far, or the starch in the veg sets up on cooling.",
              "fix": "Loosen with hot stock or water, a ladle at a time, until it pours from the spoon in a ribbon."
            },
            {
              "symptom": "Blended soup is too thin",
              "cause": "Stock-to-veg ratio too high.",
              "fix": "Simmer uncovered to reduce, or blitz in another roasted veg (potato, parsnip) to thicken."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Vegan version: swap dairy cream for cashew cream (soak 100 g cashews in hot water, blend smooth) or oat cream."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Smokier finish: stir in a teaspoon of smoked paprika at the end, or top with crispy chorizo."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
