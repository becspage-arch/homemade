      {
        "type": "infoPanel",
        "attrs": {
          "tone": "info",
          "title": "Also",
          "body": "Cake."
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to 350°F (180°C/ 160°C fan/ Gas mark 4). Lightly grease 2 x 20cm/8inch round baking pans."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Stir the lemon juice (or vinegar) into the milk and set aside to thicken and 'curdle' slightly into buttermilk."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a pot over a medium heat, melt the butter, syrup and coffee (if using) together. Set aside to cool slightly."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Sift the flour, cocoa, sugar, baking powder and baking soda into a large mixing bowl and whisk together."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pour the milk and melted margarine mixture over the flour mixture and stir well until it becomes a smooth batter."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Divide the mixture between the two prepared pans and bake for 30-35 minutes or until an inserted skewer or toothpick comes out clean."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Allow the cakes to cool in the tins for 5 minutes, then turn out onto a cooling rack to cool completely."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Meanwhile, to make the icing beat together all ingredients until smooth."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "When the cakes are completely cold, sandwich together with half of the icing. Spread the remaining icing over the top of the cake."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "If something goes wrong",
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "symptom": "Cake sinks in the middle",
              "cause": "Underbaked, or the oven door opened too early.",
              "fix": "Test with a skewer — it should come out with a few moist crumbs, not wet batter. Don't open the oven before three-quarters of the bake time."
            },
            {
              "symptom": "Cake is dry",
              "cause": "Overbaked, or too much flour measured by cup not weight.",
              "fix": "Check at the minimum bake time and every five minutes after. Weigh flour for cake recipes — cup measures vary by 20% depending on how you scoop."
            },
            {
              "symptom": "Top cracked or domed",
              "cause": "Oven too hot, or batter too thick.",
              "fix": "Drop the temperature by 10°C and check earlier. Domed cakes can be trimmed flat once cool."
            },
            {
              "symptom": "Cake didn't rise",
              "cause": "Raising agent stale or omitted, or butter and eggs cold.",
              "fix": "Check baking powder is fresh — it loses lift after six months. Use room-temperature butter and eggs so the batter holds air."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Citrus version: replace the vanilla with the zest of an orange or lemon."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Nut-free: swap ground almonds for desiccated coconut or extra plain flour, weight for weight."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A British home cook's dish. It sits among the recipes families remember without thinking about — the kind that gets adjusted across generations and never quite the same twice."
          }
        ]
      }
    ]
  }
