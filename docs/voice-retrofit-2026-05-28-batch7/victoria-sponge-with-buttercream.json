    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "The Victoria sponge is built on the ",
            "type": "text"
          },
          {
            "text": "creaming method",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termId": "cmp6kpkd50000r8v4ph4e5wbq"
                }
              }
            ]
          },
          {
            "text": ": butter and sugar beaten together until pale and fluffy, then eggs added one at a time, then flour folded in. The equal weights of each main ingredient make it simple to scale, weigh the eggs first and use the same weight of everything else.",
            "type": "text",
            "marks": []
          }
        ]
