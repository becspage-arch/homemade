      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook the pasta",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cook {{pasta-dried}} of macaroni in a large pan of well-salted boiling water for 2 minutes less than the packet says. Drain and set aside.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the cheese sauce",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt {{unsalted-butter}} of butter in the same saucepan over medium heat. Add {{plain-flour}} of flour and stir for 2 minutes. Gradually pour in {{whole-milk}} of milk, whisking constantly, until smooth. Cook for 5 minutes, stirring often, until the sauce is thick and coats the back of a spoon. Remove from the heat. Stir in {{cheddar}} of grated cheddar, {{english-mustard}} of English mustard, {{nutmeg-ground}} of nutmeg, {{sea-salt-fine}} of salt and {{black-pepper}} of pepper until the cheese is melted and smooth.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 190°C. Stir the pasta into the cheese sauce and pour into the baking dish. Mix {{breadcrumbs-dried}} of breadcrumbs with the remaining {{cheddar}} of cheddar and scatter evenly over the top. Bake for 20 to 25 minutes until the top is golden and the sauce is bubbling at the edges. Leave to rest for 5 minutes before serving.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Troubleshooting",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": null,
          "items": [
            {
              "fix": "Always add cheese off the heat. Grate cheese fresh; pre-grated blends poorly.",
              "cause": "Cheese added to a boiling sauce, or pre-grated cheese with anti-caking agents.",
              "symptom": "Sauce grainy or split"
            },
            {
              "fix": "Always undercook the pasta by 2 minutes. The sauce should be pourable before baking; it thickens further in the oven.",
              "cause": "Pasta fully cooked before going in, or sauce too thick.",
              "symptom": "Stodgy, dry mac after baking"
            },
            {
              "fix": "A mix of breadcrumbs and cheese gives a better crust than cheese alone. Switch to the grill for the last 3 minutes if the top needs more colour.",
              "cause": "Too much cheese on top, or oven not hot enough.",
              "symptom": "Crust not crisping"
            }
          ],
          "heading": "Common problems"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "American mac and cheese occupies an unusual position in the food culture: it is simultaneously the box dinner of childhood and, in restaurants, a dish chefs compete to make the richest version of. The baked, breadcrumbed version is the one worth making from scratch. It is a Saturday night dish or a weeknight treat that costs almost nothing and is eaten quietly and with commitment.",
            "type": "text"
          }
        ]
      }
    ]
