      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cut and bake the cases, 20 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Preheat the oven to 200°C fan. Roll the {{puff-pastry}} to 4 mm thick on a lightly floured surface. Cut 24 circles with an 8 cm cutter. Cut a 5 cm circle from the centre of 12 of the circles to make rings. Place the whole circles on a lined baking tray. Top each with a ring, pressing lightly to adhere. Brush the top surface of the rings only with beaten {{eggs}}, avoid the sides. Bake for 18 to 20 minutes until risen and deep gold. Press the inner disc down with a teaspoon to form the hollow. Cool on a rack.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt the {{unsalted-butter}} in a wide pan over medium heat. Soften the {{shallot}} and {{garlic}} for 3 minutes. Add the {{mushrooms-chestnut}} and {{thyme-fresh}} and cook, stirring, until all the liquid has evaporated and the mushrooms are beginning to colour, about 8 minutes. Pour in the {{double-cream}} and simmer for 3 to 4 minutes until the sauce is thick enough to mound on a spoon. Season with {{sea-salt-fine}} and {{black-pepper}}. Spoon the filling into the warm or room-temperature cases and serve immediately.",
            "type": "text"
          }
        ]
      }
    ]
