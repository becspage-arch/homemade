      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the stock and prepare the seafood"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "If using prawn shells: fry the shells in a little olive oil in a saucepan for 3 minutes until bright red, then cover with 1.2 litres of water. Simmer for 20 minutes, then strain. This makes a quick prawn stock to supplement or replace the fish stock."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Build the paella"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat {{olive-oil}} in the paella pan over medium heat. Cook the onion for 5 minutes until soft. Add the garlic and cook for 1 minute. Add the grated tomato and cook for 8 minutes until the sofrito is thick and dark. Add {{paprika-smoked}} of smoked paprika and stir for 30 seconds."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the squid rings and stir for 2 minutes. Scatter {{paella-rice}} of rice evenly over the pan. Pour in {{stock-fish}} of warm stock and the saffron water. Stir once. Bring to a boil over high heat and cook for 10 minutes without stirring."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Reduce to medium-low. Lay the prawns and mussels on top of the rice, pressing them gently into the surface. Cook for 8 more minutes until the mussels have opened and the rice has absorbed the stock. Discard any mussels that have not opened."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Increase the heat to high for 1 to 2 minutes to form the socarrat. Remove from the heat, rest for 5 minutes, then scatter with parsley and serve with lemon wedges."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "symptom": "The prawns are overcooked and rubbery",
              "cause": "Added too early",
              "fix": "Prawns need only 3 to 4 minutes to cook. Add them during the last 8 minutes alongside the mussels so they don't toughen."
            },
            {
              "symptom": "Several mussels didn't open",
              "cause": "Dead mussels before cooking, or insufficient heat",
              "fix": "Discard any mussels that didn't open after cooking. They should not be forced open. Ensure the pan is hot enough for the mussels to open."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Seafood paella is at home at long summer lunches by the Mediterranean. In Spain it is eaten at midday, outdoors if possible, as a centrepiece for a gathering. It does not transport or reheat well, so it should be made and eaten immediately from the pan."
          }
        ]
      }
    ]
  }
