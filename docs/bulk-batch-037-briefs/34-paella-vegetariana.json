      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat {{extra-virgin-olive-oil}} in the paella pan over medium-high heat. Cook the pepper strips for 6 minutes until softened and lightly coloured. Add the artichoke hearts and cook for 3 minutes more. Push everything to the sides of the pan."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In the centre of the pan, cook the garlic over medium heat for 1 minute. Add the grated tomato and cook for 8 minutes until thick and dark. Stir in {{paprika-smoked}} of smoked paprika."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the chickpeas and mix everything together. Scatter {{paella-rice}} of rice across the pan. Pour in {{stock-vegetable}} of warm vegetable stock and the saffron water. Stir once to distribute, then do not stir again."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bring to a boil over high heat and cook for 10 minutes. Reduce to medium-low for 8 to 10 minutes more until the stock is absorbed and the rice is just cooked. Increase the heat to high for 1 to 2 minutes to form the socarrat, then rest for 5 minutes. Serve with lemon wedges."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "symptom": "The rice is unevenly cooked",
              "cause": "Burner too small for the pan, or uneven heat",
              "fix": "A large paella pan needs a large burner or can be placed over two burners on the hob. Rotate the pan halfway through cooking if the rice is cooking unevenly at the edges."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Vegetable paella is made across Spain wherever seasonal produce is good and plentiful. In Valencia, it is part of the same tradition as the meat original; the method is the same, only the ingredients change. Serve at the table in the pan with bread and a jug of cold water or white wine."
          }
        ]
      }
    ]
