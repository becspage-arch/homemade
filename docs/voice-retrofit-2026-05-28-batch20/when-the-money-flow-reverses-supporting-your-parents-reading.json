            "type": "text"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though the flow has reversed and I am now the one providing, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I feel guilt and resentment alongside the love, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I am afraid this will cost me what I've built, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
