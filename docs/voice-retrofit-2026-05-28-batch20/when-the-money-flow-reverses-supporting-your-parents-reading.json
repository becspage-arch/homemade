          },
          {
            "text": " first.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Tapping round on the role-shift",
            "type": "text"
          }
        ]
