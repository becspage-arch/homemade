{
  "slug": "tapping-for-confidence-before-a-hard-conversation",
  "title": "Tapping for confidence before a hard conversation",
  "subtitle": "A five-minute tapping sequence for the dread before a difficult discussion",
  "excerpt": "A five-minute tapping sequence for the dread that arrives before a hard conversation. Asking for a raise, setting a limit, addressing a problem. For when you know you need to say something and keep putting it off.",
  "type": "PRACTICE",
  "categorySlug": "mindset",
