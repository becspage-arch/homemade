    "practiceType": "TAPPING",
    "practiceTargets": ["CONFIDENCE", "ANXIETY"],
    "timeBand": "FIVE_MIN",
    "bestTime": "AS_NEEDED",
    "practiceDepth": "BEGINNER",
    "whenToUse": "In the hour before a conversation you have been dreading, or after one that did not go the way you hoped",
    "whenNotToUse": null,
