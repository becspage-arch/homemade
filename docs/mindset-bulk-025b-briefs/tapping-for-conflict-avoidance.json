    "practiceType": "TAPPING",
    "practiceTargets": ["RELATIONSHIPS", "ANXIETY"],
    "timeBand": "FIVE_MIN",
    "bestTime": "AS_NEEDED",
    "practiceDepth": "BEGINNER",
    "whenToUse": "Before or after a conversation where you found yourself agreeing to avoid conflict, or when you feel the pull to stay quiet to keep the peace",
