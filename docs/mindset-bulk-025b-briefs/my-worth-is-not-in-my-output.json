        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The belief that worth equals productivity is one of the most common and least examined beliefs in working culture. It says: a useful day means you are valuable. An unproductive day means you are failing. This affirmation interrupts that equation."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {"level": 2},
        "content": [{"type": "text", "text": "The affirmation"}]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Read each line slowly. Pause between them."
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "My worth is not in my output."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I am valuable on days when I produce nothing."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Rest is allowed. Rest is not failure."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I do not have to earn the right to exist."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "My doing does not determine my worth."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I am enough when I am doing nothing."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "My worth is not in my output."}]}]
          }
        ]
      },
