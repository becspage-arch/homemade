        "content": [
          {
            "type": "text",
            "text": "Scarcity thinking frames every resource as finite and contested. If someone else has it, there is less for you. This is true of some things and false of others. Applied to opportunity, recognition, or love, it creates a constant low-level competition with everyone around you."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {"level": 2},
        "content": [{"type": "text", "text": "The affirmation"}]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Read each line slowly. Pause between them."
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "There is enough. I am enough."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Another person's success does not reduce mine."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "What is meant for me will find me."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I receive good things. I allow good things."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "There is room for me and for others."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "I do not need to compete for what belongs to me."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "There is enough. I am enough."}]}]
          }
        ]
