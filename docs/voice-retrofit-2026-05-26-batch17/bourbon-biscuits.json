      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make dough, chill, roll, and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Beat {{unsalted-butter}}, {{soft-brown-sugar}}, and {{golden-syrup}} together until combined. Stir in {{whole-milk}}. Add {{plain-flour}}, {{cocoa-powder}}, and {{bicarbonate-of-soda}} and mix to a firm dough. Wrap and chill for 30 minutes. Heat the oven to 180°C (160°C fan). Roll to 3 mm thick on a lightly floured surface. Cut into rectangles about 3 × 6 cm, use a ruler for straight edges. Prick each biscuit a few times with a fork. Place on lined trays and bake for 12 to 14 minutes until dry and set. Cool completely.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fill and sandwich",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Beat the filling {{unsalted-butter}}, {{icing-sugar}}, and {{cocoa-powder}} until smooth. Spread a thin layer on the flat side of half the biscuits. Press a second biscuit on top. Leave for 1 hour for the filling to set before stacking.",
            "type": "text"
          }
        ]
      }
    ]
