          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry cream",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Whisk the egg yolks, sugar, and cornflour together in a bowl until smooth. Bring the milk to a simmer in a saucepan. Pour a third of the hot milk over the egg mixture, whisking constantly to temper it, then return the whole mixture to the pan. Cook over medium heat, stirring constantly with a silicone spatula, until the cream thickens and large bubbles begin to plop at the surface, about 3 to 4 minutes. Remove from heat, stir in the vanilla and butter, then press cling film directly onto the surface to prevent a skin forming. Refrigerate until fully set, at least 2 hours.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake the sponge",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Preheat the oven to 180°C conventional. Grease and line two 23 cm round tins. Beat the butter and sugar until pale and fluffy. Add the eggs one at a time, beating well after each. Fold in the flour and baking powder in two additions, alternating with the milk. Add the vanilla. Divide between the tins and bake for 25 to 30 minutes until golden, the sides pulling away from the tin, and a skewer comes out clean. Cool in the tins for 10 minutes, then transfer to a rack.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the chocolate glaze",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the cream and golden syrup together until just at the simmer. Pour over the chopped chocolate and leave for 1 minute, then stir from the centre outward until smooth. Allow to cool at room temperature for 10 to 15 minutes until slightly thickened but still pourable.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Place one sponge layer on a serving plate. Beat the chilled pastry cream briefly to loosen it, then spread it over the sponge in a thick, even layer, going close to the edge. Place the second sponge layer on top and press gently. Pour the warm chocolate glaze over the top, allowing it to run down the sides naturally. Refrigerate for 30 minutes before slicing.",
            "type": "text"
          }
        ]
      }
    ]
