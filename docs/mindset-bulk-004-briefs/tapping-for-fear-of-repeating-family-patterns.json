            "text": "A five-minute tapping practice for the fear of repeating the family money pattern. Use when you catch yourself recognising a parent's behaviour in your own and the recognition has turned to dread."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          { "type": "text", "text": "New to tapping? Read " },
          { "type": "text", "marks": [{ "type": "link", "attrs": { "href": "/mindset/how-eft-tapping-works" } }], "text": "how EFT tapping works" },
          { "type": "text", "text": " first." }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 2 },
        "content": [{ "type": "text", "text": "The practice" }]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Karate chop" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I am afraid I am becoming the family money pattern, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I can see their behaviour in mine and it frightens me, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though this fear is heavy, I am open to releasing it and doing this differently." }] }]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Tapping round" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Eyebrow:" }, { "type": "text", "text": " I'm afraid I'm repeating it." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Side of eye:" }, { "type": "text", "text": " I can see their pattern in my choices." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under eye:" }, { "type": "text", "text": " What if I can't escape it?" }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under nose:" }, { "type": "text", "text": " I am scared that this is just who we are." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Chin:" }, { "type": "text", "text": " The same avoidance. The same spending. The same freeze." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Collarbone:" }, { "type": "text", "text": " I don't want to pass this on." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under arm:" }, { "type": "text", "text": " This fear is heavy to carry." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Top of head:" }, { "type": "text", "text": " I can see it. Seeing it is the first step out." }] }]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Reframe to positive" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Eyebrow:" }, { "type": "text", "text": " I see the pattern clearly." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Side of eye:" }, { "type": "text", "text": " Seeing it means I can choose differently." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under eye:" }, { "type": "text", "text": " I am not them. I have more information than they had." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under nose:" }, { "type": "text", "text": " I get to do this differently." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Chin:" }, { "type": "text", "text": " The pattern is not a life sentence." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Collarbone:" }, { "type": "text", "text": " I release the fear and pick up the choice." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Under arm:" }, { "type": "text", "text": " I am building a different relationship with money right now." }] }]
          },
