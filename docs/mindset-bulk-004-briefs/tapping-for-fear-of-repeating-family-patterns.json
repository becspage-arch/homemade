            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Top of head:" }, { "type": "text", "text": " I break the pattern here, with this practice, today." }] }]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [{ "type": "text", "text": "Tap each round three times, then move to the reframe and tap that three times." }]
      },
