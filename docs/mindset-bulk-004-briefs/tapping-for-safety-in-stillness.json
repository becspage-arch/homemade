            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Top of head:" }, { "type": "text", "text": " I am safe to stop. I am safe to rest." }] }]
          }
        ]
