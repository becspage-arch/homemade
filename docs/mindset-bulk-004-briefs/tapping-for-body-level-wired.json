          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I feel wired and can't find the off switch, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though my body is ready to rest even if it doesn't feel that way yet, I honour what I am trying to do." }] }]
