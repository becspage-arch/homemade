            },
            {
              "name": "Sweet almond oil",
              "unit": "g",
              "amount": 100,
              "prepNote": "20%. Cold-pressed cosmetic-grade. Contains tree nuts; declare on the finished bar if gifting or selling.",
              "groupLabel": "Oils (500 g total)",
              "isOptional": false,
              "ingredientId": "cmpb8kdtu000gx0v4qvjj9jb4",
