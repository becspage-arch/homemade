              "prepNote": "40% of oil weight.",
              "groupLabel": "Oils (500 g total)",
              "isOptional": false,
              "ingredientId": "cmp49faly00dirkv4w9quay23",
              "ingredientSlug": "olive-oil"
            },
            {
              "name": "Coconut oil",
              "unit": "g",
