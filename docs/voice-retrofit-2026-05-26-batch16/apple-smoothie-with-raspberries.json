      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add all ingredients in a blender.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Blend for about 90 seconds or until the mixture is smooth.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add more coconut water or ice cubes as needed to achieve a thicker consistency.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Notes",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "You can substitute the coconut water with any liquid you would like; almond milk, cashew milk, soy milk, water, orange juice.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pick your favourite apple. I used half green and half fuji apples. The sweetness or tartness of the apple will slightly change how tangy the smoothie will be.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "If you don’t have frozen raspberries, add 1 cup total ice, and adjust with more ice and liquid as needed to get the right consistency.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Add a splash of milk, water, or juice until the blades catch. A high-powered blender helps but isn't essential.",
              "cause": "Frozen fruit ratio too high.",
              "symptom": "Smoothie is too thick"
            },
            {
              "fix": "Add half a frozen banana, a handful of oats, or a tablespoon of nut butter. Chia seeds thicken if you blend and wait five minutes.",
              "cause": "Liquid ratio too high, or no thickener.",
              "symptom": "Smoothie is too thin"
            },
            {
              "fix": "A frozen banana or a teaspoon of honey balances spinach or kale. A spoon of nut butter softens the green note.",
              "cause": "Green veg dominating, no sweetness or fat.",
              "symptom": "Tastes flat or grassy"
            },
            {
              "fix": "Drink straight away, or add one of those to bind it. Stir before each sip.",
              "cause": "No emulsifier (no banana, no nut butter, no yoghurt).",
              "symptom": "Smoothie separates in the glass"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Variations",
            "type": "text"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Higher-protein: blend in 30 g of protein powder, a tablespoon of nut butter, or Greek yoghurt.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Green version: add a handful of spinach, the colour shifts but the flavour stays.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Make ahead, freezing, leftovers",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A classic American home recipe, generous, comforting, made for a crowd. The proportions are heartier than the British equivalent; the method is built for a Sunday afternoon.",
            "type": "text"
          }
        ]
