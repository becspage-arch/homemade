      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Marinate the lamb",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine {{lamb-shoulder}} of lamb chunks with {{plain-yoghurt}} of plain yoghurt, {{garam-masala}} of garam masala, {{turmeric}} of turmeric and {{sea-salt-fine}} of salt in a bowl. Mix well until the lamb is coated. Cover and refrigerate for at least 2 hours, or overnight.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook the masala base",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat {{rapeseed-oil}} of oil in a large frying pan over medium-high heat. Remove the lamb from the marinade (reserve the marinade) and brown in batches for 3 minutes per side. Transfer to the slow cooker. In the same pan, cook {{onion}} chopped onions for 8 minutes until dark golden. Add {{garlic}} of grated garlic, {{ginger-root}} of grated ginger and {{curry-powder}} of curry powder. Cook for 2 minutes. Add {{tinned-tomatoes}} of tinned tomatoes and the reserved marinade; stir and pour over the lamb.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Slow cook and serve",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cook on LOW for 7 to 8 hours or HIGH for 4 to 5 hours until the lamb is very tender and falling apart. Taste and adjust seasoning. Scatter with fresh coriander if using. Serve with basmati rice and warm naan.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Troubleshooting",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": null,
          "items": [
            {
              "fix": "Add 2 hours on LOW. A bone-in shoulder needs an extra hour or two.",
              "cause": "Temperature too low, or the shoulder was bone-in and the timing was for boned.",
              "symptom": "Lamb still chewy after 8 hours"
            },
            {
              "fix": "Cook on LOW rather than HIGH; the yoghurt is more likely to split at HIGH temperatures. Stir in a tablespoon of double cream to rescue a split sauce.",
              "cause": "Yoghurt split during high heat.",
              "symptom": "Sauce curdled and grainy"
            },
            {
              "fix": "Skim the surface fat with a spoon before serving, or refrigerate overnight and lift the solidified fat off the top.",
              "cause": "Lamb not trimmed and excess fat rendered into the sauce.",
              "symptom": "Sauce very oily"
            }
          ],
          "heading": "Common problems"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Anglo-Indian lamb curry is the dish that arrived in British homes through the spice trade, the empire, and the great postwar wave of South Asian migration. This version is a slow-cooker adaptation: practical, affordable, and far better on day two. Serve for a Friday dinner or set it on a Saturday morning for an easy Sunday feast.",
            "type": "text"
          }
        ]
      }
    ]
