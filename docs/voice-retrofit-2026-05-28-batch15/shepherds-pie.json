      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the {{vegetable-oil}} in a large pan over medium-high heat. Add the {{onion}} and {{carrot}} and cook for 8 minutes until softened. Increase the heat to high, add the {{lamb-mince}}, and cook, breaking it up, until browned, about 8 minutes. Add the {{tomato-puree}} and {{rosemary}}. Stir for 2 minutes. Add the {{worcestershire-sauce}} and {{stock-beef}}. Season with {{sea-salt-fine}} and {{black-pepper}}. Simmer uncovered for 20 minutes until the sauce is thick. Spoon into a baking dish.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the mash and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 190°C. Boil the {{potato}} in salted water until completely tender. Drain and steam-dry. Mash with the {{unsalted-butter}} and warm {{whole-milk}} until smooth. Season well. Spoon over the filling and spread to the edges, sealing in the mince. Rough up the surface with a fork. Bake for 25 to 30 minutes until the top is golden and the filling is bubbling at the edges.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "Reduce the filling until it holds its shape. Allow it to cool for 5 minutes before adding the mash",
              "cause": "Filling too wet or too hot when the mash was added",
              "symptom": "Mash slides off the filling when portioning"
            },
            {
              "fix": "Drain off excess fat after browning the mince before adding the other ingredients. Lamb shoulder mince has more fat than leg mince",
              "cause": "Lamb mince too fatty, or fat not drained after browning",
              "symptom": "Greasy pool at the bottom after baking"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Shepherd's pie is eaten on weeknights and Sundays throughout Britain. It is one of the most reliably popular dishes across generations and is rarely refused at a table with children. The filling freezes well and the assembled pie is better made the day before, giving the mash time to firm up against the filling.",
            "type": "text"
          }
        ]
      }
    ]
