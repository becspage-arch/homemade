      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook and blend",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the {{vegetable-oil}} in a small pan. Fry the {{onion}} for 3 minutes. Add the {{coriander-ground}} and {{cumin-ground}} and stir for 30 seconds until fragrant. Transfer to the slow cooker. Add the {{carrot}}, {{garlic}}, {{ginger-root}}, {{stock-vegetable}}, {{sea-salt-fine}}, and {{black-pepper}}. Cook on low for 6 hours, until the carrot is completely soft. Blend smooth using a stick blender. Add a squeeze of {{lemon}} juice to taste if using. Taste and adjust seasoning.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "A squeeze of lemon juice cuts through the sweetness immediately. The cumin also adds a savoury note, increase to 1 teaspoon next time",
              "cause": "Carrots concentrated over 6 hours become very sweet",
              "symptom": "Soup very sweet and lacking depth"
            },
            {
              "fix": "Blend without returning the liquid and add back gradually until the right consistency is reached",
              "cause": "Overestimated liquid needed before blending",
              "symptom": "Soup too thin after blending"
            },
            {
              "fix": "Replace any ground coriander more than a year old. Always bloom it in oil for at least 30 seconds before adding to the slow cooker",
              "cause": "Old ground coriander or insufficient blooming",
              "symptom": "Coriander flavour not coming through"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Carrot and coriander is Britain's most recognisable soup. The slow cooker version is the best home cook version because the long cook concentrates the carrot's flavour. Make a large batch and freeze it. It keeps for three months and reheats in minutes. Serve with crusty bread and a swirl of yoghurt.",
            "type": "text"
          }
        ]
      }
    ]
