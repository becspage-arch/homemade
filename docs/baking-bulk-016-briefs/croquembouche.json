  "glossaryTerms": [
    {
      "slug": "caramel-for-assembly",
      "term": "Using caramel to assemble croquembouche",
      "definition": "Cooking sugar and a little glucose syrup to a hard caramel (160 to 165°C), then using it to dip and stack the profiteroles. The caramel acts as a fast-setting adhesive: dip the bottom of each profiterole briefly into the hot caramel and press it in place on the cone, holding for a few seconds until it grips. Work quickly and have everything organised before starting: the caramel sets within 2 to 3 minutes of being removed from the heat, and can be rewarmed over very low heat if it stiffens. Do not allow the caramel to brown past amber, as burnt caramel is bitter."
    }
  ],
