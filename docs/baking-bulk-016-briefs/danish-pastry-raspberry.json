  "glossaryTerms": [
    {
      "slug": "danish-lamination",
      "term": "Laminating Danish pastry dough",
      "definition": "Folding cold butter repeatedly into yeast dough to create alternating layers of fat and dough that puff apart in the oven. The dough must be cold throughout: if the butter breaks or oozes, refrigerate the dough for 20 minutes before continuing. Each fold doubles the number of layers; three book folds produces 64 layers. After the final fold, the dough must be chilled for at least 1 hour before shaping. Rushing the lamination by skipping rest periods smears the butter into the dough and produces a bread rather than a pastry."
    }
  ],
