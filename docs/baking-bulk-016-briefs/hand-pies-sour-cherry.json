  "glossaryTerms": [
    {
      "slug": "hand-pie-crimping",
      "term": "Crimping hand pies",
      "definition": "Sealing the edge of a half-moon hand pie by pressing the two layers of pastry together firmly with a fork, pressing down at regular intervals around the curved edge. The fork tines create a decorative and functional seal that holds the filling inside during baking. First press the edge firmly with fingers or a fork to form an initial seal, then go around a second time with the fork for the pattern. A poorly sealed edge will open during baking and the filling will leak and scorch on the tray."
    }
  ],
