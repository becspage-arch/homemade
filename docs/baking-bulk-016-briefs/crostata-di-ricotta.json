  "glossaryTerms": [
    {
      "slug": "pasta-frolla",
      "term": "Pasta frolla",
      "definition": "The standard Italian sweet shortcrust pastry used in crostate and other tarts. Made with plain flour, butter, sugar, eggs, and a little lemon zest, rubbed together briefly into a crumbly dough and chilled before rolling. Pasta frolla is richer and more tender than French pâte sucrée, with a higher ratio of fat and egg yolk to flour. It is more fragile when rolling: if it tears, press the pieces back together; the high fat content means it bakes to a smooth surface regardless of patching."
    }
  ],
