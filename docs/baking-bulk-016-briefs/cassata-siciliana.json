  "glossaryTerms": [
    {
      "slug": "pan-di-spagna",
      "term": "Pan di spagna",
      "definition": "The classic Italian sponge cake base used in cassata and many other Italian layer cakes. Made from eggs, sugar, and flour with no fat and no baking powder; the leavening comes entirely from air beaten into the eggs. Whole eggs are whisked with sugar over a bain-marie (or without, using a stand mixer) until the mixture is very pale, thick, and tripled in volume, then flour is folded in with a light hand to preserve the air. A properly made pan di spagna is springy, dry, and mild enough not to compete with the filling."
    }
  ],
