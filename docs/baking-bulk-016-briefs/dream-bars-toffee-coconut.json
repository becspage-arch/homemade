  "glossaryTerms": [
    {
      "slug": "traybake-par-bake",
      "term": "Par-baking a traybake base",
      "definition": "Baking the bottom layer of a two-layer traybake partway through before adding the topping, so the base stays crisp rather than becoming soggy under a wet filling. For dream bars, the shortbread base goes in for 15 minutes until just set but not coloured; adding the topping at this point prevents it from steaming the base. A base that has not been par-baked tends to be dense and damp rather than the clean, biscuit-like layer the recipe requires."
    }
  ],
