          {
            "type": "text",
            "text": "The two-step bake is what keeps the base crisp: "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "traybake-par-bake",
                  "term": "Par-baking a traybake base"
                }
              }
            ],
            "text": "par-baking the shortbread layer"
          },
          {
            "type": "text",
            "text": " before adding the coconut topping prevents the base from going soggy. Let the base cool for 5 minutes before adding the topping so the egg mixture does not cook on contact."
          }
        ]
