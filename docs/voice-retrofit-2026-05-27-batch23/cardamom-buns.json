      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Mix and knead",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine the flour, yeast, salt, sugar, and cardamom. Add the warm milk and soft butter and mix to a dough. Knead for 10 minutes by hand until smooth, or 6 minutes in a stand mixer with a dough hook.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bulk ferment, about 60 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Place in an oiled bowl, cover with a damp cloth, and leave until doubled. About 60 minutes in a warm kitchen.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Roll, fill, and shape",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Mix the filling to a smooth paste. Roll the dough on a lightly floured surface to a 40×50 cm rectangle. Spread the filling evenly to within 1 cm of the edges. Fold the dough lengthwise into thirds, pressing the layers together gently. Cut into 16 strips of about 2.5 cm each. Twist each strip twice and coil it into a round, tucking the end underneath, or use the knotted method from the kanelbullar recipe. Place on lined baking trays with 5 cm between each.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Prove, glaze, and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cover loosely and leave for 30 minutes until slightly puffed. Preheat the oven to 220°C conventional. Brush with beaten egg and scatter pearl sugar over the tops. Bake for 10 to 12 minutes until deep gold on the peaks and set in the centre. Cool on a rack; eat warm.",
            "type": "text"
          }
        ]
      }
    ]
  },
