      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the onion gravy",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt the {{unsalted-butter}} in a pan over low-medium heat. Add the {{onion}} and {{thyme}}. Cook slowly for 20 to 25 minutes, stirring occasionally, until the onions are deeply softened and beginning to colour. Stir in the {{plain-flour}} and cook for 2 minutes. Add the {{worcestershire-sauce}} and {{stock-beef}}. Simmer for 10 minutes until thickened. Season to taste.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook the sausages and mash",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cook the {{sausages-pork}} in a frying pan over medium heat, turning regularly, for 15 to 20 minutes until deeply browned all over and cooked through. Meanwhile, boil the {{potato}} until completely tender. Drain and steam-dry. Mash with {{unsalted-butter}}, warm {{whole-milk}}, and {{sea-salt-fine}} until smooth and creamy. Serve the sausages on the mash with the gravy poured over.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "Cook on medium heat and do not move them until a crust has formed on each side. High heat causes the skin to split before the interior is cooked",
              "cause": "Pan too hot, or turning too soon",
              "symptom": "Sausages burst during cooking"
            },
            {
              "fix": "Allow the gravy to simmer for at least 10 minutes after adding the stock. If still thin, dissolve 1 teaspoon of plain flour in a little cold water and stir in",
              "cause": "Insufficient flour, or not reduced enough after adding stock",
              "symptom": "Gravy thin and watery"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Bangers and mash is a classic British pub supper, and one of the fastest weeknight meals you can put on the table. The sausage decides the dish. A good butcher's sausage with a high meat content is a different product from a cheap supermarket pack."
          }
        ]
      }
    ]
