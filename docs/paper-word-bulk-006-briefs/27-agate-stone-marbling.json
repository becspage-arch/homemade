  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The ",
            "marks": []
          },
          {
            "type": "text",
            "text": "agate-pattern",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "agate-pattern"
                }
              }
            ]
          },
          {
            "type": "text",
            "text": " marble was widely used in bookbinding from the seventeenth century onward for endpapers meant to suggest luxury materials. The",
            "marks": []
          },
          {
            "type": "text",
            "text": "bouquet-base",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "bouquet-base"
                }
              }
            ]
          },
          {
            "type": "text",
            "text": " is the starting point. The stone effect comes from working a pointed stylus in short arcs within and across the nested colour circles."
          }
        ]
      },
      {
        "type": "infoPanel",
        "attrs": {
          "variant": "safety"
        },
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Alum is a mild skin and eye irritant. Wear gloves when mixing the mordant. Carrageenan spills are slippery: wipe up immediately."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What you need"
          }
        ]
      },
      {
        "type": "suppliesCard",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Choose three to five colours for the agate: earth tones (ochres, umbers, siennas) and a dark background colour produce a convincing stone-agate effect. Paler colours can be used for a translucent quartz look."
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Building the bouquet base"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Drop a large circle of the background colour (dark umber or black) across the full surface of the size."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Drop a lighter colour into the centre of the background circle. It will push the background outward."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Continue dropping alternating colours into the centre of the last circle. A typical agate base has five to eight nested rings."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Repeat the bouquet pattern across the tray, so the surface has several distinct bouquet centres."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Working the stone effect"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Draw the stylus through the bouquet in short, tight arcs, working from the outer edge of one bouquet toward its centre, then reversing."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Work across all the bouquet centres, pulling the rings into irregular curved forms."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Do not over-work: two or three passes per bouquet is usually enough. More passes produce a blurred muddy pattern."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Care"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rinse the print under cold running water immediately after lifting to remove excess carrageenan, which can yellow over time. Allow to air-dry flat."
          }
        ]
      }
    ]
  }
}