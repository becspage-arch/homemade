  "glossaryTerms": [
    {
      "slug": "bouquet-base",
      "term": "Bouquet base",
      "definition": "A marbling surface covered with overlapping circles of colour, each circle pushed from the centre outward by successive drops."
    },
    {
      "slug": "agate-pattern",
      "term": "Agate pattern",
      "definition": "A marbling pattern that imitates the banded, curved veining of polished agate stone, produced by drawing a stylus in tight arcs through a bouquet base."
    }
  ],
