        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I am ready to release the habit of waking into urgency and rush before the day has made a single demand. I release it now. I release it now. I release it now.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
