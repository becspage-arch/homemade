        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I am ready to release the habit of overlooking steady income and small wins while waiting for one big leap. I release it now. I release it now. I release it now.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
