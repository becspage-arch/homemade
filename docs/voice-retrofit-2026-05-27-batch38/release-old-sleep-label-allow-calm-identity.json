        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I am ready to release the old label of 'bad sleeper' and all doubt that this can change. I release it now. I release it now. I release it now.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
