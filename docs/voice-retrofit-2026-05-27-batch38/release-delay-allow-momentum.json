      {
        "type": "paragraph",
        "content": [
          {
            "text": "A short energy statement for the specific drag that makes money tasks feel like they belong to a different, more capable version of you. The release clears the weight; the allow sets a new default.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "New to energy statements? Read ",
            "type": "text"
          },
          {
            "text": "how energy statements work",
            "type": "text",
            "marks": [
              {
                "type": "link",
