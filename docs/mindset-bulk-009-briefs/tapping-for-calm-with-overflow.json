          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Top of head:" }, { "type": "text", "text": " I let myself be calm when money is good." }] }]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": { "level": 3 },
        "content": [{ "type": "text", "text": "Reframe to positive" }]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
