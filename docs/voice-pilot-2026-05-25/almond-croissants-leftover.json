      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the syrup and the almond cream",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 180°C conventional (160°C fan). Line a baking tray.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "For the syrup: combine the {{water}} and the first portion of {{caster-sugar}} in a small pan. Bring to a simmer to dissolve the sugar. Take off the heat, stir in the {{rum-dark}}, and cool slightly.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "For the almond cream: beat the {{unsalted-butter}} and the second portion of {{caster-sugar}} until pale. Beat in the {{eggs}}. Fold in the {{almond-flour}} and {{almond-extract}}.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Soak, fill, top, bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Split each day-old croissant in half through the middle with a serrated knife. Brush the cut faces generously with the warm syrup, soak rather than dab.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Spread a generous tablespoon of almond cream on the bottom half and close the croissant. Spread another tablespoon across the top of each.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Scatter the {{almonds-flaked}} over the tops. Set the croissants on the lined tray.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 16 to 18 minutes. The almond cream should be set and deep gold, the flaked almonds toasted, and the croissants warmed through.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Dust with the {{icing-sugar}} and serve warm.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
