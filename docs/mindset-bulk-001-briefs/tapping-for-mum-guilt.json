            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Eyebrow:" },
                  { "type": "text", "text": " I give myself permission to be a real mother, not a perfect one." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Side of eye:" },
                  { "type": "text", "text": " My choices are made with the information I have." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Under eye:" },
                  { "type": "text", "text": " I am allowed to be tired and still good at this." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Under nose:" },
                  { "type": "text", "text": " Guilt is not the same as wisdom." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Chin:" },
                  { "type": "text", "text": " I can hear the guilt without letting it run me." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Collarbone:" },
                  { "type": "text", "text": " My children are loved. That is the through-line." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Under arm:" },
                  { "type": "text", "text": " I get to repair, and repair is part of the work." }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  { "type": "text", "marks": [{ "type": "bold" }], "text": "Top of head:" },
                  { "type": "text", "text": " I am doing this with love. Today, that is enough." }
                ]
              }
            ]
          }
