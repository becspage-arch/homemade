      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though big monthly cashflow once felt out of reach, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I thought only certain people could have it, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I've capped what I thought was possible, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
