      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Mix the flour, yeast, salt, and sugar. Add the warm milk, egg, vanilla, and soft butter and mix to a smooth dough. Knead for 8 minutes. Cover and leave for 60 minutes until doubled. Divide into portions of about 20 g each (golf-ball-sized) and roll into smooth balls. Place on a lined tray, cover, and prove for 30 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oil to 175°C. Fry the dough balls in batches of 6 to 8 for 1 to 2 minutes per side until evenly deep golden. Remove with a slotted spoon and toss immediately in the cinnamon sugar. Serve warm.",
            "type": "text"
          }
        ]
      }
    ]
