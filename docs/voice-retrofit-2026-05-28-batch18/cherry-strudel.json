      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and rest the dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Mix the flour, warm water, oil, and salt into a smooth, very soft dough. Knead for 5 minutes until satiny. Brush all over with a little oil, place in a bowl, cover with a warm bowl inverted over it, and rest for 30 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Stretch, fill, and roll",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cover a large table with a clean cloth and flour it generously. Place the rested dough in the centre and roll it with a pin as far as it will go. Then, working with hands beneath the dough, stretch it outward until paper-thin. Brush with melted butter. Scatter the toasted breadcrumbs over two-thirds of the surface, leaving a border. Toss the cherries with sugar, cinnamon, and lemon juice and spread over the breadcrumbs. Using the cloth to help, roll the strudel tightly into a log, tucking in the ends. Transfer to a lined baking tray seam-side down.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 190°C conventional (170°C fan). Brush the strudel generously with melted butter. Bake for 35 to 40 minutes, brushing with more butter at 20 minutes, until deep golden and the pastry is crisp on the base. Dust generously with icing sugar before serving.",
            "type": "text"
          }
        ]
      }
    ]
