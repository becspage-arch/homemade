    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "The batter is ready in under 5 minutes; the technique of ",
            "type": "text"
          },
          {
            "text": "pouring the batter in a spiral into the oil",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
