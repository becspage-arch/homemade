      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Whisk together the flour, sugar, baking powder, and salt in a large bowl. In a separate bowl, beat the eggs with the milk and vanilla. Pour the wet ingredients into the dry and whisk until the batter is smooth and pourable, about the consistency of double cream.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oil in a wide pan to 190°C. Hold a funnel or piping bag close to the oil surface, cover the opening, fill with about 120 ml of batter, then release over the oil in a continuous spiral pattern working from the centre outward, overlapping the strands to form a connected disc about 15 cm across. Fry for 90 seconds until golden on the underside. Flip carefully with tongs and fry for a further 60 to 90 seconds. Remove to a rack, dust generously with icing sugar, and serve immediately.",
            "type": "text"
          }
        ]
      }
    ]
