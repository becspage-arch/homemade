      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Mix the currants, mixed peel, melted butter, dark brown sugar, mixed spice, cinnamon, and rum together. Leave to macerate for 30 minutes. Roll the puff pastry to about 3 mm thick and cut into 12 cm rounds. Place a heaped tablespoon of filling in the centre of each round. Gather the pastry edges up and press firmly together to seal, then turn over seam-side down. Shape gently into an oval and score three diagonal slits across the top with a sharp knife.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Place on a lined baking tray and refrigerate for 30 minutes. Heat the oven to 210°C conventional (190°C fan). Brush the cakes with beaten egg and sprinkle with caster sugar. Bake for 20 to 25 minutes until deep golden and puffed. Cool on a rack for 10 minutes before eating. Best eaten warm.",
            "type": "text"
          }
        ]
      }
    ]
