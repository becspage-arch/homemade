      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Rub the cold butter into the flour, sugar, and salt until crumbly. Add the egg yolks and lemon, bring into a dough. Divide into two-thirds and one-third, flatten into discs, wrap, and refrigerate for 1 hour.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the hazelnut chocolate filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Spread the hazelnuts on a baking tray and roast at 180°C for 12 to 14 minutes until golden. Tip onto a clean cloth, rub off the skins, and leave to cool slightly. Heat the cream, butter, and sugar in a small saucepan until the butter melts and the mixture just simmers. Pour over the chopped chocolate and stir until smooth. Transfer to a blender with the warm hazelnuts and vanilla and blend until as smooth as you like. The filling thickens as it cools.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Assemble and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 180°C conventional (160°C fan). Roll the larger pastry disc and line a 23 cm tart tin. Spread the chocolate hazelnut filling evenly over the base. Roll the remaining pastry into strips and arrange in a lattice. Trim and press the ends. Bake for 28 to 32 minutes until the pastry is golden and the filling is just set. Cool completely before unmoulding.",
            "type": "text"
          }
        ]
      }
    ]
