        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and bake the choux",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Bring the water, butter, salt, and sugar to the boil in a large saucepan. Add all the flour at once and beat vigorously over medium heat for 2 minutes until the dough pulls away from the sides. Transfer to a large bowl and cool for 5 minutes. Beat in the eggs one at a time until the paste is smooth and falls from a spoon in a slow V-shape. Pipe or spoon walnut-sized mounds onto lined trays. Bake at 200°C conventional (180°C fan) for 20 to 25 minutes until deep golden. Pierce the base of each immediately and cool on a rack.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the crème pâtissière",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the milk with the vanilla pod and seeds until just simmering. Whisk the egg yolks, sugar, and flour together in a bowl until pale. Pour the hot milk over in a thin stream, whisking constantly. Return to the pan and cook over medium heat, stirring continuously, until very thick and beginning to bubble. Stir in the butter. Press cling film onto the surface and refrigerate until cold. Pipe into the cooled profiteroles through the base hole.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook the caramel and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine the sugar, glucose syrup, and water in a heavy saucepan. Cook without stirring to 160°C. Set the pan on a heatproof surface. Working quickly, dip the side of each profiterole in the caramel and press into a cone shape, starting from a wide base and working upward. Hold each piece briefly until the caramel grips. Drizzle any remaining caramel over the tower with a fork to create fine threads.",
            "type": "text"
          }
        ]
      }
    ]
