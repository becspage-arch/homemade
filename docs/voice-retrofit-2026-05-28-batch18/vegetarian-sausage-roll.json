      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt ",
            "type": "text"
          },
          {
            "text": "{{unsalted-butter}} of butter",
            "type": "text"
          },
          {
            "text": " in a large frying pan over high heat. Add the onion and garlic, cook for 5 minutes, then add the ",
            "type": "text"
          },
          {
            "text": "{{mushrooms-chestnut}} of chopped mushrooms",
            "type": "text"
          },
          {
            "text": " and cook over high heat, stirring frequently, for 10-12 minutes until all moisture has evaporated and the mushrooms are dry and concentrated. Off the heat, stir in the drained ",
            "type": "text"
          },
          {
            "text": "{{lentils-green}} of lentils",
            "type": "text"
          },
          {
            "text": ", ",
            "type": "text"
          },
          {
            "text": "{{cheddar}} of grated cheddar",
            "type": "text"
          },
          {
            "text": ", thyme leaves, and Worcestershire sauce if using. Season with ",
            "type": "text"
          },
          {
            "text": "{{sea-salt-flakes}}",
            "type": "text"
          },
          {
            "text": " and ",
            "type": "text"
          },
          {
            "text": "{{black-pepper}}",
            "type": "text"
          },
          {
            "text": ". Cool completely.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Roll and cut",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Unroll or lay out each sheet of the ",
            "type": "text"
          },
          {
            "text": "{{puff-pastry}} of puff pastry",
            "type": "text"
          },
          {
            "text": " on a lightly floured surface. Divide the filling into two portions and spread each one in a log along the centre third of each sheet. Fold the pastry over the filling and press the seam to seal. Brush with beaten egg and score the surface lightly. Cut each log into 6 rolls and place on a lined baking tray, seam-down. Chill for 20 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 200°C (180°C fan). Bake for 22-25 minutes until deeply golden and puffed. Rest for 5 minutes before serving.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "rows": [
            {
              "fix": "Cook the mushrooms until the pan is completely dry and the sound changes from a sizzle to a gentle spit. Cool completely before rolling.",
              "cause": "Mushroom filling was not cooked dry enough, or the filling was still warm when rolled",
              "symptom": "Pastry is soggy at the base"
            },
            {
              "fix": "Drain tinned lentils thoroughly and pat dry. Extra cheese (20-30 g more) helps bind.",
              "cause": "Too little cheese to bind, or lentils were too wet",
              "symptom": "Filling falls out when cut"
            },
            {
              "fix": "Use undiluted beaten egg. Pastry must be cold.",
              "cause": "Egg wash too thin or pastry was warm when it went in",
              "symptom": "Rolls are pale after 25 minutes"
            },
            {
              "fix": "Leave at least 2 cm of clear pastry on each side of the filling log for the overlap seam.",
              "cause": "Too much filling, or pastry was too thin",
              "symptom": "Pastry tears when rolling around the filling"
            }
          ]
        },
        "content": []
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Vegetarian sausage rolls became a staple of the British bakery and party table in the 2010s as plant-based eating moved from specialist shops to the mainstream. The filling needs to be satisfying enough to stand alongside its pork counterpart, and a dry mushroom and lentil base achieves this. These are party food, picnic food, and children's tea food in equal measure.",
            "type": "text"
          }
        ]
      }
    ]
