      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 180°C conventional (160°C fan). Grease and line a 23 x 33 cm tin. Rub the cold butter into the flour, sugar, and salt until the mixture resembles breadcrumbs. Press firmly and evenly into the tin. Bake for 15 minutes until just set. Remove from the oven and leave to cool for 5 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Whisk together the eggs, golden syrup, dark brown sugar, baking powder, salt, and vanilla. Stir in the desiccated coconut and walnuts. Pour the topping evenly over the par-baked base. Return to the oven for 20 to 25 minutes until the topping is golden and set. Cool completely in the tin before cutting into bars.",
            "type": "text"
          }
        ]
      }
    ]
