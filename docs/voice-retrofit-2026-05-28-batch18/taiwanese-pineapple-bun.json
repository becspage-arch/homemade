      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the bread dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine flour, yeast, salt, and sugar in a large bowl. Add the warm milk and egg and mix to a rough dough. Knead for 8 minutes until smooth. Work in the soft butter a piece at a time and continue kneading for 4 minutes until the dough is smooth and slightly tacky. Cover and leave for 60 minutes until doubled.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the cookie topping",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Beat the butter and icing sugar together until pale. Add half the beaten egg and the vanilla and mix in. Stir in the flour to form a soft dough. Divide into 8 equal pieces, roll each into a ball, flatten between two sheets of baking paper to about 8 cm rounds, and refrigerate for 30 minutes until firm.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Shape, top, and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Divide the bread dough into 8 equal pieces and shape into smooth rounds. Arrange on lined baking trays, cover, and prove for 40 minutes. Heat the oven to 190°C conventional (170°C fan). Peel a round of cookie topping off the paper, drape it over a proved roll, and press gently to adhere. Score a light crosshatch pattern across the surface with a knife. Brush with the reserved beaten egg. Bake for 18 to 22 minutes until golden. Cool on a rack.",
            "type": "text"
          }
        ]
      }
    ]
