      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Whisk the flour, yeast, sugar, and salt in a bowl. Add the warm milk and egg and whisk to a smooth batter the consistency of double cream. Leave to rest for 30 minutes at room temperature. Heat the oil in a deep saucepan to 180°C.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Pat the apple rings dry with paper. Dip each ring in the batter, letting the excess drip off, and lower carefully into the hot oil. Fry in batches of 3 to 4 rings for 2 to 3 minutes per side until deep golden. Remove with a slotted spoon and drain on paper briefly, then transfer to a rack. Dust with the icing sugar and cinnamon mixture and serve immediately.",
            "type": "text"
          }
        ]
      }
    ]
