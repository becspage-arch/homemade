          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Combine flour, yeast, salt, and sugar in a large bowl. Add the warm milk and eggs and mix to a rough dough. Knead for 8 minutes until smooth. Work in the soft butter gradually and knead for a further 5 minutes. Place in an oiled bowl, cover, and leave for 60 minutes until doubled.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fill, roll, and chill",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Mix the filling ingredients together until smooth. Roll the dough on a lightly floured surface into a rectangle about 40 x 50 cm. Spread the filling evenly across the surface, leaving a 2 cm border at the far edge. Roll up tightly from the near edge into a log. Wrap in cling film and refrigerate for 30 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Twist and prove",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Oil a 900 g loaf tin. Remove the chilled log and cut it lengthways down the centre. Twist the two halves around each other, cut sides up, keeping the layers visible. Lift into the tin. Cover and prove for 45 minutes until the dough is level with or just above the rim. Heat the oven to 180°C conventional (160°C fan).",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake and glaze",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Bake for 32 to 38 minutes until deep brown and cooked through. While it bakes, dissolve the sugar in the water in a small saucepan over medium heat, bring to the boil, then remove from the heat. As soon as the loaf comes out of the oven, brush all over with the hot syrup. Leave in the tin for 15 minutes before turning out.",
            "type": "text"
          }
        ]
      }
    ]
