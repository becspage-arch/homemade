  "title": "Vegan Cinnamon Doughnuts",
  "subtitle": null,
  "excerpt": "Vegan Cinnamon Doughnuts. A home-cook's recipe from Rebecca's collection, kept in the family rotation.",
  "type": "RECIPE",
