  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Vegan Cinnamon Doughnuts. A British home-cook's dish, the kind of recipe families adjust across generations. Serves 12.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A weeknight-friendly recipe: most of the work is the prep, and the cooking takes care of itself.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "What you need",
            "type": "text"
          }
        ]
      },
      {
        "type": "ingredientsList",
        "attrs": {
          "items": [
            {
              "name": "Unsalted butter",
              "unit": "g",
              "amount": 50,
              "prepNote": null,
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49f3gf000wrkv4p017cubd",
              "ingredientSlug": "unsalted-butter"
            },
            {
              "name": "Soya milk",
              "unit": "ml",
              "amount": 120,
              "prepNote": null,
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp5mo1vm0002wwv4g0eszetf",
              "ingredientSlug": "soya-milk"
            },
            {
              "name": "Sunflower oil",
              "unit": "tbsp",
              "amount": 2,
              "prepNote": null,
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49faoe00dmrkv4zlsjvtib",
              "ingredientSlug": "sunflower-oil"
            },
            {
              "name": "Plain flour",
              "unit": "g",
              "amount": 250,
              "prepNote": null,
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49f2xb0000rkv47vd545ba",
              "ingredientSlug": "plain-flour"
            },
            {
