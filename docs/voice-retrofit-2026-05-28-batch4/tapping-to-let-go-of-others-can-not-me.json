                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Side of eye:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I wonder why it skips me.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
