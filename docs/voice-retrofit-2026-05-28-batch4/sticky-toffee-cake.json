      {
        "type": "paragraph",
        "content": [
          {
            "text": "Put the chopped ",
            "type": "text"
          },
          {
            "text": "Medjool dates",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
