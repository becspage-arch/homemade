      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake the potatoes"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat the oven to 220°C fan. Prick the potatoes, rub with oil and sea salt, and bake directly on the oven rack for 70 to 75 minutes until the skin is crisp and the flesh is tender."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the filling"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "About 40 minutes before the potatoes are done, heat a little oil in a saucepan over a medium heat. Cook the onion and carrot for 8 minutes until softened. Add the garlic and cook for 1 minute."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the mince and cook, breaking it up, until browned all over. Stir in the tomato puree. Add the stock and Worcestershire sauce. Season."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Simmer for 25 to 30 minutes until the sauce has thickened and reduced. Add the frozen peas for the last 5 minutes if using."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Serve"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cut a deep cross in each potato and squeeze the ends to open it up. Spoon a generous ladleful of the cottage pie filling over and inside each potato."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "symptom": "The filling is too runny",
              "cause": "Not reduced enough.",
              "fix": "Simmer without a lid until the liquid is almost entirely absorbed and the mince holds together rather than swimming in sauce."
            },
            {
              "symptom": "The potato skin is soft",
              "cause": "Foil was used, or temperature was too low.",
              "fix": "Bake unwrapped at a high temperature. No foil."
            },
            {
              "symptom": "The mince is tough and dry",
              "cause": "Lean mince cooked at too high a temperature.",
              "fix": "Use a mince with some fat content. Simmer rather than boil, and keep the lid off only to reduce."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The jacket potato is the British vehicle for almost anything hot and saucy. Cottage pie filling is a natural candidate. The combination skips the time-consuming step of making mashed potato topping and works well with batch-cooked mince kept in the fridge. It uses leftovers well and avoids waste: two firmly British instincts."
          }
        ]
      }
    ]
  }
