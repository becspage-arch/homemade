      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake the sponge layers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 175 degrees C fan. Grease and line three 20 cm round tins. Beat 180 g softened butter with 250 g sugar until pale. Fold in 350 g flour, 2.5 tsp baking powder, and 0.5 tsp salt alternating with 180 ml milk. Stir in 1 tsp vanilla. In a separate clean bowl, whisk 6 egg whites to stiff peaks, then fold into the batter in three additions. Divide between the three tins. Bake for 22 to 25 minutes until a skewer comes out clean. Cool completely on racks."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the bourbon filling"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Put 8 egg yolks, 250 g sugar, and 120 g cubed butter in a heatproof bowl over a pan of barely simmering water. Stir continuously for 10 to 12 minutes until the mixture is thick, pale, and leaves a clear trail when you draw a spoon through it. Remove from the heat. Stir in 80 ml bourbon, 100 g chopped pecans, 80 g raisins, and 50 g desiccated coconut. Cool to room temperature."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Assemble"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Place the first sponge layer on a serving plate. Spread half the cooled filling over it. Add the second layer and spread with the remaining filling. Place the third layer on top. Refrigerate for 30 minutes to firm the filling."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the seven-minute frosting"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Combine 4 egg whites, 300 g sugar, 0.25 tsp cream of tartar, and 80 ml water in a heatproof bowl over a pan of simmering water. Whisk continuously with an electric whisk for 7 to 9 minutes until the frosting is thick, white, glossy, and holds a stiff peak. Remove from the heat. Spread over the top and sides of the cake immediately; the frosting sets quickly as it cools."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Troubleshooter"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "problem": "Filling is thin and does not hold between layers",
              "solution": "The custard was not cooked for long enough, or was not cooled before assembly. Cook until the mixture leaves a clear trail when you draw a spoon through it, and allow to cool fully — at least 45 minutes — before using."
            },
            {
              "problem": "Sponge layers are dense",
              "solution": "The egg whites were folded in too vigorously, or not whisked to stiff peaks first. Fold in three additions, using a large metal spoon, stopping when just combined."
            },
            {
              "problem": "Seven-minute frosting is grainy",
              "solution": "The sugar crystallised before dissolving fully. Make sure the sugar is fully dissolved in the water before the mixture heats, and whisk continuously throughout the cooking time."
            }
          ]
        }
      }
    ]
  }
