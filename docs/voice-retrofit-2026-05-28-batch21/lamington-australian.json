      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake the sponge",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan (190°C conventional). Grease and line a 20 cm square tin.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat {{unsalted-butter}} and {{caster-sugar}} together until pale and fluffy, about 3 minutes. Beat in {{eggs}} one at a time, then add {{vanilla-extract}}.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Fold in {{self-raising-flour}} in two additions, alternating with {{whole-milk}}, until just combined. Spread evenly into the tin.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 22 to 25 minutes until risen, golden, and springy. Cool in the tin for 10 minutes, then turn onto a rack. When completely cool, wrap in cling film and refrigerate for at least 2 hours, or overnight.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Coat the lamingtons",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cut the cold sponge into 16 equal squares using a sharp knife. Keep in the fridge while you make the icing.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Sift {{icing-sugar}} and {{cocoa-powder}} into a bowl. Add {{unsalted-butter}} and {{whole-milk}}. Stir until smooth and the consistency of thick pouring cream. If too thick, add hot water a teaspoon at a time.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Spread {{desiccated-coconut}} on a flat plate. Set a cooling rack over a tray. Working quickly with cold cake squares, dip each piece in the chocolate icing using two forks, turning to coat all sides. Allow excess to drip off for a few seconds, then roll in the coconut. Place on the rack to set. Repeat.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Leave on the rack for 30 minutes to firm up before serving. The icing will set; the coconut will stick. Store in a single layer in a tin at room temperature for up to three days.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Lamington problems almost always come from the sponge temperature.",
          "items": [
            {
              "fix": "Refrigerate for at least 2 hours, ideally overnight. Even a slightly warm sponge will crumble into the icing.",
              "cause": "Sponge not cold enough.",
              "symptom": "Sponge fell apart during dipping."
            },
            {
              "fix": "Thin the icing by adding hot water a teaspoon at a time until it coats the back of a spoon but flows freely when tipped.",
              "cause": "Not enough hot milk in the icing.",
              "symptom": "Icing too thick and clumping on the sponge."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
