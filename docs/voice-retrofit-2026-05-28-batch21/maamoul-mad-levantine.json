      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the dough and filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Mix {{semolina}}, {{caster-sugar}}, and {{baking-powder}} together in a large bowl. Pour in the melted {{unsalted-butter}} (dough quantity) and mix with your hands until the semolina is evenly coated. It will look sandy. Add {{rose-water}} and {{orange-blossom-water}} and mix again. Cover and leave to rest for 1 hour.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Blend {{dates-medjool}} with {{unsalted-butter}} (filling quantity) and {{cinnamon-ground}} in a food processor until smooth. If the mixture is stiff, add a tablespoon of warm water. The paste should be soft and spreadable.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Assemble and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 180°C fan (200°C conventional). Grease and line the baking tin.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Divide the rested dough in half. Press the first half into the base of the tin in an even layer, using wet fingers or a flat-bottomed glass. Spread the date paste over the top in an even layer, right to the edges.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Press the remaining dough into a flat slab on a piece of baking paper (the same size as the tin), then invert it over the date layer. Press gently to stick. Scatter {{almonds-flaked}} over the surface and press in lightly.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 28 to 32 minutes until golden on top. Leave to cool completely in the tin before cutting into squares or diamonds. The texture firms up as it cools; do not cut while warm.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Texture is the main thing to watch.",
          "items": [
            {
              "fix": "Rest for the full hour. If still crumbly, add a tablespoon of warm water and mix again.",
              "cause": "Resting time skipped, or not enough fat.",
              "symptom": "Dough too crumbly to press into the tin."
            },
            {
              "fix": "Wait until completely cool. The semolina sets as it cools. Cut with a sharp knife in one clean downward motion.",
              "cause": "Cut while still warm.",
              "symptom": "Cake falls apart when cut."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
