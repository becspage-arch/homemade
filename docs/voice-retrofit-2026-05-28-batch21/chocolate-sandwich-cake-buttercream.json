      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake the sponge",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan (190°C conventional). Grease and line two 20 cm sandwich tins.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat {{unsalted-butter}} and {{caster-sugar}} until very pale and fluffy, about 3 to 4 minutes. Beat in {{eggs}} one at a time.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Sift {{self-raising-flour}}, {{cocoa-powder}}, and {{baking-powder}} into a bowl and set aside. Fold this into the butter mixture in two batches, alternating with {{whole-milk}}. Stop when the flour just disappears.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Divide between the two tins and level. Bake for 28 to 32 minutes until springy to the touch and just pulling away from the sides. Cool in the tins for 10 minutes, then turn onto a rack.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the buttercream and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat {{unsalted-butter}} alone for 2 minutes until very pale. Sift in {{icing-sugar}} and {{cocoa-powder}} in three additions, beating well between each. Add {{dark-chocolate}} and {{whole-milk}} and beat for a further 3 minutes until smooth and light.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place one sponge on a board or plate. Spread with about a third of the buttercream. Place the second sponge on top and use the remaining buttercream to cover the top and sides.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "This is a reliable cake with predictable failure modes.",
          "items": [
            {
              "fix": "Bring butter and eggs to room temperature before starting. Fold the flour in gently; the moment no dry flour remains, stop.",
              "cause": "Butter or eggs too cold, or overmixed after adding flour.",
              "symptom": "Sponge layers dense and heavy."
            },
            {
              "fix": "Sift the cocoa before adding and beat for longer. A tablespoon of hot water added gradually can help smooth it.",
              "cause": "Cocoa not fully incorporated.",
              "symptom": "Buttercream grainy from the cocoa."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
