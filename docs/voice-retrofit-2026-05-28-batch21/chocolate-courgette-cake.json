      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan (190°C conventional). Grease and line a 900g loaf tin.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Grate {{courgette}} coarsely, then tip into a clean tea towel and squeeze hard to remove as much liquid as possible. Set aside.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Put {{plain-flour}}, {{cocoa-powder}}, {{caster-sugar}}, {{baking-powder}}, and {{sea-salt-fine}} in a large bowl and whisk to mix. Add {{bicarbonate-of-soda}} and whisk it in well.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "In a separate bowl, whisk {{sunflower-oil}}, {{eggs}}, and {{vanilla-extract}} together until combined. Pour into the dry ingredients and stir until just combined.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Fold in the squeezed courgette and the {{dark-chocolate}} chunks if using. The batter will be thick.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Spoon into the prepared tin and level the top. Bake for 60 to 65 minutes until a skewer inserted in the centre comes out with just a few moist crumbs. Cover loosely with foil after 40 minutes if the top is browning quickly.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cool in the tin for 15 minutes, then transfer to a rack.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "This is a forgiving bake with a couple of common pitfalls.",
          "items": [
            {
              "fix": "Squeeze harder next time. The courgette should feel almost dry to the touch before it goes in. A slightly sunken loaf still tastes fine; the texture is unaffected.",
              "cause": "Courgette not squeezed dry, making the batter too wet.",
              "symptom": "Cake sinks in the middle."
            },
            {
              "fix": "The skewer test is essential with this loaf. Stir the wet and dry ingredients until just combined; a few streaks of flour are acceptable.",
              "cause": "Underbaked, or batter overmixed.",
              "symptom": "Dense and gummy rather than moist."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
  },
