      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the custard (at least 2 hours ahead)",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat {{whole-milk}} (filling quantity) and {{vanilla-extract}} until steaming. In a bowl, whisk {{egg-yolks}} and {{caster-sugar}} (filling quantity). Add {{cornflour}} and whisk until smooth.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour the hot milk slowly over the egg mixture, whisking constantly. Return to the pan and cook over medium heat, stirring constantly, until the custard thickens and bubbles. Cook for 1 minute more, then stir in {{unsalted-butter}} (filling quantity) until melted.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Press cling film directly onto the surface and refrigerate until cold and firm, at least 2 hours. The custard must be stiff enough to hold its shape when piped.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and prove the dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Combine {{strong-bread-flour}}, {{yeast-fast-action}}, {{caster-sugar}} (dough quantity), and {{sea-salt-fine}} in a stand mixer bowl with a dough hook. Add {{eggs}} and warm {{whole-milk}} (dough quantity) and mix on low for 2 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Increase speed to medium and knead for 5 minutes. Add {{unsalted-butter}} (dough quantity) a few pieces at a time, letting each piece incorporate before adding the next. Knead for a further 8 to 10 minutes until smooth and elastic.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cover and prove for 1.5 to 2 hours until doubled. Divide into 12 balls (about 80g each), shape into smooth rounds, and prove again for 45 minutes to 1 hour until puffed.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fry and fill",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat {{sunflower-oil}} to 175°C. Fry 3 to 4 doughnuts at a time for 2.5 to 3 minutes per side until deep golden. Drain on kitchen paper, then roll in {{caster-sugar}} (finishing quantity) while hot.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Once cool enough to handle, whisk the chilled custard briefly to loosen it. Spoon into a piping bag fitted with a round nozzle. Use a skewer to make a small hole in the side of each doughnut, then pipe custard in until the doughnut feels heavy and resists further filling.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Custard consistency and frying temperature are the two things to watch.",
          "items": [
            {
              "fix": "The custard must be cold and set firm before piping. If it is still soft after 2 hours, refrigerate for a further hour. Use the skewer to make only a small entry hole.",
              "cause": "Custard not thick enough, or filling hole too large.",
              "symptom": "Custard leaks back out of the doughnut."
            },
            {
              "fix": "Fry in small batches and monitor the temperature; adding cold dough lowers the oil temperature. Wait for it to return to 175°C between batches.",
              "cause": "Oil temperature dropped too low during frying.",
              "symptom": "Doughnuts heavy and greasy."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
  },
