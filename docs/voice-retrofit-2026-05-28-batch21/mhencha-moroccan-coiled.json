      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Mix {{almond-flour}}, {{icing-sugar}}, {{orange-blossom-water}}, and {{cinnamon-ground}} together in a bowl. Add just enough beaten {{eggs}} to bring the mixture together into a firm paste that holds its shape when rolled. You may not need all the egg.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the almond paste into a long sausage shape roughly 2 cm in diameter. It should be long enough to coil around a 25 cm tray. Set aside.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Wrap and coil",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 180°C fan (200°C conventional). Line a large baking tray with baking paper.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Lay one sheet of {{filo-pastry}} on a clean surface with a long side facing you. Brush with melted {{unsalted-butter}}. Lay a second sheet on top and brush again.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place the almond paste sausage along the long edge nearest you, leaving a 3 cm border. Fold the short side edges over the filling to enclose the ends, then roll the whole thing away from you to form a long cylinder. Brush the outside with butter.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Starting at one end, coil the cylinder into a flat spiral on the lined tray. Tuck the loose end underneath. Continue adding more buttered filo sheets and rolling the snake longer if you have remaining almond paste.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Brush the top of the coil generously with melted butter. Bake for 25 to 30 minutes until golden all over.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Leave to cool for 10 minutes, then dust generously with the icing sugar and cinnamon mixture. Serve in wedges.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Filo handling is the skill to practise.",
          "items": [
            {
              "fix": "Keep all unused sheets covered with a damp (not wet) cloth at all times. Work quickly. A few tears in inner layers are not visible in the finished pastry.",
              "cause": "Sheets dried out.",
              "symptom": "Filo tearing while rolling."
            },
            {
              "fix": "Fold the short side edges firmly over the filling and press them down before rolling. A small dab of water helps the filo stick.",
              "cause": "End flaps not sealed.",
              "symptom": "Filling leaking from the ends."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
