      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and prove the dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Combine {{strong-bread-flour}}, {{yeast-fast-action}}, {{caster-sugar}}, and {{sea-salt-fine}} in the bowl of a stand mixer fitted with a dough hook. Add {{eggs}} and warm {{whole-milk}} and mix on low speed until combined, about 2 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Increase to medium speed and knead for 5 minutes. Add {{unsalted-butter}} a few pieces at a time, allowing each addition to incorporate before adding the next. Continue kneading for a further 8 to 10 minutes until the dough is smooth, stretchy, and pulls away from the sides of the bowl.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cover the bowl and leave to rise at room temperature for 1.5 to 2 hours until doubled in size.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Shape and second prove",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Tip the risen dough onto a lightly floured surface. Divide into 12 equal pieces (about 80g each). Shape each into a smooth ball by cupping your palm over the dough and rolling with light pressure. Place on baking paper squares or a lightly oiled tray.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cover loosely and prove for a further 45 minutes to 1 hour until noticeably puffed.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fry and fill",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat {{sunflower-oil}} in a deep fryer or large saucepan to 175°C. Have kitchen paper and a tray ready.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Fry 3 to 4 doughnuts at a time for 2.5 to 3 minutes per side, turning once, until deep golden brown all over. Lift out with a slotted spoon and drain briefly on kitchen paper.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "While still hot, roll each doughnut in {{caster-sugar}} to coat.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Once cool enough to handle (about 5 minutes), use a skewer to make a small hole in the side of each doughnut. Fit a piping bag with a round nozzle, fill with {{jam}}, and pipe 15 to 20g of jam into each doughnut. You will feel resistance when the doughnut is full.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Frying temperature and proving time are the two critical factors.",
          "items": [
            {
              "fix": "Reduce to 170°C and fry slightly longer. The inside needs time to cook through.",
              "cause": "Oil too hot.",
              "symptom": "Pale outside but raw doughy inside."
            },
            {
              "fix": "Both proves matter. A cold oil temperature means the doughnut sits in the oil absorbing fat rather than crisping. Keep the temperature consistent.",
              "cause": "Underproved, or oil too cool so they absorbed fat.",
              "symptom": "Dense, heavy doughnuts."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
  },
