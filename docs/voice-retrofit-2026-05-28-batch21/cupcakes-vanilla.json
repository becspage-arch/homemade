      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake the cupcakes",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan (190°C conventional). Line a 12-hole muffin tin with paper cases.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat {{unsalted-butter}} and {{caster-sugar}} together until pale and very fluffy, about 3 to 4 minutes. Add {{vanilla-extract}}.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add {{eggs}} one at a time, beating well between each. If the mixture curdles, add a tablespoon of flour to bring it back together.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add {{self-raising-flour}} to the bowl in two additions, alternating with {{whole-milk}}. Fold each addition in gently until just combined.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Divide the batter evenly between the 12 cases, filling each about two thirds full. Bake for 18 to 20 minutes until risen, pale golden, and springy to the touch. Cool in the tin for 5 minutes, then transfer to a rack.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the buttercream and finish",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat {{unsalted-butter}} alone on high speed for 2 minutes until very pale. Add {{icing-sugar}} in three additions, beating for 1 minute between each. Add {{vanilla-extract}} and {{whole-milk}} and beat for a further 3 minutes until light and fluffy.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pipe or spoon buttercream onto each cooled cupcake. If piping, use a star nozzle and pipe in a swirl from the outside in. If spooning, use the back of the spoon to create a small peak.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Cupcakes are straightforward but have a few reliable failure points.",
          "items": [
            {
              "fix": "Lower the temperature by 10 degrees and check that the flour is self-raising, not plain. A slightly domed top is fine for a buttercream swirl; a sharply peaked top suggests over-leavening.",
              "cause": "Oven too hot, or too much baking powder in self-raising flour.",
              "symptom": "Peaked and domed tops rather than flat."
            },
            {
              "fix": "Refrigerate the bowl for 10 minutes, then beat again. Buttercream needs cool, soft butter, not warm melting butter.",
              "cause": "Butter too warm.",
              "symptom": "Buttercream greasy and split-looking."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
  },
