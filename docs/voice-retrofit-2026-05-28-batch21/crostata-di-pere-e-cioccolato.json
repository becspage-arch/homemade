      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and blind-bake the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub {{plain-flour}}, {{icing-sugar}}, and cold {{unsalted-butter}} (the pastry quantity) together until like breadcrumbs. Add {{egg-yolks}} and {{lemon-zest}} and mix to a firm dough. Wrap and refrigerate for 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan. Roll the pastry to 3 mm thick, line the tart tin, and trim. Refrigerate for 15 minutes. Line with baking paper, fill with baking beans, and blind-bake for 15 minutes. Remove the beans and paper and bake for a further 10 to 12 minutes until pale golden. Cool completely.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Poach the pears",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Peel and halve {{pear}}. Bring 400ml water, {{caster-sugar}}, and {{vanilla-extract}} to a simmer in a saucepan. Add the pear halves and poach for 8 to 12 minutes until just tender when pierced with a knife. Remove and leave to cool completely, then slice thinly.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the chocolate filling and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat {{double-cream}} to a simmer and pour over {{dark-chocolate}} in a heatproof bowl. Stir until smooth. Add the butter portion of {{unsalted-butter}} and stir until melted.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour the chocolate filling into the cooled pastry case and refrigerate for at least 30 minutes until set to a firm ganache.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Arrange the sliced pears over the set chocolate, fanning them from the centre or in concentric rings. Serve at room temperature.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "The most common issue is timing the stages.",
          "items": [
            {
              "fix": "Return to the fridge and check again after 30 minutes. A 1:1 ratio of cream to chocolate sets to a firm, sliceable ganache.",
              "cause": "Not chilled for long enough, or cream-to-chocolate ratio too high.",
              "symptom": "Chocolate filling not setting."
            },
            {
              "fix": "Slice and arrange the pears just before serving, or toss the slices briefly in a little of the cooled poaching liquid which contains enough sugar to slow browning.",
              "cause": "Oxidation.",
              "symptom": "Pears browning after slicing."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
