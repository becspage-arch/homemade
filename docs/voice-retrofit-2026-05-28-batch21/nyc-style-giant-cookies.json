      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Whisk {{unsalted-butter}}, {{light-brown-sugar}}, and {{caster-sugar}} together in a large bowl until combined. Add {{eggs}} and {{vanilla-extract}} and whisk until the mixture is smooth and slightly thickened.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add {{plain-flour}}, {{bicarbonate-of-soda}}, and {{sea-salt-fine}}. Stir with a wooden spoon or spatula until a thick dough forms. Fold in {{dark-chocolate}}.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Refrigerate the dough for at least 30 minutes (or up to 3 days for better flavour and texture).",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan (190°C conventional). Line two large baking trays with baking paper.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Scoop the dough into 12 equal balls (roughly 80g each) and place well apart on the trays, at most 6 per tray. Flatten each ball slightly with your palm. Scatter a few sea salt flakes on top of each if using.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake one tray at a time for 12 to 14 minutes until the edges are set and golden but the centres still look underdone. They will firm up as they cool. Leave on the tray for 5 minutes, then transfer to a rack.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
