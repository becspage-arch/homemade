      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub {{plain-flour}}, {{icing-sugar}}, {{sea-salt-fine}}, and cold {{unsalted-butter}} (the pastry quantity) together until the mixture resembles breadcrumbs. Add 3 to 4 tablespoons of cold water, one at a time, mixing until a dough forms. Flatten into a disc, wrap, and refrigerate for 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 190°C fan (210°C conventional). Line a baking tray with baking paper.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the pastry on a lightly floured surface to a rough circle, about 35 cm across and 3 mm thick. Transfer to the lined tray.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Scatter {{almond-flour}} over the pastry, leaving a 6 cm border. Toss {{apple}} slices with {{caster-sugar}} and {{cinnamon-ground}}, then pile them on top of the almond flour. Dot the butter over the top if using.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Fold the pastry border up and over the fruit edge, pleating as you go. Press gently to seal. Brush the pastry with beaten egg and scatter the tablespoon of caster sugar over the pastry.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 35 to 40 minutes until the pastry is deep golden and the fruit is tender and caramelised at the edges. Cool on the tray for 10 minutes before sliding onto a board to serve.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A free-form galette is almost impossible to ruin.",
          "items": [
            {
              "fix": "Press the folds firmly so the wall holds. A small amount of leakage is expected; the almond flour base absorbs most of it. Leaked caramel on the baking paper is not a problem.",
              "cause": "Gaps in the folded edge.",
              "symptom": "Filling juices leaking out during baking."
            },
            {
              "fix": "Slice fruit thinly. The almond flour layer absorbs excess juice; increase it to 4 tablespoons if the fruit is very juicy.",
              "cause": "Too much juice from the fruit, or fruit sliced too thick.",
              "symptom": "Pastry base soggy."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
