    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "The key to a good ",
            "type": "text"
          },
          {
            "text": "shortcrust pastry",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termId": "cmpa9wgcf0000rwv4dzwe9dav"
                }
              }
            ]
          },
          {
            "text": " is keeping everything cold. Cold fat, cold water, cold hands. Work quickly and stop mixing as soon as the dough holds together. Overworking develops gluten and makes the pastry tough rather than short.",
            "type": "text"
          }
        ]
