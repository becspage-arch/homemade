      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Sift {{plain-flour}}, {{icing-sugar}}, and {{sea-salt-fine}} into a large bowl. Rub in the cold {{unsalted-butter}} until the mixture looks like rough breadcrumbs. Add {{eggs}} (just enough to bind; start with the beaten egg and use cold water to finish if needed) and mix to a firm dough. Divide in two, one slightly larger than the other. Flatten into discs, wrap, and refrigerate for 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Prepare the filling and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 190°C fan (210°C conventional). Place a baking tray in the oven to heat.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Toss {{apple}} slices with {{blackberries}}, {{caster-sugar}}, {{cornflour}}, and {{cinnamon-ground}}.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the larger pastry disc on a floured surface to a circle about 3 mm thick and large enough to line the pie dish with overhang. Lay it in and press into the base and sides. Fill with the fruit mixture, mounding it slightly in the centre.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll the second disc to the same thickness. Brush the pastry rim with beaten egg, lay the lid on top, and press the edges together. Trim the excess and crimp. Cut a small cross in the centre to let steam escape. Brush the top with beaten egg and scatter with caster sugar if using.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place on the hot baking tray in the oven. Bake for 40 to 45 minutes until deep golden all over. Cover loosely with foil if the top colours too quickly. Leave to rest for 10 minutes before cutting.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Pastry problems are nearly all about temperature and handling.",
          "items": [
            {
              "fix": "Always bake on a preheated metal tray to crisp the base from the start. The cornflour absorbs juice from the fruit; without it the base will likely be wet.",
              "cause": "Pie placed on a cold tray, or filling too wet.",
              "symptom": "Soggy bottom."
            },
            {
              "fix": "Press the pastry gently into the dish rather than stretching it. If it looks very elastic, refrigerate for a further 15 minutes before filling.",
              "cause": "Overstretched when lining the dish, or not chilled before baking.",
              "symptom": "Pastry shrinking from the sides."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
