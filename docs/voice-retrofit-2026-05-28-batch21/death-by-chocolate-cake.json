      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake the sponge",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 170°C fan (190°C conventional). Grease and line two 20 cm round tins.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Melt 200g of {{dark-chocolate}} in a heatproof bowl over barely simmering water, stirring occasionally. Set aside to cool for 10 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat {{unsalted-butter}}, {{caster-sugar}}, and {{light-brown-sugar}} until pale and fluffy, about 3 to 4 minutes. Beat in {{eggs}} one at a time.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Stir in the cooled melted chocolate. Sift in {{plain-flour}}, {{cocoa-powder}}, and {{baking-powder}}. Fold in alternating with {{soured-cream}} until just combined.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Divide between the two tins. Bake for 32 to 35 minutes until a skewer comes out with moist crumbs. Cool in the tins for 10 minutes, then turn onto racks and cool completely.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the buttercream and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat the second quantity of {{unsalted-butter}} until very pale, about 2 minutes. Sift in {{icing-sugar}} and {{cocoa-powder}} in three additions, beating between each. Add {{whole-milk}} and beat for 3 minutes until smooth and light.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place one sponge on a board or stand. Spread with half the buttercream. Place the second sponge on top. Use the remaining buttercream to coat the top and sides thinly.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Refrigerate the assembled cake for 30 minutes while you make the ganache.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the ganache and finish",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat {{double-cream}} to a simmer and pour over the remaining 200g of {{dark-chocolate}}. Stir until completely smooth. Leave to cool for 15 to 20 minutes until thick but still pourable.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour the ganache over the chilled cake from the centre, letting it spread and drip down the sides. Leave at room temperature for at least 20 minutes before serving.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "This is a reliable cake for all its richness.",
          "items": [
            {
              "fix": "Cool completely on the rack before frosting. A warm sponge will melt the buttercream and slide.",
              "cause": "Not fully cooled, or turned out too soon.",
              "symptom": "Sponge layers cracking or crumbling when stacked."
            },
            {
              "fix": "Return the ganache bowl to the warm water bath for 30 seconds and stir. It should flow from a spoon in a slow ribbon.",
              "cause": "Cooled too long.",
              "symptom": "Ganache set too firm before pouring."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
  },
