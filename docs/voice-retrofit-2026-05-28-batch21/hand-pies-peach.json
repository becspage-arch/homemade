      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Combine {{peaches}}, {{caster-sugar}}, {{cornflour}}, {{vanilla-extract}}, {{cinnamon-ground}}, and {{lemon-juice}} in a bowl. Stir and leave for 15 minutes. The cornflour will absorb the juice. Leave to cool completely.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the pastry and assemble",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Rub {{plain-flour}}, {{icing-sugar}}, {{sea-salt-fine}}, and cold {{unsalted-butter}} together until the mixture resembles breadcrumbs. Add 4 to 5 tablespoons of cold water, a tablespoon at a time, until the dough comes together. Divide in two, wrap, and refrigerate for 30 minutes.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 190°C fan (210°C conventional). Line two baking trays with baking paper.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Roll one half of the pastry to about 3 mm thick on a floured surface. Cut into 10 cm x 12 cm rectangles (or use a round cutter for a D-shape fold). You need 16 pieces total. Re-roll trimmings as needed.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place a heaped tablespoon of filling on one half of each pastry piece, leaving a 1.5 cm border. Brush the border with beaten egg. Fold the pastry over to enclose the filling. Press the edges together firmly with a fork to seal. Transfer to the lined trays.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Brush the tops with beaten egg and scatter with {{caster-sugar}}. Cut a small slit in the top of each pie. Bake for 22 to 25 minutes until deep golden. Cool on a rack for 10 minutes before serving.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "Sealing is the critical step.",
          "items": [
            {
              "fix": "Press the fork tines firmly all the way around. A small amount of caramelised leakage is normal. If there is a lot of liquid in the filling before it goes in, drain it first and add a little more cornflour.",
              "cause": "Seal not pressed firmly enough, or filling too wet.",
              "symptom": "Filling leaks during baking."
            },
            {
              "fix": "Preheat the baking tray in the oven before placing the pies on it. This gives the bottom crust a head start.",
              "cause": "Tray not hot enough.",
              "symptom": "Pastry pale on the bottom."
            }
          ],
          "heading": "Troubleshooting"
        }
      }
    ]
  },
