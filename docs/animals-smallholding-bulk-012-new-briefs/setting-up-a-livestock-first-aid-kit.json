{
  "slug": "setting-up-a-livestock-first-aid-kit",
  "title": "Setting Up a Livestock First Aid Kit",
  "subtitle": "What to keep on the holding for emergencies before the vet arrives",
  "excerpt": "A stocked first aid kit does not replace a vet. It buys time and keeps an animal stable while professional help is on the way. Knowing what to keep and how to use it is part of responsible livestock keeping.",
  "type": "TECHNIQUE",
  "categorySlug": "animals-smallholding",
  "subCategorySlug": "smallholding-skills",
  "difficulty": "BEGINNER",
  "season": "YEAR_ROUND",
  "timeMinutes": 20,
  "sourceType": "SYNTHESISED",
  "sourceNotes": "NADIS (National Animal Disease Information Service) livestock emergency care guidance; general veterinary first aid references including The Sheep Keeper's Veterinary Handbook (Judith Charnley); synthesised from practitioner guidance and livestock-keeping references.",
  "glossaryTerms": [
    {
      "slug": "drenching-gun",
      "term": "Drenching gun",
      "definition": "A device used to deliver liquid medicines, fluids, or electrolytes directly into an animal's throat. Used when an animal cannot or will not drink voluntarily."
    },
    {
      "slug": "stomach-tube",
      "term": "Stomach tube",
      "definition": "A flexible tube passed through the mouth or nostril into the stomach, used to deliver fluids or relieve bloat. Requires practice and ideally vet instruction before first use."
    },
    {
      "slug": "colostrum",
      "term": "Colostrum",
      "definition": "The first milk produced by a mammal after birth. Rich in antibodies and vital for newborn survival. Colostrum supply in a first aid kit usually means frozen or dried colostrum kept for emergency bottle-feeding."
    },
    {
      "slug": "iodine-solution",
      "term": "Iodine solution",
      "definition": "An antiseptic liquid used to disinfect umbilical cords in newborns and clean wounds. Dilute iodine is used for navels; strong iodine for instrument disinfection."
    }
  ],
  "techniqueSlugs": [],
  "criticalTechniques": [],
  "aliases": [
    "livestock emergency kit",
    "sheep first aid",
    "goat first aid kit",
    "smallholding vet kit"
  ],
