{
  "slug": "smallholding-record-keeping-basics",
  "title": "Smallholding Record Keeping Basics",
  "subtitle": "What the law requires you to keep and for how long",
  "excerpt": "UK law requires keepers of livestock to maintain specific written records. This covers the medicine book, movement records, and feed records. Knowing what to record and how long to keep it protects you from penalties and supports animal welfare.",
  "type": "READING",
  "categorySlug": "animals-smallholding",
  "subCategorySlug": "smallholding-skills",
  "difficulty": "BEGINNER",
  "season": "YEAR_ROUND",
  "timeMinutes": 15,
  "sourceType": "SYNTHESISED",
  "sourceNotes": "UK Government guidance: APHA livestock keeper obligations; Veterinary Medicines Regulations 2013; The Sheep and Goats (Records, Identification and Movement) (England) Order 2009; Cattle Identification Regulations 2007. Synthesised from official DEFRA and APHA publications.",
  "glossaryTerms": [
    {
      "slug": "medicine-book",
      "term": "Medicine book",
      "definition": "A written record of all veterinary medicines given to livestock, required by law under the Veterinary Medicines Regulations 2013."
    },
    {
      "slug": "holding-number",
      "term": "Holding number",
      "definition": "A unique identifier issued by the Rural Payments Agency (RPA) to every registered livestock holding in England."
    },
    {
      "slug": "withdrawal-period",
      "term": "Withdrawal period",
      "definition": "The minimum time that must pass after giving a medicine before an animal or its produce can enter the food chain."
    },
    {
      "slug": "cph-number",
      "term": "CPH number",
      "definition": "County Parish Holding number. A nine-digit code that identifies the location of a livestock holding. Required before you can keep most farmed animals."
    }
  ],
  "techniqueSlugs": [],
  "criticalTechniques": [],
  "aliases": [
    "livestock records uk",
    "smallholding paperwork",
    "animal medicine book"
  ],
  "recipeTools": [],
  "projectSchedule": [],
  "body": {
    "type": "doc",
    "content": [
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Why records matter"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Keeping livestock in the UK is a regulated activity. You must register your holding and obtain a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "cph-number"
                }
              }
            ],
            "text": "CPH number"
          },
          {
            "type": "text",
            "text": " before your first animal arrives. Records are inspected by the Animal and Plant Health Agency (APHA). Incomplete records can result in fines. They also protect you if there is a disease outbreak or a welfare investigation."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "The medicine book"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "You must keep a "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "medicine-book"
                }
              }
            ],
            "text": "medicine book"
          },
          {
            "type": "text",
            "text": " for all farmed animals. Record every medicine treatment, even over-the-counter products. Each entry must include:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The date of treatment"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The name and batch number of the product"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The dose given and the route of administration"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Which animal or group was treated (with tag numbers where relevant)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termSlug": "withdrawal-period"
                        }
                      }
                    ],
                    "text": "withdrawal period"
                  },
                  {
                    "type": "text",
                    "text": " and the date it ends"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The name of the prescribing vet, if applicable"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Keep the medicine book for at least five years. Some records for cattle must be kept for three years after the animal leaves the holding. Check species-specific rules with APHA."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Movement records"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Every time an animal moves on or off your "
          },
          {
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termSlug": "holding-number"
                }
              }
            ],
            "text": "holding number"
          },
          {
            "type": "text",
            "text": ", you must record it. Movement records must show:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The date of movement"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The number of animals moved"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The identification numbers of those animals"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Where they came from or went to (CPH number of the other holding)"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Movement records must be kept for at least three years. For cattle, records must be sent to the British Cattle Movement Service (BCMS). For pigs, sheep, and goats, online reporting is also required. See the companion tutorial on online movement reporting for species-specific detail."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Feed records"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "If your animals are part of a food chain, you must record all feed given to them. This applies even if you grow your own fodder. Records must show:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "What feed was used"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Where it came from"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "When it was given and to which animals"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Feed records must be kept for at least five years. This requirement comes from EU-retained food law that still applies in Great Britain."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Practical storage tips"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A simple A4 folder with sections for each record type works well. Date every entry on the day it happens. Do not rely on memory. Keep the folder in a dry, accessible place near where you handle animals. A waterproof cover sleeve costs little but prevents records from becoming unreadable."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Back up paper records with a photograph on your phone each week. This takes two minutes and gives you a digital copy if the original is lost or damaged."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "How long to keep each record"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Medicine book: 5 years minimum"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Movement records: 3 years minimum (cattle passports: lifetime of animal plus 3 years)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Feed records: 5 years minimum"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Identification records (ear tag registers): 3 years after the animal leaves"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "When in doubt, keep records longer than the legal minimum. Storage costs nothing but missing records can be expensive."
          }
        ]
      }
    ]
  }
}