        "content": [
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though millions once felt out of reach, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though I sometimes doubt I'm the kind of person that level of wealth is for, I deeply and completely accept myself." }] }]
          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Even though \"millionaire\" has felt like it belongs to someone else, I deeply and completely accept myself." }] }]
          }
        ]
      },
