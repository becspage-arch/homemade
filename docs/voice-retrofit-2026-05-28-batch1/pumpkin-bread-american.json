      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Prepare",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 160°C fan. Grease and line a 900 g loaf tin.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Mix wet ingredients",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "In a large bowl, whisk the {{pumpkin-puree}} with the {{light-brown-sugar}}. Add the {{vegetable-oil}}, {{free-range-eggs}}, and {{vanilla-extract}}. Whisk until smooth.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Add dry ingredients",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Add the {{plain-flour}}, {{bicarbonate-of-soda}}, and {{baking-powder}}. Add the {{fine-sea-salt}}. Add the {{ground-cinnamon}}, {{ground-ginger}}, {{ground-nutmeg}}, and {{ground-cloves}}. Stir until just combined.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake, 55 to 65 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Pour into the tin. Bake for 55 to 65 minutes until a skewer inserted in the centre comes out clean. The top will crack along the centre. Cool in the tin for 20 minutes before turning out.",
            "type": "text"
          }
        ]
      }
    ]
  },
