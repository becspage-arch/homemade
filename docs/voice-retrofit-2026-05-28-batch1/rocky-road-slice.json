                  "quantity": 0.25,
                  "isOptional": false
                }
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Line the tin",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Line a 20×30 cm tin with baking paper.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Melt chocolate",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt the {{dark-chocolate}}, {{unsalted-butter}}, and {{golden-syrup}} in a heatproof bowl set over a pan of barely simmering water using the ",
            "type": "text"
          },
          {
            "text": "bain-marie",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termId": "cmp1gmolt00030sv4n3xzzjhh"
                }
              }
            ]
          },
          {
            "text": " method. Stir until smooth, then remove from the heat and stir in the {{fine-sea-salt}}. Allow to cool for 5 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fold in the fillings",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Fold the broken {{digestive-biscuits}} into the chocolate. Fold in the {{mini-marshmallows}}. Fold in the {{raisins}}. Stir until everything is coated. Tip into the tin and press into an even layer.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Chill and cut",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Refrigerate for at least 2 hours until completely set. Lift out by the paper, place on a board, and cut into 16 pieces. Store in the fridge.",
            "type": "text"
          }
        ]
      }
    ]
  },
