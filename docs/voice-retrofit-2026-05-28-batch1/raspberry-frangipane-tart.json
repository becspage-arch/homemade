      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and chill the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Rub the cold {{unsalted-butter}} (for the pastry) into the {{plain-flour}} (for the pastry), {{icing-sugar}}, and {{fine-sea-salt}} until the mixture resembles coarse sand. Mix in the egg yolk and 1 to 2 tablespoons of cold water until the dough just comes together. Flatten into a disc, wrap, and refrigerate for 30 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Blind-bake the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 190°C fan. Roll the pastry to 3 mm thick and line a 23 cm tart tin with a slight overhang above the rim. Prick the base, line with baking paper, and fill with baking beans. Bake for 12 minutes. Remove the beans and paper and bake for a further 5 to 6 minutes until the base is dry and lightly golden. Reduce the oven to 170°C fan.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and add the frangipane",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Beat the {{unsalted-butter}} (for the filling) and {{caster-sugar}} together until pale. Beat in the {{free-range-eggs}} from the filling and the {{almond-extract}}. Fold in the {{ground-almonds}} and {{plain-flour}} (for the filling). Spread the frangipane into the pastry case. Press the {{raspberries}} into the surface in a single layer.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake, 35 to 40 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Bake at 170°C fan for 35 to 40 minutes until the frangipane is set, golden, and a skewer in the centre comes out clean. The raspberries will sink slightly into the filling. Cool in the tin for 20 minutes before slicing.",
            "type": "text"
          }
        ]
      }
    ]
