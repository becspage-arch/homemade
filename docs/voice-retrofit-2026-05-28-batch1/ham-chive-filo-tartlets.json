            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Vegetarian: use roasted veg in place of the ham. Try courgette, pepper, and aubergine with feta.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Make-ahead: assemble fully the day before, refrigerate, and bake the morning of.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Make ahead, freezing, leftovers",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid.",
            "type": "text"
          }
        ]
      },
