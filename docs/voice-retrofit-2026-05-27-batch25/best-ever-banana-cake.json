      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Make buttermilk if not pre-bought",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Mix the milk (milk, oat milk or almond milk) and the lemon juice or white vinegar in a jar or bowl until well combined.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Let the mixture rest at room temperature for about 10 minutes. After this time, the milk will thicken and curdle. Use immediately.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Preheat oven to 275°.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Grease and flour a 9 x 13 pan.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "In a small bowl, mix mashed banana with the lemon juice; set aside.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "In a medium bowl, mix flour, baking soda and salt; set aside.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "In a large bowl, cream 3/4 cup butter and 2 1/8 cups sugar until light and fluffy.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat in eggs, one at a time, then stir in 2 tsp vanilla.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat in the flour mixture alternately with the buttermilk.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Stir in banana mixture.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Pour batter into the prepared pan and bake in a preheated oven for one hour or until a toothpick inserted in the centre comes out clean.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Remove from the oven and place directly into the freezer for 45 minutes. This will make the cake very moist.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "For the frosting, cream the butter and cream cheese until smooth.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Beat in 1 teaspoon vanilla.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Add icing sugar and beat on low speed until combined, then on high speed until frosting is smooth.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Spread on cooled cake.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Sprinkle chopped walnuts over top of the frosting, if desired.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Test with a skewer. It should come out with a few moist crumbs, not wet batter. Don't open the oven before three-quarters of the bake time.",
              "cause": "Underbaked, or the oven door opened too early.",
              "symptom": "Cake sinks in the middle"
            },
            {
              "fix": "Check at the minimum bake time and every five minutes after. Weigh flour for cake recipes, cup measures vary by 20% depending on how you scoop.",
              "cause": "Overbaked, or too much flour measured by cup not weight.",
              "symptom": "Cake is dry"
            },
            {
              "fix": "Drop the temperature by 10°C and check earlier. Domed cakes can be trimmed flat once cool.",
              "cause": "Oven too hot, or batter too thick.",
              "symptom": "Top cracked or domed"
            },
            {
              "fix": "Check baking powder is fresh. It loses lift after six months. Use room-temperature butter and eggs so the batter holds air.",
              "cause": "Raising agent stale or omitted, or butter and eggs cold.",
              "symptom": "Cake didn't rise"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Variations",
            "type": "text"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Citrus version: replace the vanilla with the zest of an orange or lemon.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Nut-free: swap ground almonds for desiccated coconut or extra plain flour, weight for weight.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Make ahead, freezing, leftovers",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A British home cook's dish. It sits among the recipes families remember without thinking about, the kind that gets adjusted across generations and never quite the same twice.",
            "type": "text"
          }
        ]
      }
    ]
