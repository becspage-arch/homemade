      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the tangzhong"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Whisk 25 g of flour with 125 ml of milk in a small saucepan over medium heat. Stir constantly as you heat it; it will begin to thicken at around 65°C and become a thick, porridge-like paste. Remove from the heat and leave to cool to room temperature."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix the dough"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Combine 295 g of flour, yeast, sugar, and salt in a large bowl. Add the cooled tangzhong, warm milk, and egg, and mix to a dough. Add the softened butter a little at a time, kneading it in as you go. The dough is quite soft; resist adding extra flour. Knead for 10 minutes until smooth and slightly tacky, pulling back from the bowl sides but still soft."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bulk ferment, 75 minutes"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Cover the bowl and leave in a warm place until the dough has nearly doubled, around 75 minutes. Enriched doughs can take a little longer than lean doughs; the fat slows the yeast slightly."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Divide, shape, and proof"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Divide the dough into 8 equal pieces. Shape each into a tight ball on a lightly floured surface and place on a lined baking tray, leaving 3 cm between them. Cover loosely and prove for 45 minutes, until clearly puffed."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Glaze and bake"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 180°C fan. Brush the buns gently with the egg-and-milk glaze. Bake for 16 to 18 minutes, until the tops are deep gold. They should feel hollow when you tap the base. Transfer to a wire rack immediately; leaving them on the hot tray steams the base and softens the crust faster than necessary."
          }
        ]
      }
    ]
  }
