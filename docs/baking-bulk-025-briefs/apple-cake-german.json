      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Prepare"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 170°C fan. Grease a 23 cm springform tin and line the base. Toss the apple chunks with lemon juice and set aside."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix the batter"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Beat the butter and caster sugar together until pale and light, about 3 minutes. Add the eggs one at a time with the vanilla, beating well after each. Sift over the flour, baking powder, cinnamon, and salt, and fold in with a spatula until just combined. The batter is thick. Fold in the apple chunks, coating them with batter but not breaking them up."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Scrape the batter into the prepared tin and smooth the top. Scatter with demerara sugar. Bake for 45 to 50 minutes, until a skewer through the thickest part of the batter (not through an apple chunk) comes out clean and the top is golden and set. The cake sinks slightly as it cools; this is the apple moisture releasing. Cool in the tin for 20 minutes before releasing the springform. Serve at room temperature with crème fraîche."
          }
        ]
      }
    ]
  }
