      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake the cake"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 170°C fan. Grease two 20 cm round tins and line the bases. Sift the flour, bicarbonate of soda, baking powder, spices, and salt into a large bowl. In a separate bowl, whisk together the sugar, oil, and eggs until combined. Pour the wet mixture into the dry and fold until just incorporated. Fold in the grated carrot and walnuts. Divide between the two tins and bake for 30 to 35 minutes, until a skewer comes out clean and the tops spring back when pressed. Cool in the tins for 10 minutes, then turn out onto wire racks."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the frosting"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Beat the softened butter until fluffy, then beat in the cold cream cheese until smooth. The cream cheese must be cold; warm cream cheese frosting becomes runny. Beat in the sifted icing sugar in two additions, then the vanilla. Chill for 15 minutes if it looks too soft to spread."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Assemble"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Place one cooled cake layer on a plate. Spread a third of the frosting evenly over the top. Place the second layer on top. Spread the remaining frosting over the top and sides, or pile it on the top and swirl roughly. Scatter over a few walnut halves to finish."
          }
        ]
      }
    ]
  }
