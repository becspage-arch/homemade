      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Prepare the base"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 160°C fan. Wrap the outside of a 23 cm springform tin tightly in two layers of foil (to prevent water seeping in from the bain-marie). Mix the crushed biscuits, melted butter, and 20 g of sugar. Press firmly into the base of the tin and 2 cm up the sides. Bake for 8 minutes, then cool."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the filling"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Beat the cream cheese with the sugar and flour until smooth. Beat in the vanilla, then the eggs one at a time on low speed; do not over-beat, as air in the filling causes cracking. Stir in the double cream. Pour over the cooled base. The batter should be smooth and pourable with no lumps."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake in a water bath"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Set the cheesecake tin inside a large roasting pan. Pour boiling water into the roasting pan to reach halfway up the sides of the springform tin. Bake for 55 minutes, until the edges are set and the centre still has a slight wobble. Stir together the soured cream, 30 g sugar, and vanilla, then pour and spread over the surface. Return to the oven for 10 minutes. Turn off the oven, leave the door ajar, and leave the cheesecake inside for 1 hour. Remove from the water bath and cool completely at room temperature before refrigerating for at least 8 hours."
          }
        ]
      }
    ]
  }
