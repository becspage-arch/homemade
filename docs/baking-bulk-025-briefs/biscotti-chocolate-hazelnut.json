      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix and shape the log"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 170°C fan. Line a baking tray with baking paper. Sift the flour, cocoa, baking powder, and salt into a large bowl. Add the sugar and mix. Whisk the eggs with the vanilla, pour into the dry ingredients, and stir until a stiff, slightly sticky dough forms. Fold in the hazelnuts and chocolate chips. With damp hands, shape the dough into a log about 30 cm long and 8 cm wide on the prepared tray. Flatten slightly so it is about 3 cm thick."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "First bake and slice"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Bake for 28 to 30 minutes, until the log is firm and set through. Remove from the oven and leave to cool on the tray for 10 minutes. Reduce the oven to 150°C fan. Transfer the log to a board and, using a sharp knife, cut it at a slight diagonal into slices about 1 cm thick."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Second bake"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Lay the slices flat on the lined tray. Bake for 15 minutes, turn each slice over, and bake for another 12 to 15 minutes. The biscotti should feel dry to the touch and firm throughout with no give. They will crisp further as they cool completely on a rack. Store in an airtight tin."
          }
        ]
      }
    ]
  }
