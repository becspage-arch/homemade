      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake the sponge"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 170°C fan. Grease and line two 20 cm round cake tins. Beat the softened butter and sugar with an electric mixer for 3 minutes until pale and fluffy. Add the eggs one at a time, beating well after each. Sift in the flour, cocoa, baking powder, and salt and fold in with a spatula. Add milk until the batter drops off a spoon in 3 seconds. Divide evenly between the tins and level. Bake for 22 to 25 minutes, until the tops spring back and a skewer comes out clean. Cool in the tins for 5 minutes, then turn out onto a rack."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the buttercream"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Beat the softened butter until very pale, about 3 minutes. Add the sifted icing sugar and cocoa in two batches, then the double cream. Beat until smooth and glossy. If the buttercream is stiff, add another teaspoon of cream."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Assemble"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Place one cooled sponge on a board. Spread half the buttercream over the top to the edges. Place the second sponge on top and press down gently. Spread the remaining buttercream over the top, using a small palette knife to smooth or swirl it. Serve at room temperature; the buttercream is hard from the fridge."
          }
        ]
      }
    ]
  }
