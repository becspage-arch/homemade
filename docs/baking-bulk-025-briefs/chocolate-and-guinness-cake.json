      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Melt the butter and stout"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 175°C fan. Grease a 23 cm springform tin and line the base. Melt the butter in a large saucepan over low heat. Remove from the heat and add the stout and cocoa powder. Whisk until smooth and leave to cool for 5 minutes."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix the batter"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Whisk in the sugar, then the eggs and soured cream. Sift over the flour, baking powder, bicarbonate of soda, and salt and fold in with a spatula until just combined. The batter is thin and pourable. Pour into the prepared tin."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Bake for 50 to 55 minutes. The cake is ready when a skewer through the centre comes out clean and the top springs back lightly when pressed. The surface will be deeply dark; this is correct for a stout cake. Cool completely in the tin before removing, at least an hour. The crumb is fragile when hot."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Frost"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Beat the cream cheese with the sifted icing sugar until smooth. Add the double cream and beat briefly until the frosting holds a soft peak. Do not overbeat or it becomes grainy. Pile the frosting on top of the cooled cake and spread to the edges, leaving a rough, cloud-like finish."
          }
        ]
      }
    ]
  }
