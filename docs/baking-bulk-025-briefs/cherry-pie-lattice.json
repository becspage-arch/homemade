      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the pastry"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Rub the cold butter into the flour, sugar, and salt until rough crumbs with some butter flakes form. Add cold water a tablespoon at a time until the dough just comes together. Divide two-thirds for the base and one-third for the lattice. Flatten each piece, wrap, and refrigerate for 30 minutes. Heat the oven to 200°C fan."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Fill and lattice"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Toss the cherries with the sugar, cornflour, lemon juice, and almond extract. Roll the larger pastry piece to 3 mm and line a 23 cm pie dish, leaving overhang. Pile in the cherry filling. Roll the remaining pastry to 3 mm and cut into strips about 2 cm wide. Lay half the strips across the filling, spacing evenly, then weave the remaining strips over and under to form a lattice. Press the strip ends onto the rim, trim, and crimp the edge. Brush the lattice and rim with beaten egg and scatter with the tablespoon of caster sugar."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake and rest"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Bake for 45 to 55 minutes, until the pastry is deep golden and the filling is bubbling thickly through the lattice. Cover the edges with foil after 30 minutes if they are colouring too fast. Cool on a rack for at least 20 minutes before cutting. The filling firms as it cools."
          }
        ]
      }
    ]
  }
