      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix and knead"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Combine flour, yeast, salt, and sugar in a large bowl. Add the butter, milk, and water, and mix to a dough. The butter will not incorporate immediately; it will soften and work in as you knead. Knead on a lightly floured surface for 8 minutes, until the dough is smooth and springs back when poked. It should feel soft rather than stiff."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bulk ferment, about 60 minutes"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Cover the dough and leave in a warm place until doubled. Milk-enriched doughs often prove a little faster than plain water doughs. Check at 45 minutes; a kitchen at 22°C takes around an hour."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Divide and shape"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Divide the dough into 12 equal pieces, about 65 g each. Shape each into a tight ball by cupping your hand over the dough on an unfloured surface and moving it in a circular motion. The friction against the surface builds tension. Place the rolls in a lightly greased 30×20 cm tin in three rows of four, touching or almost touching."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Proof, 30 minutes"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Cover loosely and prove until the rolls are puffed and just touching each other at the sides. They should feel light when the tin is lifted."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Glaze and bake"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Heat the oven to 200°C fan. Brush the rolls gently with beaten egg, trying not to deflate the tops. Bake for 18 to 20 minutes, until the tops are deep gold and an instant-read thermometer through the middle roll reads at least 90°C. Transfer the whole tray to a wire rack. The rolls can be pulled apart as soon as they are cool enough to handle."
          }
        ]
      }
    ]
  }
}