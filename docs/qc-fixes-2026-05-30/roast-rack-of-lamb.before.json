  "preFix": {
    "title": "Roast rack of lamb",
    "subtitle": "French-trimmed, herb-crusted, medium-rare",
    "excerpt": "Two French-trimmed racks of lamb roasted at high heat for 25 minutes until pink throughout. A quick, impressive centrepiece for a dinner party or Easter lunch.",
    "sourceNotes": "Classic French-trimmed rack technique, widely used in British restaurant and home cooking.",
    "body": {
      "type": "doc",
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "text": "A rack of lamb is a quick roast: 25 minutes from raw to carved, with the most hands-on time spent applying the herb crust. The internal temperature is everything here. At 58 degrees C the lamb is pink and juicy; at 65 it is cooked through and still acceptable; above that it is a waste of a good rack.",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "What you need",
              "type": "text"
            }
          ]
        },
        {
          "type": "ingredientsList",
          "attrs": {
            "items": [
              {
                "name": "Rack of lamb",
                "unit": "each",
                "amount": 2,
                "prepNote": "French-trimmed, about 8 ribs each",
                "groupLabel": null,
                "isOptional": false,
                "ingredientId": "cmp49f46p0027rkv44xirv0sb",
                "ingredientSlug": "lamb-rack"
              },
              {
                "name": "Fresh breadcrumbs",
                "unit": "g",
                "amount": 60,
                "prepNote": null,
                "groupLabel": "For the crust",
                "isOptional": false,
                "ingredientId": "cmpagf70n000qd4v4b2nt1nn0",
                "ingredientSlug": "breadcrumbs-fresh"
              },
