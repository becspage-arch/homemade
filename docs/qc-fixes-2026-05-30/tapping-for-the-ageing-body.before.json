          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Even though my body is changing and parts of it look and feel different than they used to. I deeply and completely accept myself.",
                      "type": "text",
                      "marks": []
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Even though there are days when I do not like what I see in the mirror. I deeply and completely accept myself.",
                      "type": "text",
                      "marks": []
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Even though the marketing-world body is not my body, I deeply and completely accept myself.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
