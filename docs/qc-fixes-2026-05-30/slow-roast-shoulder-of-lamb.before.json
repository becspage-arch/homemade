  "preFix": {
    "title": "Slow-roast shoulder of lamb",
    "subtitle": "Six hours low and slow until it falls apart",
    "excerpt": "A whole bone-in lamb shoulder roasted at 140 degrees C for six hours until the meat pulls apart with no resistance. Little effort, long time, deeply satisfying result.",
    "sourceNotes": "Standard British slow-roast shoulder technique. Bone-in shoulder for the best flavour.",
    "body": {
      "type": "doc",
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Shoulder of lamb is the best value roasting joint. Where the leg is lean and precise in its timing, the shoulder is forgiving: the high fat and collagen content mean it almost cannot be overcooked. Six hours at 140 degrees C and it simply falls from the bone.",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "What you need",
              "type": "text"
            }
          ]
        },
        {
          "type": "ingredientsList",
          "attrs": {
            "items": [
              {
                "name": "Lamb shoulder",
                "unit": "g",
                "amount": 2200,
                "prepNote": "bone-in, about 2.2 kg",
                "groupLabel": null,
                "isOptional": false,
                "ingredientId": "cmp49f44r0024rkv4k9xk2lvx",
                "ingredientSlug": "lamb-shoulder"
              },
              {
                "name": "Garlic",
                "unit": "clove",
                "amount": 6,
                "prepNote": "halved lengthways",
                "groupLabel": null,
                "isOptional": false,
                "ingredientId": "cmp49f5bt0046rkv4vhu2h5ze",
                "ingredientSlug": "garlic"
              },
              {
                "name": "Rosemary",
                "unit": "sprig",
                "amount": 4,
                "prepNote": "broken into smaller pieces",
                "groupLabel": null,
                "isOptional": false,
                "ingredientId": "cmp49f79m007lrkv4rnhlhiq1",
                "ingredientSlug": "rosemary"
              },
              {
                "name": "Olive oil",
                "unit": "tbsp",
                "amount": 2,
                "prepNote": null,
                "groupLabel": null,
                "isOptional": false,
                "ingredientId": "cmp49faly00dirkv4w9quay23",
                "ingredientSlug": "olive-oil"
              },
              {
                "name": "Sea salt flakes",
                "unit": "tsp",
                "amount": 2,
                "prepNote": null,
                "groupLabel": null,
                "isOptional": false,
                "ingredientId": "cmp49f7ll0087rkv43k6j3dft",
                "ingredientSlug": "sea-salt-flakes"
              },
              {
                "name": "Lamb stock",
                "unit": "ml",
                "amount": 200,
                "prepNote": "or stock-beef",
                "groupLabel": null,
