        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Build the layers",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oven to 180 degrees C fan. Melt half the butter in a medium saucepan over a low heat. Add the onions and garlic and ",
                      "type": "text"
                    },
                    {
                      "text": "sweat",
                      "type": "text",
                      "marks": [
                        {
                          "type": "glossaryTooltip",
                          "attrs": {
                            "termId": "cmpqyw15m0000k4v4uibyfs9i"
                          }
                        }
                      ]
                    },
                    {
                      "text": " gently for 10 minutes until softened.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Butter a large deep pie dish or gratin dish. Layer the potato slices and softened onions in alternate layers, seasoning each potato layer with salt and tucking in the thyme sprigs. The top layer should be potato slices only, arranged neatly.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Pour over the hot stock until it just reaches the top layer of potatoes. Dot the remaining butter across the top.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Bake and brown",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Bake uncovered for 1 hour to 1 hour 15 minutes until the stock has been absorbed and the top is deeply golden and ",
                      "type": "text"
                    },
                    {
                      "text": "gratinated",
                      "type": "text",
                      "marks": [
                        {
                          "type": "glossaryTooltip",
                          "attrs": {
                            "termId": "cmpsoiqdy0000tsv4qa9qqpus"
                          }
                        }
                      ]
                    },
                    {
                      "text": ". The potatoes should be completely tender when a sharp knife is inserted.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Slice the potatoes no thicker than 3 mm. Ensure the stock level reaches the top layer before going into the oven. Continue baking and check every 10 minutes.",
                "cause": "The slices were cut too thick, or the stock did not reach the middle layers.",
                "symptom": "The potatoes are still firm in the middle after 75 minutes"
              },
              {
                "fix": "Cover with foil and continue baking at a lower temperature. Remove the foil for the last 10 minutes to re-crisp the top.",
                "cause": "The oven was too hot.",
                "symptom": "The top is very brown but the middle is underdone"
              },
              {
                "fix": "The dish should be deep rather than wide. Add an extra 100 ml of hot stock if the top layer looks dry before 30 minutes.",
                "cause": "The dish was too wide, or the stock was not enough.",
                "symptom": "The dish is dry and the stock has evaporated too fast"
              },
              {
                "fix": "The sweating step is important: raw onion slices will not soften evenly within the potato baking time.",
                "cause": "They were not softened before layering.",
                "symptom": "The onions are still raw-tasting"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Variations",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Place a lamb joint directly on top of the potato dish for the last hour of roasting: the lamb drippings fall into the potatoes as both cook. Add shredded leeks to the onion layers for a milder flavour. A handful of grated Parmesan on top before baking adds a savoury crust.",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Boulangere potatoes are named after the baker's oven tradition, where cooks would bring their potato dishes to bake in the residual heat after the bread was done. The method came to Britain through French influence. It remains a useful alternative to cream-based potato gratins.",
              "type": "text"
            }
          ]
        }
      ]
    },
    "servings": 6,
