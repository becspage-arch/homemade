        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Cook the base",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat {{extra-virgin-olive-oil}} of olive oil in a large saucepan over a medium heat. Add the {{lardons}} of pancetta and cook for 4 minutes until lightly golden. Add the {{onion}} onion and {{celery}} celery and cook for 8 minutes until soft.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add the {{garlic}} of garlic and {{rosemary}} of rosemary and cook for 1 minute. Add {{tinned-tomatoes}} of tinned tomatoes and simmer for 5 minutes, breaking up the tomatoes with a spoon.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Add beans and simmer",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add the {{borlotti-beans}} of drained borlotti beans and pour in {{stock-chicken}} of hot stock. Simmer for 10 minutes. Remove the rosemary sprig. Use the back of a spoon or a potato masher to crush about a third of the beans into the broth to thicken it.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Cook the pasta",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Bring the soup to a brisk simmer. Add {{pasta-dried}} of pasta directly to the pot. Cook according to packet instructions until al dente, stirring often as the pasta will stick.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Taste and season with salt and black pepper. Ladle into bowls and drizzle with olive oil. Finish with grated Parmesan if using.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Cook the pasta only when ready to eat. If the soup has set, add hot water or stock and reheat gently, stirring. The soup will loosen back into a ladle-able consistency.",
                "cause": "The pasta was left to stand in the soup after cooking.",
                "symptom": "Pasta has turned the soup into a solid mass"
              },
              {
                "fix": "Crush more beans against the side of the pot with a spoon, or blend a ladleful of the soup separately and stir it back in.",
                "cause": "Not enough beans were crushed to thicken the broth.",
                "symptom": "Soup is too thin"
              },
              {
                "fix": "Start checking ditalini at 7 minutes. It should be slightly underdone when you take the pot off the heat as it continues cooking in the residual heat.",
                "cause": "Small pasta cooks faster than most people expect in a thick soup.",
                "symptom": "Pasta is overcooked and soft"
              },
              {
                "fix": "The drizzle of olive oil at the end is not decoration: it carries flavour and brings the soup together. Use the best olive oil you have. Season generously and finish with black pepper.",
                "cause": "Italian bean soups need generous olive oil and a good hit of salt.",
                "symptom": "Flavour is flat"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Pasta e fagioli is one of the oldest dishes in the Italian tradition, documented in cookbooks since the 15th century. Like ribollita, it was born of economy: beans and pasta were the cheapest ingredients available. In Rome, where it is most closely associated, it is known as pasta e fasòl. Every region has a version; the Roman version uses borlotti beans and is thick, almost porridge-like.",
              "type": "text"
            }
          ]
        }
      ]
    },
    "servings": 4,
    "yieldDescription": null,
    "difficulty": "BEGINNER"
  },
