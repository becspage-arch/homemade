{
  "slug": "citronella-bug-repellent-balm",
  "capturedAt": "2026-05-30T12:36:28.170Z",
  "preFix": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "This balm uses ",
            "type": "text"
          },
          {
            "text": "citronella essential oil",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termId": "cmps3tsux00001wv4c5bghl94"
                }
              }
            ]
          },
          {
            "text": " alongside eucalyptus, both of which have documented repellent activity against mosquitoes. The beeswax and coconut-oil base creates a solid balm that melts on skin contact and clings for longer than a water-based spray. Apply generously before going outdoors and reapply every two to three hours.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Ingredients",
            "type": "text"
          }
        ]
      },
      {
        "type": "ingredientsList",
        "attrs": {
          "items": [
            {
              "name": "Beeswax pellets",
              "unit": "g",
              "amount": 15,
              "prepNote": "sets the balm firm",
              "isOptional": false,
              "ingredientId": "cmpa4jwk70006q0v4uipa25yz",
              "ingredientSlug": "beeswax-pellets"
            },
            {
              "name": "Coconut oil",
              "unit": "g",
              "amount": 45,
              "prepNote": "unrefined or refined",
