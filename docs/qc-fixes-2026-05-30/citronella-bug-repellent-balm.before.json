            }
          ],
          "defaultServings": 1
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Melt",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Place the beeswax pellets and coconut oil in a heatproof container over a double boiler. Melt over a gentle heat, stirring occasionally, until fully liquid. Remove from the heat.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Add essential oils",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Allow the melted base to cool slightly to about 50 to 55°C -- too hot and the essential oils will flash off. Add the citronella, eucalyptus, and lavender drops and stir through.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Pour and set",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Pour into two small tins or lip-balm-style containers. Leave undisturbed at room temperature for 30 minutes until fully set. Cap when completely cool.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "How to use",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Rub a small amount of balm on wrists, ankles, the back of the neck, and any exposed skin. Reapply every two to three hours outdoors. Not suitable for children under 2 years -- do not apply to the face or hands of young children. Keep away from eyes. Do not apply to cats or dogs.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Storage and shelf life",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Keep at room temperature in the sealed tin. Use within one year. Discard if the balm develops a rancid smell or if the surface is greasy and oily.",
            "type": "text"
          }
        ]
      }
    ]
  }
}