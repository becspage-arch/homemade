        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Build the base",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Melt {{unsalted-butter}} of butter in a large saucepan or casserole over a medium-low heat. Add the {{onion}} onion with a pinch of salt and ",
                      "type": "text"
                    },
                    {
                      "text": "sweat",
                      "type": "text",
                      "marks": [
                        {
                          "type": "glossaryTooltip",
                          "attrs": {
                            "termId": "cmprxt4wo0000tov4zwneakss"
                          }
                        }
                      ]
                    },
                    {
                      "text": " for 8 minutes until soft.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add the {{garlic}} of crushed garlic and {{ginger-root}} of ginger. Cook for 1 minute.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add {{coriander-seeds}} of ground coriander and ",
                      "type": "text"
                    },
                    {
                      "text": "bloom",
                      "type": "text",
                      "marks": [
                        {
                          "type": "glossaryTooltip",
                          "attrs": {
                            "termId": "cmprxt4xi0001tov4w9b2m6hh"
                          }
                        }
                      ]
                    },
                    {
                      "text": " for 30 seconds, stirring constantly, until fragrant.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Cook and blend",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Add {{carrot}} carrots and pour over {{stock-vegetable}} of hot vegetable stock. Bring to a simmer, cover, and cook for 25 minutes until the carrots are completely tender.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Remove from the heat and blend until smooth with a stick blender. Taste, adjust salt, and reheat gently if needed.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Ladle into bowls. Add a spoonful of soured cream if using and scatter fresh coriander leaves over the top.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Bloom spices for no more than 30 to 40 seconds over medium heat. Use ground coriander within six months of opening for the best flavour.",
                "cause": "The ground coriander was cooked too long in the fat before the liquid was added, or it was old and past its best.",
                "symptom": "Soup tastes bitter"
              },
              {
                "fix": "Use fresh, bright-coloured carrots. Don't cook for longer than needed: the carrots need to be tender but not mushy.",
                "cause": "The carrots were old, or the soup was overcooked, which dulls the colour.",
                "symptom": "Soup is dull orange, not vibrant"
              },
              {
                "fix": "Cook for another 5 minutes and blend again. The carrot must be fully soft before the stick blender will give a completely smooth result.",
                "cause": "The carrots were not tender enough before blending.",
                "symptom": "Texture is not smooth after blending"
              },
              {
                "fix": "Simmer uncovered for 5 to 10 minutes to reduce slightly before blending, or use slightly less stock next time.",
                "cause": "Too much stock for the quantity of carrots.",
                "symptom": "Soup is too thin"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Carrot and coriander soup became a fixture of British cafe and supermarket cooking in the 1980s and has stayed there. It is one of the clearest expressions of the shift in British cooking toward using spice as flavour rather than heat. The combination works because the earthy warmth of ground coriander meets the sweetness of the carrot exactly where both are strongest.",
              "type": "text"
            }
          ]
        }
      ]
    },
