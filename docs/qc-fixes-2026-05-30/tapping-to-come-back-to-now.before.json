                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Even though I've been everywhere but here, I'm open to returning to this quiet moment tonight.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
