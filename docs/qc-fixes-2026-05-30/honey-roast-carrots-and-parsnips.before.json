        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Method",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3
          },
          "content": [
            {
              "text": "Par-boil and roast",
              "type": "text"
            }
          ]
        },
        {
          "type": "orderedList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the oven to 200 degrees C fan. ",
                      "type": "text"
                    },
                    {
                      "text": "Par-boil",
                      "type": "text",
                      "marks": [
                        {
                          "type": "glossaryTooltip",
                          "attrs": {
                            "termId": "cmpsoh7wy0000qkv4s2li8mbq"
                          }
                        }
                      ]
                    },
                    {
                      "text": " the carrots and parsnips together in well-salted boiling water for 6 minutes. Drain well and leave to steam-dry in the colander.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Heat the butter and oil in the roasting tin for 3 minutes until the butter foams. Add the vegetables and turn to coat. Add the thyme. Season with salt. Roast for 25 minutes, turning once.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Drizzle the honey over the vegetables. Return to the oven for a further 10 minutes until ",
                      "type": "text"
                    },
                    {
                      "text": "caramelised",
                      "type": "text",
                      "marks": [
                        {
                          "type": "glossaryTooltip",
                          "attrs": {
                            "termId": "cmpsoite7000058v4adr5t3jp"
                          }
                        }
                      ]
                    },
                    {
                      "text": " and sticky at the edges.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "troubleshooter",
          "attrs": {
            "items": [
              {
                "fix": "Add honey only in the last 10 minutes. It will darken quickly.",
                "cause": "Honey was added too early in the cooking.",
                "symptom": "The honey has burnt before the vegetables are glazed"
              },
              {
                "fix": "Cut both vegetables to similar diameters: no thicker than 2 cm at the thickest point. Parsnips often need to be quartered and cored if large.",
                "cause": "The carrot pieces were thicker than the parsnip pieces.",
                "symptom": "The parsnips are golden but the carrots are still firm"
              },
              {
                "fix": "Shake the colander vigorously to remove all steam before roasting. Give the vegetables plenty of space in a wide tin.",
                "cause": "Too much moisture remaining from the par-boil, or the tin was overcrowded.",
                "symptom": "The vegetables are cooked but pale, without the deep caramel colour"
              },
              {
                "fix": "Maintain a steady 200 degrees C fan. The glaze needs sustained heat to caramelise rather than just set.",
                "cause": "The oven temperature dropped during roasting.",
                "symptom": "The honey glaze has crystallised and the vegetables are sticky but not caramelised"
              }
            ]
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Variations",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Add a teaspoon of wholegrain mustard to the honey for a mustard glaze. A pinch of cumin or coriander in the butter gives a warm spiced background. Maple syrup is a slightly more complex alternative to honey.",
              "type": "text"
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "text": "Where this dish lives",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "Honey-roast vegetables became a fixture on British Christmas tables in the 1980s. Food writers began recommending vegetable sides that could match the richness of the main course. The combination of carrots and parsnips is now so embedded in the British Christmas tradition that it appears on most supermarket Christmas side dish ranges.",
              "type": "text"
            }
          ]
        }
      ]
