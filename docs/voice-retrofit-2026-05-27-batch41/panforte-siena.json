      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix dry ingredients"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to 150°C fan. Line the base and sides of a 20 cm round tin with baking paper and dust with {{icing-sugar}}."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Combine the toasted {{blanched-almonds}}, {{hazelnuts}}, {{dried-apricots}}, {{glace-cherries}}, and {{mixed-peel}} in a large bowl. Sift in the {{plain-flour}}, {{cocoa-powder}}, {{mixed-spice}}, and {{black-pepper}}. Toss together."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the syrup and combine"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put the {{honey}} and {{caster-sugar}} in a small saucepan. Melt over medium heat. Stir until the sugar dissolves."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Increase the heat and cook without stirring until the syrup reaches 116°C."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pour immediately over the fruit and nut mixture and stir quickly to coat everything evenly. The mixture will be very stiff."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake 30 to 35 minutes, cool in tin"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tip the mixture into the prepared tin and press firmly into an even layer with wet hands."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake for 30 to 35 minutes. See the "
                  },
                  {
                    "type": "text",
                    "text": "panforte set point",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termId": "cmpa2eku10000a8v45l0yscbs"
                        }
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": ": it will look barely set when hot."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Leave to cool completely in the tin before turning out. Dust with more icing sugar and wrap in baking paper."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
