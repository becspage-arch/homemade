      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix and bake"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat the oven to 170°C (150°C fan). Grease a 23 cm round cake tin and line the base."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Whisk {{eggs}} and {{caster-sugar}} together for 2 minutes until pale. Whisk in {{olive-oil}}, then add the {{orange}} zest and juice."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fold in {{almond-flour}}, {{plain-flour}}, {{baking-powder}}, and {{salt-table}} until just combined. Pour into the tin."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake for 35 to 40 minutes until golden and a skewer comes out clean. The centre may dip slightly; that is normal for an almond cake."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cool in the tin for 15 minutes, then turn out onto a rack. Dust with {{icing-sugar}} when completely cool."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
