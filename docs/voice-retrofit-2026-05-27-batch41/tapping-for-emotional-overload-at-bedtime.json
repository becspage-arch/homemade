    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A five-minute tapping practice from the Night Tap on Day 6 of the SLEEP program. The script targets the emotional residue that accumulates across a day: conversations, small stresses, feelings that were set aside rather than processed. It moves these out before sleep.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "New to tapping? Read ",
            "type": "text"
          },
          {
            "text": "how EFT tapping works",
            "type": "text",
            "marks": [
              {
                "type": "link",
                "attrs": {
                  "href": "/mindset/how-eft-tapping-works"
                }
              }
            ]
          },
          {
            "text": " first.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "The practice",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Karate chop",
            "type": "text"
          }
        ]
