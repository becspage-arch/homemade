              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp49f7kz0086rkv4lsr8ds3o",
              "ingredientSlug": "sea-salt-fine"
            },
            {
              "name": "Rolled oats",
              "unit": "g",
              "amount": 350,
              "prepNote": null,
              "groupLabel": null,
              "isOptional": false,
              "ingredientId": "cmp871sng000e2wv4gpifi942",
              "ingredientSlug": "rolled-oats"
            }
          ],
          "defaultServings": 16
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Melt and mix"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat the oven to 160°C fan. Grease and line a 20 x 20 cm tin."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put the {{unsalted-butter}}, {{light-muscovado-sugar}}, {{golden-syrup}}, and {{sea-salt-fine}} in a medium saucepan. Melt over low heat, stirring until the butter has melted and the sugar has dissolved. Do not boil."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove from the heat and stir in the {{rolled-oats}} until all the oats are coated."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Press and bake"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tip the oat mixture into the prepared tin. Press down firmly and evenly with the back of a spoon or damp hands. Pack the oats as densely as possible, or the bars will crumble when cut."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake for 20 to 22 minutes for chewy, or 25 to 27 minutes for a crisper result. The edges should be golden-brown and the surface dry. The centre will still look slightly soft through the oats."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Score and cool"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove from the oven and score into 16 bars immediately with a sharp knife, pressing through the surface but not lifting the bars."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Leave to cool completely in the tin, at least 30 minutes, before cutting all the way through and removing. The bars firm up significantly as they cool. Store in an airtight tin."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
