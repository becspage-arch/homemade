      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Assemble and soak (night before)",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Grease a deep baking dish (roughly 23 x 33 cm) with butter or vegetable oil. Cut or tear the bread into cubes and add to the dish, filling it to about three-quarters full.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "In a large bowl, whisk together the {{eggs}}, milk, {{vanilla-extract}} of vanilla extract, {{cinnamon-ground}} of cinnamon, and {{light-brown-sugar}} of brown sugar until combined. Pour the mixture evenly over the bread.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Slice the {{strawberries}} and scatter over the top along with the {{blueberries}}.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Cover with cling film and refrigerate for at least 4 hours, or overnight.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Heat the oven to 180°C (160°C fan). Take the casserole out of the fridge 20 minutes before baking.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Bake for 35 to 50 minutes. Check at 35 minutes: the top should be golden and the custard in the centre should be set. If it is still liquid in the middle, bake for a further 10 to 15 minutes. Bake time varies depending on how much custard the bread absorbed and how cold the dish was going in.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Dust with {{icing-sugar}} of icing sugar and serve with maple syrup.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Return to the oven for 10 more minutes, covering loosely with foil if the top is already well coloured.",
              "cause": "The casserole went in cold from the fridge, or the dish is deep and the custard needs longer to set through.",
              "symptom": "Centre is still liquid after 50 minutes"
            },
            {
              "fix": "Use bread that is a few days old, or dry the cubes in a low oven (120°C) for 20 minutes before assembling.",
              "cause": "Fresh soft bread cannot absorb the custard without collapsing.",
              "symptom": "Texture is very heavy and wet in the middle"
            },
            {
              "fix": "Cover loosely with foil for the second half of baking.",
              "cause": "Oven runs hot, or dish is in the top third of the oven.",
              "symptom": "Top is very brown before the centre is set"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Variations",
            "type": "text"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Autumn version: replace the strawberries and blueberries with sliced apple or pear and a pinch of nutmeg.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Richer: use brioche or challah instead of baguette, and whole milk instead of semi-skimmed.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Make ahead, freezing, leftovers",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "The casserole is designed to be made the night before. Leftovers keep two days in the fridge; reheat covered in a low oven or microwave.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "French toast casserole is a North American brunch dish. It is popular for holidays and family gatherings, where you want something good without standing at the stove all morning. It takes the idea of pain perdu (the French way of reviving stale bread in egg) and scales it up to feed a table.",
            "type": "text"
          }
        ]
      }
    ]
  },
