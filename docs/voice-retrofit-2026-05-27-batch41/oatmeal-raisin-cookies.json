      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix, drop, bake, 12 to 14 minutes"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to 175°C fan. Line two baking trays with baking paper."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Whisk together the {{rolled-oats}}, {{plain-flour}}, {{bicarbonate-of-soda}}, {{mixed-spice}}, and {{sea-salt-fine}}."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a separate bowl, beat the {{unsalted-butter}} with the {{light-brown-sugar}} and {{caster-sugar}} until pale. Beat in the {{eggs}} and {{vanilla-extract}}."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fold in the dry ingredients, then the {{raisins}}. This is a "
                  },
                  {
                    "type": "text",
                    "text": "drop cookie",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termId": "cmp9yhhmd00009wv4qtsr0xt3"
                        }
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " dough: drop heaped tablespoons onto the lined trays, spacing them 5 cm apart."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake for 12 to 14 minutes until the edges are set and lightly coloured. The centres will look underdone. Cool on the tray for 10 minutes before moving to a rack."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
