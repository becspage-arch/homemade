      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Mix"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to 175°C fan. Oil and line the tin."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a large bowl, whisk together the {{eggs}} and {{caster-sugar}} until pale and slightly thickened, about 2 minutes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pour in the {{extra-virgin-olive-oil}} and whisk to combine. Add the {{whole-milk}}, the {{vanilla-extract}}, and the zest from both {{orange}}s. Whisk again."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the {{plain-flour}}, {{almond-flour}}, {{baking-powder}}, and {{sea-salt-fine}} and fold together until the batter is smooth."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake, 38 to 40 minutes"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pour the batter into the tin. Bake for 38 to 40 minutes until the edges pull away from the tin and a skewer inserted into the centre comes out clean."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The "
                  },
                  {
                    "type": "text",
                    "text": "oil cake crumb",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termId": "cmp9yhkzs0000hwv44goy9809"
                        }
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " will feel slightly springy when pressed, not bouncy like a butter sponge. Cool in the tin for 10 minutes, then turn out onto a rack."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Once completely cold, dust lightly with {{icing-sugar}}."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
