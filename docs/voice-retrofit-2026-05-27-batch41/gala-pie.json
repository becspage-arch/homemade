      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the hot water crust and line the tin"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Sift the {{plain-flour}} and {{sea-salt-flakes}} into a bowl. Heat the {{lard}} with 200 ml of water until just boiling. Pour into the flour and stir quickly until the dough comes together."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Work the dough while warm. Reserve a quarter for the lid. Press the rest evenly into a well-greased 900 g loaf tin, pushing it up the sides to 5 mm thickness."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Fill with pork and eggs"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mix the {{pork-mince}} and {{sausagemeat}} with the {{sage-dried}}, {{mace}}, {{nutmeg}}, {{black-pepper}}, and filling salt."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Press half the pork mixture into the lined tin. Lay the 4 hard-boiled eggs end-to-end in a row down the centre. Pack the remaining pork firmly around and over the eggs so there are no gaps."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Roll the lid pastry and seal on top. Make a steam hole in the centre and brush the pastry with beaten egg."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake and jelly"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat the oven to 200°C (180°C fan). Bake for 20 minutes, then reduce to 180°C (160°C fan) for a further 70 to 80 minutes. A probe through the steam hole should read 75°C."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cool in the tin for 1 hour, then turn out. Heat the {{stock-chicken}} and pour it slowly through the steam hole. Refrigerate for at least 8 hours."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Slice with a sharp serrated knife. Serve cold."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "rows": [
            {
              "fix": "Press a thick layer of pork into the tin first, ensuring the eggs sit in the middle third of the tin height.",
              "cause": "Not enough pork packed under the eggs to hold them central",
              "symptom": "Eggs have sunk to the bottom of the pie when sliced"
            },
            {
              "fix": "Boil eggs for 8 to 9 minutes only, then plunge straight into cold water. Overcooked eggs will have a grey-green ring but still taste fine.",
              "cause": "Hard-boiled eggs were overcooked",
              "symptom": "Egg white is grey-green around the yolk"
            },
            {
              "fix": "Dissolve 2 tsp gelatine powder in 2 tbsp cold water, then stir into the hot stock before pouring.",
              "cause": "Stock was not gelatine-rich enough",
              "symptom": "Jelly has not set after 8 hours"
            },
            {
              "fix": "Work quickly: the pastry must be pressed into the tin while still warm and pliable.",
              "cause": "Pastry was worked when it had cooled too much and become brittle",
              "symptom": "Pastry walls are thin and cracking"
            }
          ]
        },
        "content": []
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Gala pie is the butcher's counter showpiece and the village fete centrepiece. The egg line running down the middle of each slice is the point: it turns a plain pork pie into something that looks considered and celebratory. It is picnic food in the best British tradition."
          }
        ]
      }
    ]
  },
