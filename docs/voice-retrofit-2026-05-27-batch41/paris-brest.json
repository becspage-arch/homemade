              "amount": 100,
              "prepNote": "for the praline caramel"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "slug": "double-cream",
              "unit": "ml",
              "amount": 300,
              "prepNote": "very cold"
            }
          },
          {
            "type": "ingredientItem",
            "attrs": {
              "slug": "icing-sugar",
              "unit": "g",
              "amount": 30,
              "prepNote": "plus extra for dusting"
            }
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make and pipe the choux"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat the oven to 200°C conventional (180°C fan). Draw a 20 cm circle on baking paper as a guide; flip it pencil-side down on the tray."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bring the water, milk, butter, salt, and sugar to a full boil in a medium saucepan."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add all the flour at once and beat vigorously over medium heat for 1 to 2 minutes until the dough pulls cleanly from the pan sides and a light film coats the base."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tip into the mixer bowl and beat on medium speed for 1 minute to cool slightly. Add the beaten eggs gradually, beating well between each addition, until the dough is smooth, glossy, and falls in a thick ribbon."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Load into a piping bag with a large star tip. Pipe two overlapping rings around the traced circle to form a tyre shape. Scatter flaked almonds over the top."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake for 30 minutes, then reduce to 170°C conventional (150°C fan) and bake for 15 to 20 more minutes until very crisp and deep golden all over. Cool completely on a rack."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the praline cream"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Melt the sugar in a dry pan over medium heat, swirling (not stirring) until a deep amber caramel forms."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the toasted hazelnuts, toss to coat, and pour onto a baking paper-lined tray. Leave to harden."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Break into pieces and blitz in a food processor to a coarse or smooth paste, as preferred."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Whip the cream and icing sugar to firm peaks. Fold in the praline paste."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Assemble"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Split the cooled choux ring horizontally with a serrated knife. Remove any uncooked dough from the inside."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fill the bottom half generously with praline cream, piping in rosettes or spreading with a spoon. Replace the top."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Dust with icing sugar and serve within 2 hours."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
