        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the joconde sponge"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat the oven to 220°C conventional (200°C fan). Line a large rimmed tray with baking paper."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Whisk the whole eggs, almond flour, and icing sugar until thick and pale. Fold in the plain flour."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Whisk the egg whites with the caster sugar to firm peaks and fold into the almond mixture in two additions. Fold in the melted butter last."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spread thinly and evenly across the tray. Bake 8 to 10 minutes until set and pale gold. Slide onto a rack still on its paper. Once cool, cut into three equal rectangles."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the syrup, buttercream, and ganache"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Coffee syrup: dissolve the sugar in the water over gentle heat, add the espresso powder, stir to dissolve. Cool completely."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Buttercream: beat the butter until very pale, beat in the icing sugar, then beat in the dissolved espresso."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Ganache: heat the cream to just below boiling, pour over the chocolate, leave 1 minute, then stir until smooth. Add the butter and stir until glossy. Cool to a thick, spreadable consistency."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Assemble"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lay the first joconde layer paper-side down on a flat board or tray. Brush generously with coffee syrup. Spread with a thin, even layer of buttercream and smooth with a palette knife. Refrigerate for 15 minutes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place the second joconde layer, soak with syrup, and spread with ganache. Refrigerate for 15 minutes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place the third joconde layer and soak with syrup. Spread the remaining buttercream smoothly over the top. Refrigerate for 30 minutes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Rewarm the remaining ganache to pourable, then pour over the top and tilt the board to level. Refrigerate until set, at least 1 hour."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Trim the edges with a hot knife. Serve in slices cut with a hot knife wiped between each cut."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
