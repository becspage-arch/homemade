                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I scanned for what would take it away.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
