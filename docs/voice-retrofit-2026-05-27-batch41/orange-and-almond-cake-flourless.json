      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Boil the oranges, 1 hour 30 minutes"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put the two {{orange}} whole and unwaxed in a medium saucepan. Cover completely with cold water."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bring to a boil, reduce to a steady simmer, and cook for 1 hour 30 minutes. Add more water as needed to keep them submerged."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The oranges are ready when a skewer passes through the skin with no resistance and the fruit feels completely soft. Remove and leave to cool."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "When cool, cut in half and remove any seeds. Blend the whole orange, skin, flesh, and all the juice, to a completely smooth puree using a stick blender or food processor."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the batter"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat the oven to 175°C fan. Grease and line a 23 cm round tin."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Beat the {{eggs}} and {{caster-sugar}} together until well combined and slightly lighter, about 2 minutes with a hand mixer."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Stir in the orange puree. Fold in the {{almond-flour}}, {{baking-powder}}, and {{sea-salt-fine}}. The batter will be quite runny; this is correct."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Bake, 50 to 55 minutes"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pour the batter into the prepared tin. Bake for 50 to 55 minutes, until the top is deep golden-brown, the edges have pulled away slightly from the tin, and a skewer through the centre comes out clean."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cool in the tin for 30 minutes before turning out. The lack of gluten makes it fragile when hot."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Dust with {{icing-sugar}} before serving."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
