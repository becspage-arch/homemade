                }
              }
            ]
          },
          {
            "type": "ingredientsGroup",
            "attrs": {
              "title": "Filling"
            },
            "content": [
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "cream-cheese",
                  "unit": "g",
                  "prepNote": "full-fat, at room temperature",
                  "quantity": 500,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "double-cream",
