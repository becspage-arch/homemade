                  "unit": "tbsp",
                  "prepNote": "freshly squeezed",
                  "quantity": 1,
                  "isOptional": false
                }
              }
            ]
          },
          {
            "type": "ingredientsGroup",
            "attrs": {
              "title": "Topping"
            },
            "content": [
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "strawberries",
