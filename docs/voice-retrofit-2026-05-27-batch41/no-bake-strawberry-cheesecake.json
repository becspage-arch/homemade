                  "quantity": 400,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "jam",
                  "unit": "tbsp",
                  "prepNote": "strawberry, warmed until liquid",
                  "quantity": 3,
                  "isOptional": false
                }
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the base and chill"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mix the crushed {{digestive-biscuits}} with the melted {{unsalted-butter}} until the crumbs are evenly coated."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Press firmly into the base of a 20 cm springform tin in an even layer. Refrigerate for 30 minutes while you make the filling."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the filling and set, 6 hours or overnight"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Beat the {{cream-cheese}} with the {{icing-sugar}}, {{vanilla-extract}}, and {{lemon-juice}} until smooth."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a separate bowl, whip the cold {{double-cream}} to soft peaks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fold the whipped cream into the cream cheese mixture in two additions until just combined and no streaks remain."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spoon over the chilled biscuit base and smooth the top. Refrigerate for at least 6 hours or overnight."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Top and serve"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Arrange the halved {{strawberries}} over the set filling, cut-side down, starting from the outside edge and working inward."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Brush the warmed {{jam}} over the strawberries to give a glossy finish."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Release the springform tin and serve immediately, or return to the fridge for up to 4 hours."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
