      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Toast the nuts and prepare the tin"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Toast the {{blanched-almonds}} and {{pistachios}} on a baking tray at 180°C fan for 8 minutes until lightly golden. Keep in the oven (turned off) to stay warm."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Line a 20 x 20 cm tin with rice paper or greased baking paper. Measure all ingredients before starting the syrups. Nougat waits for no one."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Whip egg whites and add the honey syrup"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Start whipping the {{egg-whites}} in a stand mixer on high speed. When they reach soft peaks, add the 50 g of {{caster-sugar}} and whip to firm peaks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Simultaneously, heat the {{honey}} in a small saucepan over medium heat to 121°C. Pour the hot honey in a thin stream down the inside of the mixer bowl while it runs on high. The mixture will increase in volume and turn slightly golden."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Add the main sugar syrup"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tip the remaining 300 g of {{caster-sugar}}, {{glucose-syrup}}, and {{water}} into a medium saucepan. Cook to 145°C. Do not stir once it boils."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pour this syrup in a thin stream into the still-beating mixture. Add {{vanilla-extract}}. Beat on high for 5 to 8 minutes until the nougat is very thick, opaque, white, and holds its shape when the mixer stops."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Fold in nuts and set"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove the bowl from the mixer. Add the warm nuts and fold through quickly with a spatula until evenly distributed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Scrape into the prepared tin immediately. Press flat with wet hands or a piece of rice paper placed on top."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Leave to cool at room temperature for at least 4 hours, or overnight. Cut into 24 pieces with a sharp knife dipped in hot water between cuts."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
