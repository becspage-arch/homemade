      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Press the base"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tip the {{rolled-oats}} into a bowl. Add the melted {{unsalted-butter}}, the {{golden-syrup}}, and the {{demerara-sugar}}. Stir until the oats are evenly coated."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Press firmly into the base of a 20 cm springform tin in an even layer. Refrigerate while you make the filling."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Make the filling and chill, at least 4 hours"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Beat the {{cream-cheese}} with the {{icing-sugar}} and {{vanilla-extract}} until smooth."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a separate bowl, beat the {{double-cream}} to stiff peaks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fold the whipped cream into the cream cheese mixture until just combined. This is the "
                  },
                  {
                    "type": "text",
                    "text": "cold-set cheesecake",
                    "marks": [
                      {
                        "type": "glossaryTooltip",
                        "attrs": {
                          "termId": "cmp9yhcmz000030v4d3z6j2g8"
                        }
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " method: the filling holds its shape through fat and aeration, not gelatine."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spoon over the chilled base and smooth the top. Refrigerate for at least 4 hours before serving."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "type": "text",
            "text": "Serve"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Run a palette knife around the inside of the tin before releasing the clip. Slice with a knife dipped in hot water and wiped clean between cuts. Top with seasonal fruit if you like."
          }
        ]
      }
    ]
  },
