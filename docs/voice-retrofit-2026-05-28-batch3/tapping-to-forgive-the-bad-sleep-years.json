            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Side of eye:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I forgive myself for the harsh words.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Under eye:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I thank my system for doing its best with what it knew.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Under nose:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I choose compassion over punishment.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Chin:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " Forgiveness makes room for something new.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Collarbone:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I partner with my body going forward.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Under arm:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " We're on the same side now.",
                    "type": "text"
