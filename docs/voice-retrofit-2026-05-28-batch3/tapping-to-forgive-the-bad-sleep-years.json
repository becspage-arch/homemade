            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Top of head:",
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "text": " I move ahead lighter and freer.",
                    "type": "text"
