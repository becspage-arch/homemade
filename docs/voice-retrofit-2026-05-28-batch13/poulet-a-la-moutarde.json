      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Brown and cook the chicken",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Season the chicken. Melt the butter in a wide sauté pan over medium-high heat. Brown the chicken skin-side down for 5 to 6 minutes until deep gold. Turn and brown the other side for 3 minutes. Transfer to a plate. Reduce the heat to medium. Cook the shallots in the pan for 5 minutes until softened. Add the thyme and white wine and let it bubble and reduce by half, about 3 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Finish with mustard and cream",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Stir the mustard into the cream in a small bowl. Return the chicken to the pan skin-side up. Pour the mustard cream around (not over) the chicken. Reduce to a low simmer, cover, and cook for 20 minutes until the chicken is cooked through. Check the sauce and season. Serve with rice, buttered noodles, or mashed potato.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "Keep the heat low after the cream goes in, double cream is stable but will split if it boils hard",
              "cause": "Heat too high after adding the cream",
              "symptom": "Cream sauce has split"
            },
            {
              "fix": "Reduce to 2 tablespoons for a milder sauce; or add an extra splash of cream to soften it",
              "cause": "Good Dijon is assertive by nature",
              "symptom": "Mustard taste is very sharp"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Poulet à la moutarde is Burgundian in spirit, the same region that produces both Dijon mustard and the Charolais beef that makes boeuf bourguignon. It is a weeknight dish but also a dinner-party dish: quick to make, elegant in result, and immediately recognisable as French in flavour. The sauce reduces around the chicken during the braise and coats each piece with a glossy, mustardy cream.",
            "type": "text"
          }
        ]
      }
    ]
