      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place freeze dried raspberry into blender, blend into fine powder, set aside for later use",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place walnuts, almonds, oats, cocoa powder and salt into blender, pulse until coarsely chopped, place into a mixing bowl",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Place soaked dates and agave syrup into blender, blend until smooth",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put the chopped oat-nut mixture into the blender with the dates-agave paste. Blend to form a dough. Don't worry if it's a little wet. If it's too dry, add a bit more agave."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Remove dough from blender, shape into balls, place into fridge for 1 hour to harden",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "After 1 hour remove balls from fridge then roll brownie balls on raspberry powder, until the ball is entirely covered with raspberry powder",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Serve immediately, or place truffles into air-tight container and store in fridge for up to 1 week.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "fix": "Use a sugar thermometer. Stages: soft-ball 115°C, hard-ball 125°C, soft-crack 135°C, hard-crack 150°C. Cold-water tests work but the thermometer doesn't lie.",
              "cause": "Sugar didn't reach the right stage, or temperature was guessed.",
              "symptom": "Mixture won't set"
            },
            {
              "fix": "Don't stir once the sugar is dissolved. Brush the inside of the pan with a wet pastry brush to wash crystals down.",
              "cause": "Mixture stirred after it started bubbling, or a stray crystal landed on the side of the pan.",
              "symptom": "Sugar crystallised"
            },
            {
              "fix": "Cool to 43°C before beating. The mixture turns from glossy to matte when ready to set.",
              "cause": "Beaten too soon. While still too hot.",
              "symptom": "Fudge is grainy"
            },
            {
              "fix": "Add a teaspoon of warm cream or water and stir until smooth, this is the trick. Drier seizing needs more liquid; thin seizing wants less.",
              "cause": "Water touched melted chocolate.",
              "symptom": "Mixture seized into a ball"
            }
          ],
          "heading": "If something goes wrong"
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Variations",
            "type": "text"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Flavoured version: stir in a teaspoon of vanilla, almond, or peppermint extract once the mixture is off the heat.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Dip-coated: once set, dip pieces in melted dark chocolate and let drip on baking paper.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Make ahead, freezing, leftovers",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A classic American home recipe, generous, comforting, made for a crowd. The proportions are heartier than the British equivalent; the method is built for a Sunday afternoon.",
            "type": "text"
          }
        ]
      }
    ]
