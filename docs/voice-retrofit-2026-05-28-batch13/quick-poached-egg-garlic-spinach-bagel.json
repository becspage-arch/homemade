  "body": {
    "type": "doc",
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Quick Poached Egg & Garlic Spinach Bagel. A British home-cook's dish, the kind of recipe families adjust across generations. Adjustable for what you need.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A weeknight-friendly recipe: most of the work is the prep, and the cooking takes care of itself.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
