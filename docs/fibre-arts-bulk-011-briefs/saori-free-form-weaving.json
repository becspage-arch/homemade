  "glossaryTerms": [
    {
      "slug": "warp",
      "term": "Warp",
      "definition": "The threads strung lengthways on the loom under tension, forming the structure the weft passes through."
    },
    {
      "slug": "weft",
      "term": "Weft",
      "definition": "The threads woven across the warp; in SAORI these can be any fibre, strip, or found material."
    },
    {
      "slug": "selvedge",
      "term": "Selvedge",
      "definition": "The finished edge of a woven cloth where the weft turns at the outermost warp thread."
    },
    {
      "slug": "shed",
      "term": "Shed",
      "definition": "The gap between raised and lowered warp threads through which the weft passes."
    },
    {
      "slug": "shed-stick",
      "term": "Shed stick",
      "definition": "A flat stick threaded through alternate warp ends to hold one half of the shed open."
    }
  ],
  "techniqueSlugs": [],
