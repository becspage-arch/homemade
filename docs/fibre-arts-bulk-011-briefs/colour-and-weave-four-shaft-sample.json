  "glossaryTerms": [
    {
      "slug": "warp",
      "term": "Warp",
      "definition": "The lengthwise threads on the loom, threaded through heddles and reed."
    },
    {
      "slug": "weft",
      "term": "Weft",
      "definition": "The crosswise thread woven in on each pick."
    },
    {
      "slug": "colour-and-weave",
      "term": "Colour and weave",
      "definition": "A weaving effect produced by the interaction of alternating warp colours and alternating weft colours in plain weave, without a complex threading."
    },
    {
      "slug": "log-cabin",
      "term": "Log cabin",
      "definition": "The simplest colour-and-weave structure: two shafts, warp and weft each with two alternating colours, producing a checked or striped optical effect."
    },
    {
      "slug": "ms-and-os",
      "term": "M's and O's",
      "definition": "A four-shaft threading in which blocks of four warp ends alternate between two threading sequences, used here as a colour-and-weave block structure."
    },
    {
      "slug": "threading-draft",
      "term": "Threading draft",
      "definition": "A chart showing which shaft (heddle) each warp end passes through, read right to left in weaving notation."
    },
    {
      "slug": "plain-weave",
      "term": "Plain weave",
      "definition": "The simplest interlacement: each weft goes over one warp end and under the next, alternating on every row."
    },
    {
      "slug": "colour-repeat",
      "term": "Colour repeat",
      "definition": "The sequence of warp colours that repeats across the width; in colour-and-weave the repeat must align with the threading repeat."
    }
  ],
