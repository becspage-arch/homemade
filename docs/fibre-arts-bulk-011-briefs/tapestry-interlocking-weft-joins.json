  ],
  "glossaryTerms": [
    {
      "slug": "weft",
      "term": "Weft",
      "definition": "The horizontal threads woven across the warp."
    },
    {
      "slug": "warp",
      "term": "Warp",
      "definition": "The vertical threads under tension on the loom."
    },
    {
      "slug": "slit-tapestry",
      "term": "Slit tapestry",
      "definition": "A colour-join method where two wefts each turn back at the same warp thread, leaving a deliberate vertical opening."
    },
    {
      "slug": "interlocking",
      "term": "Interlocking",
      "definition": "A join method where two adjacent wefts loop around each other at the colour boundary before turning back."
    },
    {
      "slug": "interlinking",
      "term": "Interlinking",
      "definition": "A join method where each weft passes through the shed of the adjacent weft before turning back."
    },
    {
      "slug": "lazy-line",
      "term": "Lazy line",
      "definition": "A diagonal colour boundary in tapestry achieved by staggering the turning point over several rows rather than keeping it at the same warp thread."
    },
    {
      "slug": "shed",
      "term": "Shed",
      "definition": "The opening between raised and lowered warp threads through which the weft is passed."
    }
  ],
