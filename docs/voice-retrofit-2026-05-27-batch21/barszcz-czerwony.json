      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Simmer the broth",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Put all the vegetables, garlic, bay leaves, and allspice in a large saucepan. Add the stock and bring slowly to a simmer. Cook over low heat for 45 to 60 minutes until the beetroot is completely soft and has given all its colour to the broth. Do not boil hard at any point.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Strain, season, and serve",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Strain the broth through a fine sieve, pressing the vegetables to extract every drop of colour. Discard the solids. Add the red wine vinegar, salt, pepper, and sugar if using. Taste, the broth should be deeply savoury with a clear acidic edge. Reheat gently without boiling. Serve in cups or bowls with a drizzle of soured cream or with uszka alongside.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "Keep at a gentle simmer throughout; once the colour is gone it cannot be recovered, prevent by controlling the heat",
              "cause": "Boiled hard; heat destroys the betacyanin pigment in beetroot",
              "symptom": "Barszcz has turned brown"
            },
            {
              "fix": "Add more vinegar a teaspoon at a time, the sour-sweet balance is everything; also check the salt level",
              "cause": "Not enough acid or salt",
              "symptom": "Broth tastes flat"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Barszcz czerwony is the first course of Wigilia, the Polish Christmas Eve supper, a meatless meal of 12 dishes. The clear barszcz arrives in cups, followed by uszka (tiny dumplings filled with dried mushroom and onion), then pickled herring, carp, and pierogis. Outside the Christmas context, barszcz is daily winter food, poured into a mug from the hob.",
            "type": "text"
          }
        ]
      }
    ]
