      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and line the pastry",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Rub the cold butter into the flour and salt until the mixture resembles breadcrumbs. Add cold water a tablespoon at a time and mix until the dough just comes together. Wrap and refrigerate for 30 minutes. Preheat the oven to 190°C conventional (170°C fan). Roll the pastry to 3 mm and line a 23 cm tart tin or pie dish. Chill for 10 minutes, then blind-bake with baking beans for 12 minutes. Remove beans and bake for 5 more minutes. The base should be pale but dry.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the filling and crumb",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Dissolve the bicarbonate of soda in the hot water. Add the treacle and beaten egg and stir until combined. The mixture will foam slightly. Make the crumb by rubbing the cold butter into the flour, brown sugar, cinnamon, and salt until the mixture forms coarse, irregular crumbs.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Assemble and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Pour the treacle filling into the part-baked shell. Scatter the crumb topping evenly over the surface. It will sink slightly as the filling is liquid. Bake for 30 to 35 minutes until the crumb top is set and the filling is no longer liquid at the edges. The centre will still wobble; it sets fully as it cools. Cool completely before slicing. Serve at room temperature, with or without cream.",
            "type": "text"
          }
        ]
      }
    ]
