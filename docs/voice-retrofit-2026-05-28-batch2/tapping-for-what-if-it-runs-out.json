        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I worry the money will run out, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I fear there won't be enough for what we need, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I feel unsafe when I look at the bank balance, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
        ]
