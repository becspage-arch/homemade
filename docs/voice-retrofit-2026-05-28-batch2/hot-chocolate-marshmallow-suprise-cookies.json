      {
        "type": "infoPanel",
        "attrs": {
          "body": "I’ve included ingredients for various batch sizes. Use whichever you prefer.; (makes 24); (makes 48); (makes 96); ¼ teaspoon (generous pinch); x10; x20; x40.",
          "tone": "info",
