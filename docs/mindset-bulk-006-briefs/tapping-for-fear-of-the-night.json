          },
          {
            "type": "listItem",
            "content": [{ "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "bold" }], "text": "Chin:" }, { "type": "text", "text": " I welcome the safety of dusk and dim light." }] }]
          },
