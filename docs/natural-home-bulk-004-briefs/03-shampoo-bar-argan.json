  "glossaryTerms": [
    {
      "slug": "superfat",
      "term": "Superfat",
      "definition": "The percentage of oils left unsaponified in a soap formula. Shampoo bars use 0% superfat to prevent excess oil coating the hair shaft and leaving a waxy feel."
    },
    {
      "slug": "lauric-acid",
      "term": "Lauric acid",
      "definition": "A saturated fatty acid abundant in coconut and palm kernel oil. It produces a generous, bubbly lather in soap and shampoo bars, making it essential in high-cleansing formulas."
    },
    {
      "slug": "acv-rinse",
      "term": "Apple cider vinegar rinse",
      "definition": "A dilute rinse of apple cider vinegar in water used after a shampoo bar to restore the hair's natural slightly acidic pH, which soap making shifts alkaline. Closes the cuticle and reduces frizz."
    },
    {
      "slug": "trace",
      "term": "Trace",
      "definition": "The emulsification point in cold-process soap making when the batter holds a visible drizzle on its surface."
    },
    {
      "slug": "saponification",
      "term": "Saponification",
      "definition": "The reaction between oils and an alkali that produces soap and glycerol."
    }
  ],
