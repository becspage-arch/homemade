  "glossaryTerms": [
    {
      "slug": "lard-sap-value",
      "term": "SAP value",
      "definition": "The saponification value of a fat or oil: the number of grams of sodium hydroxide (NaOH) needed to fully saponify 1 gram of that fat. Lard has a SAP value of approximately 0.138."
    },
    {
      "slug": "superfat",
      "term": "Superfat",
      "definition": "The percentage of oils left unsaponified in a soap formula, providing a conditioning margin."
    },
    {
      "slug": "trace",
      "term": "Trace",
      "definition": "The emulsification point when the soap batter holds a visible trail drizzled on its surface."
    },
    {
      "slug": "gel-phase",
      "term": "Gel phase",
      "definition": "A translucent, jelly-like phase that soap passes through during the first 24 hours in the mould as heat from saponification builds. Lard soaps gel easily and the result is a slightly glossier bar."
    },
    {
      "slug": "cure",
      "term": "Cure",
      "definition": "The 4 to 8 week drying and finishing period after unmoulding cold-process soap."
    }
  ],
