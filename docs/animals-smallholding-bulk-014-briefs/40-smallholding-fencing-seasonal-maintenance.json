{
  "slug": "smallholding-fencing-seasonal-maintenance",
  "title": "Seasonal fencing maintenance on a smallholding",
  "subtitle": "A calendar for checking and repairing fencing before it fails.",
  "excerpt": "A fence that has been standing through a winter will have taken some damage: frost-lifted posts, wire loosened by debris, gates that no longer close squarely. Three maintenance walks per year, late winter, summer, and autumn, catch problems before an escape or an injury, and are less expensive than emergency repairs.",
  "type": "TECHNIQUE",
  "categorySlug": "animals-smallholding",
  "subCategorySlug": "smallholding-skills",
  "difficulty": "BEGINNER",
  "season": "YEAR_ROUND",
  "timeMinutes": 120,
  "sourceType": "SYNTHESISED",
  "sourceNotes": "AHDB fencing guidance for livestock, ahdb.org.uk. Emery, C., Encyclopedia of Country Living (updated edition). Institute of Auctioneers and Appraisers in Scotland (IAAS) fencing standards.",
  "glossaryTerms": [
    {
      "slug": "stock-proof",
      "term": "Stock-proof",
      "definition": "A fence that prevents the specific livestock species it is intended to contain. What is stock-proof for cattle is not necessarily stock-proof for sheep or goats."
    },
    {
      "slug": "fence-staple",
      "term": "Fence staple",
      "definition": "A U-shaped metal nail used to fix wire to timber fence posts. Staples work loose over time and should be checked and re-driven as part of annual fence maintenance."
    }
  ],
