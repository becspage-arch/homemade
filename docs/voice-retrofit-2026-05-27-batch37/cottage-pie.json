      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Cook the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the {{vegetable-oil}} in a large pan over medium heat. Cook the {{onion}}, {{carrot}}, and {{celery}} for 10 minutes until softened. Increase to high heat, add the {{beef-mince}}, and cook without stirring for 3 minutes, then break it up and continue cooking until browned all over. Add the {{tomato-puree}} and {{thyme}}. Stir for 2 minutes. Add the {{worcestershire-sauce}} and {{stock-beef}}. Season with {{sea-salt-fine}} and {{black-pepper}}. Simmer uncovered for 20 minutes until the sauce is thick. Transfer to a baking dish.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the mash and bake",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 190°C. Boil the {{potato}} in salted water until completely tender. Drain and steam-dry. Mash with {{unsalted-butter}} and warm {{whole-milk}} until smooth. Season well. Spread over the filling, rough up the surface with a fork, and bake for 25 to 30 minutes until golden on top and bubbling at the edges.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "items": [
            {
              "fix": "High heat and patience before stirring. The mince should form a brown crust before you break it up",
              "cause": "Mince not properly browned, or cooked at too low a temperature",
              "symptom": "Grey, flat-tasting filling"
            },
            {
              "fix": "Use low-sodium stock or homemade. Season at the end rather than the beginning, as the sauce concentrates during the simmer",
              "cause": "Stock too salty before adding worcestershire sauce",
              "symptom": "Filling too salty after reducing"
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cottage pie is eaten on weeknights across Britain, more so than shepherd's pie because beef mince is more commonly bought than lamb mince. It reheats well, improves over two days, and feeds a family economically. The mash topping ensures it does not need any accompaniment beyond peas or a simple green vegetable.",
            "type": "text"
          }
        ]
      }
    ]
