        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make the base",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Preheat the oven to 150°C conventional. Crush the digestive biscuits to fine crumbs. Stir together with the melted butter and sugar until the crumbs hold when pressed. Press firmly and evenly into the base and sides of a 20 cm tart tin. Bake for 10 minutes until set and lightly coloured. Leave to cool.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Make and bake the filling",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Whisk together the condensed milk, egg yolks, lime juice, and lime zest until smooth and slightly thickened. Pour into the cooled base. Bake for 15 minutes until just set with a slight wobble in the centre. Remove and leave to cool to room temperature, then refrigerate for at least 2 hours before serving. Serve with whipped double cream.",
            "type": "text"
          }
        ]
      }
    ]
