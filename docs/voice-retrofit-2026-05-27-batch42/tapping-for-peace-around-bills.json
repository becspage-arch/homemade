            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I feel stressed every time a bill arrives, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
