          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I see bills as proof of struggle, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I brace for bad news when I open them, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
