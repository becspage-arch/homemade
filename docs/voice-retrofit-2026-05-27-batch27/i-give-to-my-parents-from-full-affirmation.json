        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "The affirmation",
            "type": "text"
          }
        ]
      },
      {
        "type": "pullQuote",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "text": "I give to my parents from full, not from depletion. My care is chosen, not coerced.",
                "type": "text"
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "How to use it",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Say it three times in the morning, hand on heart. Say it again when obligation pulls harder than love. When you're giving because the alternative feels worse rather than because you want to. The affirmation is a redirect toward the chosen version of care.",
            "type": "text"
          }
        ]
