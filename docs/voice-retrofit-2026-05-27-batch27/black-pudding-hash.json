        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Fry the base",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat ",
            "type": "text"
          },
          {
            "text": "{{unsalted-butter}} of butter",
            "type": "text"
          },
          {
            "text": " and ",
            "type": "text"
          },
          {
            "text": "{{olive-oil}} of olive oil",
            "type": "text"
          },
          {
            "text": " together in a wide frying pan over medium-high heat. Add the onion and cook for 5 minutes until golden. Add the diced apple if using and cook for 2 minutes. Add the crushed potato and press it flat with a spatula. Season with ",
            "type": "text"
          },
          {
            "text": "{{sea-salt-flakes}}",
            "type": "text"
          },
          {
            "text": " and ",
            "type": "text"
          },
          {
            "text": "{{black-pepper}}",
            "type": "text"
          },
          {
            "text": ". Cook without disturbing for 5 minutes until the base is crisp and golden.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Add the black pudding and serve",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Scatter the ",
            "type": "text"
          },
          {
            "text": "{{black-pudding}} of black pudding",
            "type": "text"
          },
          {
            "text": " chunks over the potato and press them in lightly. Turn the hash in sections, breaking it up, and cook for another 5 minutes until the black pudding is crisp and hot through. Divide between two warm plates. In the same pan, fry the eggs to your liking and place on top.",
            "type": "text"
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "rows": [
            {
              "fix": "Use a combination of butter and oil. The oil raises the smoke point of the butter and prevents burning.",
              "cause": "Pan not hot enough when the potato went in, or too little fat",
              "symptom": "Hash is sticking to the pan and burning"
            },
            {
              "fix": "Leave the black pudding chunks alone for 3 minutes before touching; this allows a crust to form.",
              "cause": "Too much moisture in the pudding, or it was pressed too hard",
              "symptom": "Black pudding falls apart rather than crisping"
            },
            {
              "fix": "Boil potatoes until just tender, not falling apart. Cold, firm potato makes the best hash.",
              "cause": "Overboiled potatoes, or not enough cold time in the fridge",
              "symptom": "Potato is falling apart before the hash is cooked"
            },
            {
              "fix": "Salt the boiling water generously. Add more seasoning during frying and taste before serving.",
              "cause": "Insufficient seasoning, or potato was unsalted when boiled",
              "symptom": "Hash tastes bland"
            }
          ]
        },
        "content": []
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Where this dish lives",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Black pudding hash is a northern English and Scottish brunch staple. It sits alongside scrambled eggs and smoked salmon at the upper end of the breakfast table and beside baked beans and toast at the everyday end. The apple is optional but traditional in the northwest, where apple and black pudding are a long-established pairing.",
            "type": "text"
          }
        ]
      }
