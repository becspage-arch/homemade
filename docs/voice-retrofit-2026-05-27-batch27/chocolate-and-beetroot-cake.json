      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Mix and bake, 35 to 40 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 170°C fan. Grease and line a 20 cm round cake tin. Whisk the {{vegetable-oil}}, {{eggs}}, and {{vanilla-extract}} together. Stir in the {{dark-brown-sugar}}. Fold in the {{plain-flour}}, {{cocoa-powder}}, {{baking-powder}}, {{bicarbonate-of-soda}}, and {{fine-sea-salt}}. Fold in the grated {{beetroot}} until evenly distributed. Spoon into the tin and bake for 35 to 40 minutes until a skewer inserted in the centre comes out clean. The cake will be very dark. Cool in the tin for 15 minutes, then turn out onto a rack to cool completely.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Ganache and finish",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Place the {{dark-chocolate}} in a heatproof bowl. Bring the {{double-cream}} to the boil in a small saucepan and pour over the chocolate. Leave for 2 minutes, then stir from the centre outward until smooth and glossy. Leave at room temperature for 15 minutes until the ganache thickens to a pourable coating consistency. Place the cooled cake on a rack set over a tray. Pour the ganache over the top and let it flow down the sides naturally. Leave for 30 minutes to set before cutting.",
            "type": "text"
          }
        ]
      }
    ]
