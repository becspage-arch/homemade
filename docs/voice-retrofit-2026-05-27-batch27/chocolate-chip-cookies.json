                  "quantity": 280,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "bicarbonate-of-soda",
                  "unit": "tsp",
                  "prepNote": null,
                  "quantity": 1,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "fine-sea-salt",
                  "unit": "tsp",
                  "prepNote": null,
                  "quantity": 1,
                  "isOptional": false
                }
              },
              {
                "type": "ingredient",
                "attrs": {
                  "slug": "dark-chocolate-chips",
                  "unit": "g",
                  "prepNote": null,
                  "quantity": 300,
                  "isOptional": false
                }
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "text": "Method",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Brown the butter",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Melt the {{unsalted-butter}} in a small saucepan over medium heat. Keep cooking, swirling occasionally, until the foam subsides and the milk solids at the bottom of the pan turn a golden hazelnut brown, about 5 to 7 minutes. The smell should shift from plain butter to something nutty and slightly caramelised. Pour into a large bowl immediately; leave the darkest solids in the pan. Leave to cool for 15 minutes.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Mix the dough",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Whisk the {{dark-brown-sugar}} and {{caster-sugar}} into the cooled browned butter until smooth. Add the egg, extra yolk, and {{vanilla-extract}} and beat for 1 minute until the mixture lightens slightly. Stir in the {{plain-flour}}, {{bicarbonate-of-soda}}, and {{fine-sea-salt}} until a dough forms. Fold in the {{dark-chocolate-chips}}.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Chill, at least 1 hour",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Cover the bowl and refrigerate for at least 1 hour, and up to 3 days. The rest allows the flour to hydrate fully and gives the sugar time to draw moisture from the dough, producing a cookie that spreads less and tastes more complex.",
            "type": "text"
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
        "content": [
          {
            "text": "Bake, 11 to 12 minutes",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Heat the oven to 190°C fan. Line the baking tray with baking paper. Scoop the dough into balls roughly 45 g each, about the size of a golf ball. Space them 5 cm apart. Bake one tray at a time for 11 to 12 minutes. The cookies are done when the edges are set and golden-brown and the centres still look underdone and slightly shiny. They firm up as they cool.",
            "type": "text"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "text": "Leave on the tray for 5 minutes before moving to a rack. They need to set before you handle them.",
            "type": "text"
          }
        ]
      }
    ]
  },
