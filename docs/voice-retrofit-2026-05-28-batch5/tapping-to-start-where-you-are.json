                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "Even though I'm scared things won't improve, I deeply and completely accept myself.",
                    "type": "text"
                  }
                ]
              }
            ]
          }
