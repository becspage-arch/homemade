    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "text": "A ",
            "type": "text"
          },
          {
            "text": "baked custard",
            "type": "text",
            "marks": [
              {
                "type": "glossaryTooltip",
                "attrs": {
                  "termId": "cmpa6fa9h00008gv4rs8narfp"
                }
              }
            ]
          },
          {
            "text": " tart is done before it looks done. Pull it when the edges are set and the centre still trembles. The residual heat finishes it as it cools. A fully set, non-trembling custard when it comes from the oven means it has curdled slightly inside and will be watery when cut.",
            "type": "text"
          }
        ]
