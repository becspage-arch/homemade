          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Even though I'm the first to imagine millions, I deeply and completely accept myself."}]}]
          },
          {
            "type": "listItem",
            "content": [{"type": "paragraph", "content": [{"type": "text", "text": "Even though change this big feels strange, I deeply and completely accept myself."}]}]
          }
        ]
      },
      {
