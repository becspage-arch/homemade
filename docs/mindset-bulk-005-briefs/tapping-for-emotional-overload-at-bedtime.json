{
  "slug": "tapping-for-emotional-overload-at-bedtime",
  "title": "Tapping for Emotional Overload at Bedtime",
  "subtitle": "A tapping practice for emptying the emotional bucket before sleep",
  "excerpt": "A five-minute tapping practice from Day 6 of SLEEP: A 30-Day Tapping Intensive. Two scripts: the first clears absorbed energy from other people during the day; the second releases the day's emotional residue so it doesn't carry into the night.",
  "type": "PRACTICE",
  "categorySlug": "mindset",
  "subCategorySlug": "tapping",
  "difficulty": "BEGINNER",
  "sourceType": "CREATOR",
  "sourceNotes": "Adapted from Day 6 of SLEEP: A 30-Day Tapping Intensive to Fall Asleep Faster and Wake Energised (Rebecca J Page, 2025, ISBN 9798269649795). The tapping framework is Gary Craig's Emotional Freedom Technique (EFT), in use since the mid-1990s.",
  "practice": {
    "practiceType": "TAPPING",
    "practiceTargets": ["SLEEP", "ANXIETY", "ENERGY"],
    "timeBand": "FIVE_MIN",
    "bestTime": "EVENING",
    "practiceDepth": "BEGINNER",
    "whenToUse": "When you arrive at bedtime carrying the emotional weight of the day — other people's stress, small disappointments, unprocessed feelings that haven't had space to move through.",
