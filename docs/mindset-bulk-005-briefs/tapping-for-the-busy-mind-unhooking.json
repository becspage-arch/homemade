{
  "slug": "tapping-for-the-busy-mind-unhooking",
  "title": "Tapping for the Busy Mind Unhooking",
  "subtitle": "A tapping practice for releasing the need to keep going when the day is done",
  "excerpt": "A five-minute tapping practice from Day 7 of SLEEP: A 30-Day Tapping Intensive. Two scripts: the first works with the discomfort of slowing down during the day; the second switches off the mental momentum at bedtime.",
  "type": "PRACTICE",
  "categorySlug": "mindset",
  "subCategorySlug": "tapping",
  "difficulty": "BEGINNER",
  "sourceType": "CREATOR",
