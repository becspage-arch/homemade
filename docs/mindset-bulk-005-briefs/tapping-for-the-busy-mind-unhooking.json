  "practice": {
    "practiceType": "TAPPING",
    "practiceTargets": ["SLEEP", "ANXIETY", "BODY"],
    "timeBand": "FIVE_MIN",
    "bestTime": "EVENING",
    "practiceDepth": "BEGINNER",
    "whenToUse": "When the mind is still in work mode at bedtime — mentally ticking off tasks, replaying what you should have finished, struggling to turn the day off.",
    "whenNotToUse": null,
