      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In an electric mixer get the egg whites to soft peaks stage. Add one T/s at a time of the icing sugar, beating well between each addition. Continue to add the icing sugar until it is all incorporated. Add the lemon juice and turn off the mixer."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place the icing sugar in a piping bag with a fluted nozzle."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Assembly:"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "This is the fun part. Using the largest star as a base, pipe the royal icing onto the centre of the biscuit and add a smaller star to the stack."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "The royal icing acts like cement for the Christmas tree so put a lot on and keep the icing central and even so the tree stays straight."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Dust with icing sugar for a snowy effect"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
