              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat oven to 200C/fan 180C/gas 6."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Boil the potatoes for 5 mins."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Drain and tip into a bowl - they will be slightly underdone."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Toss with the tarragon, lemon zest, butter and seasoning to taste. Pile in the centre of a foil-lined baking tray."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Season salmon with black pepper and wrap the pancetta or prosciutto around the fillets."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place on top of the potatoes and roast for 15-20 mins, or until the fish flakes easily and the pancetta or prosciutto is golden."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Serve with steamed green beans."
                  }
                ]
              }
            ]
          }
        ]
      }
