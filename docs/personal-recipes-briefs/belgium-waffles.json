        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Sits well in the fridge overnight; see the method for the chilling step."
          }
        ]
