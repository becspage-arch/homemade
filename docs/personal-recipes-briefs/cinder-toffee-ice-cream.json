          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "lightly oil a non-stick baking sheet"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "To make the cinder toffee, heat the sugar and syrup gently in a large deep saucepan until the sugar melts and turns into a syrup, and then boil the mixture until it turns a deep, golden caramel"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Whisk in the bicarbonate of soda (this will make it foam up) then quickly pour it onto the oiled baking sheet and cool. Break into bite-sized pieces."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put the condensed milk, cream and vanilla into a large bowl. Beat with an electric whisk until softly whipped."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Fold in the pieces of cinder toffee."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Tip into a freezer container, cover and freeze."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
