      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put the walnut oil, olive oil, mustard powder, white wine vinegar and salt and pepper to a small jar and shake until well combined"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lightly toast the walnuts in a large dry pan until lightly coloured and set aside"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Peel and core the pears then cut length-ways into quarters"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put one tablespoon of olive oil into the large pan over medium heat. Add the pears, cut side down"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Sauté the pears until slightly caramelised but still firm. Remove the pears from the pan and keep warm"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Finely slice the spinach and arrange with the rocket on a large serving plate. Place the warm pears and walnuts over the top and drizzle the dressing over the top."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "If something goes wrong",
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "symptom": "Dressing pools at the bottom of the bowl",
              "cause": "Dressing not emulsified, or salad too wet.",
              "fix": "Spin leaves dry first. Whisk dressing ingredients until thick and pourable. Dress at the table, not in the kitchen, so it stays evenly coated."
            },
            {
              "symptom": "Leaves wilted by the time it reached the table",
              "cause": "Dressed too early, or fruit/cheese added warm.",
              "fix": "Combine everything cold and dress just before serving. Sturdy leaves (kale, chicory, romaine) cope with sitting; spinach and rocket don't."
            },
            {
              "symptom": "Salad tastes too oily",
              "cause": "Wrong oil-to-acid ratio in the dressing.",
              "fix": "Three parts oil to one part acid is the classic ratio. Adjust with a squeeze of lemon if it's flat, or a splash more oil if it's sharp."
            },
            {
              "symptom": "Toppings ended up in the bottom",
              "cause": "Heavy ingredients added before tossing.",
              "fix": "Toss the leaves with dressing first, then scatter cheese, nuts, croutons on top. Don't toss again after garnishing."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add-protein: top with grilled chicken, halloumi, or a soft-boiled egg for a main-course salad."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Crunch upgrade: scatter toasted nuts or seeds on top — pumpkin, almond, sunflower."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid."
          }
        ]
      },
