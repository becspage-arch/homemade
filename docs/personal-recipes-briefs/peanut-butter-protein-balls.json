                "content": [
                  {
                    "type": "text",
                    "text": "Add the no stir creamy peanut butter, honey, rolled oats, vanilla protein powder, salt, and mini dark chocolate chips to a mixing bowl and use a rubber spatula to mix until the batter is combined"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Use a mini cookie scoop or a spoon to drop energy balls with a spoon onto a wax paper covered cookie sheet. They should be around 1 inch in size."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Roll the energy balls with your hands to form the shape"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place cookie sheet with the energy bites on it in the fridge for 1 hour, or until the balls are hardened"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Transfer energy balls to a ziploc bag and store in the freezer"
                  }
                ]
              }
            ]
          }
        ]
