          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put the walnut oil, olive oil, mustard powder, white wine vinegar and salt and pepper to a small jar and shake until well combined"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Lightly toast the walnuts in a large dry pan until lightly coloured and set aside"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Peel and core the pears then cut length-ways into quarters"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put one tablespoon of olive oil into the large pan over medium heat. Add the pears, cut side down"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Sauté the pears until slightly caramelised but still firm. Remove the pears from the pan and keep warm"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Finely slice the spinach and arrange with the rocket on a large serving plate. Place the warm pears and walnuts over the top and drizzle the dressing over the top."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
