            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Boil linguine in salted water until al dente. Reserve ¼ cup of pasta water, then drain."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Season chicken with garlic powder, onion powder, paprika, cayenne, salt, and pepper. Cook in olive oil until golden and fully cooked. Set aside."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Melt butter in the same skillet, add garlic, chicken broth, heavy cream, Dijon mustard, and red pepper flakes. Let it simmer and thicken."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add chicken and pasta to the sauce, tossing to coat. Stir in Parmesan, parsley, and lemon juice. Adjust consistency with reserved pasta water if needed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Garnish with additional parsley and Parmesan. Serve warm."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
