                "content": [
                  {
                    "type": "text",
                    "text": "Add-protein: top with grilled chicken, halloumi, or a soft-boiled egg for a main-course salad."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Crunch upgrade: scatter toasted nuts or seeds on top — pumpkin, almond, sunflower."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid."
          }
        ]
      },
