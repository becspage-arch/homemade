        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Pat salmon dry, then season with salt, pepper, paprika and blackening seasoning (if using). Set aside."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Adjust oven rack to middle position, then preheat broiler/grill."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add butter and oil to a large, oven-safe skillet over MED-HIGH heat."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Once butter is melted, add garlic, water, soy sauce, sriracha, honey and lemon juice and cook for 30 seconds or so, until the sauce is heated through."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add salmon, skin side down (if using salmon with skin), and cook for 3 minutes. While salmon cooks, baste frequently with sauce from the pan by spooning it over the top of the salmon."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Broil/grill salmon for 5-6 minutes, basting with sauce once during the broil, until salmon is caramelised and cooked to desired doneness."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Garnish with minced parsley if desired."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
