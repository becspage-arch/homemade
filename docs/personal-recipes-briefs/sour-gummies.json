        },
        "content": [
          {
            "type": "text",
            "text": "Also"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "1 cup (200g/7oz) frozen fruit, defrosted (strawberries, blueberry, raspberry etc)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "4 teaspoons unflavored gelatin*"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "1-3 tsp citric acid"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Puree the fruit in a food processor until smooth."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Combine all ingredients except gelatin, sugar (for coating) and citric acid in a small saucepan over medium-low heat. Stir with a whisk."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "When it comes to a simmer, gradually sprinkle and whisk the gelatin into the mixture, stirring constantly. (Avoid dumping gelatin into pan all at once, which will cause big globs of gelatin to remain in finished product.)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Continue heating over medium-low heat until it comes to a simmer and all ingredients are well combined and gelatin is completely melted. (The mixture will change from a grainy, jelly-like consistency to a more glassy, smooth consistency when gelatin is all melted.)"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Take it off the heat and pass it through a sieve to remove any gelatin of fruit bits. If there are bubbles on top, remove with a spoon."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place gummy bear mold on a cookie sheet (which makes it easier to move without spilling once filled). Pour mixture into silicone mold and place in the fridge for a minimum of 6 hours. Any air bubbles that appear just pop with a toothpick."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Carefully pop gummy bears out of mold and store in an airtight container in the fridge. They will keep in the refrigerator for a few weeks."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mix together the sugar and citric acid and then toss in the gummies until well coated. Store in a container on the counter top. Do not place in the fridge as they will get slimy."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
