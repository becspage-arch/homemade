    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Garlic Parmesan Pasta. A British home-cook's dish — the kind of recipe families adjust across generations. Adjustable for what you need."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Pasta in a pan, sauce in another. The trick is the meeting — the noodles finish in the sauce, holding the starchy water that binds the two."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "What you need"
          }
        ]
      },
      {
        "type": "ingredientsList",
        "attrs": {
          "defaultServings": 4,
          "items": [
            {
              "ingredientSlug": "parmesan",
              "amount": 0.5,
              "unit": "cup",
              "prepNote": "or vegan alternative",
              "isOptional": false,
              "groupLabel": null
            },
            {
              "ingredientSlug": "salted-butter",
              "amount": 3,
              "unit": "tbsp",
              "prepNote": "or vegan butter",
              "isOptional": false,
              "groupLabel": null
            },
            {
              "ingredientSlug": "garlic",
              "amount": 4,
              "unit": "clove",
              "prepNote": null,
              "isOptional": false,
              "groupLabel": null
            },
            {
              "ingredientSlug": "stock-chicken",
              "amount": 2,
              "unit": "cup",
              "prepNote": null,
              "isOptional": false,
              "groupLabel": null
            },
            {
              "ingredientSlug": "whole-milk",
              "amount": 1,
              "unit": "cup",
