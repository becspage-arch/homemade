        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cut sourdough bread into four 1/2-inch slices."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Top two slices of sourdough with sliced camembert cheese. Next, sprinkle the thyme, lemon zest, and ground pepper over the camembert slices."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cut the apple into thin slices and arrange them over the camembert."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "On the other two slices of sourdough, add the slices of cheddar cheese. Carefully close the sandwich, placing the apple sides over the cheddar sides, and press together with your hands."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat a large non-stick skillet over medium heat and spray with avocado oil spray (or other cooking oil, as desired)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place the CHEDDAR side of the sandwiches onto the skillet. Cook for several minutes, pressing down with spatula occasionally, until cheese begins to melt and the underside of the bread is golden brown."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spray the top sides of the sandwiches, and carefully flip with a spatula. Cook on this side for another few minutes until the underside is golden brown."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Feel free to flip sandwiches a couple more times to ensure even cooking. Once the cheese has melted, remove from the pan and place onto a cutting board."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Carefully slice the sandwiches in half with a serrated knife, and serve immediately!"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
