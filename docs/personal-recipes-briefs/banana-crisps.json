                "content": [
                  {
                    "type": "text",
                    "text": "Non-stick cooking spray or parchment paper"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to 225°F and line a baking sheet with parchment paper or lightly spray with non-stick spray. Peel the bananas and slice them as thinly and evenly as possible, about 1/8-inch thick, for uniform crispness."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place the banana slices in a bowl and gently toss with lemon juice to prevent browning. Arrange the slices in a single layer on the prepared baking sheet, making sure they don’t overlap."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a small bowl, mix together the sugar and cinnamon. Lightly sprinkle the cinnamon sugar over the banana slices."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake the chips for 2 to 3 hours, flipping halfway through, until they are dry and crispy. Keep a close eye on them during the final 30 minutes to avoid burning."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove from the oven and let them cool completely. They will continue to crisp up as they cool."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Notes - The key to crispy chips is slicing the bananas thinly and baking at a low temperature for a long time. Use firm bananas to make slicing easier and to prevent sogginess. Store the chips in an airtight container at room temperature to maintain their crunch. You can adjust the cinnamon sugar ratio to your taste or leave them plain for a less sweet version."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
