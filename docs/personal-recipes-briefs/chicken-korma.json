      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to  425 F (220 C / 200 Fan / Gas 7)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Prepare the spice mix by mixing the following in a large bowl: garlic, ginger, ground almonds, tomato puree, ground cumin, garam masala, ground coriander, turmeric, paprika, ground cardamom, ground cinnamon, white sugar and salt. Put aside."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put chicken breast on an oven tray and bake in the oven for 10-12 minutes. It should be nearly cooked through but not quite."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Meanwhile, fry the onion in a pan for 5 minutes with the oil, stirring often until softened."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove chicken from the oven and put onto a clean plate. Use two forks to shred."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add shredded chicken to the frying pan with the onion. Fry for approx 5 minutes until the chicken is cooked through and slightly browning."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the spice mix to the frying pan and stir to coat."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the yoghurt, ground almonds, coconut cream and sugar."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Stir everything together and bring to a gentle oil."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Simmer gently for 5-10 minutes to deepen the flavors. Add a little water to thin if it gets too thick. Taste to check seasoning and add salt & pepper as needed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Serve with rice as desired."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
