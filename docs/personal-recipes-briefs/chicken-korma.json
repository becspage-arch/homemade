      {
        "type": "infoPanel",
        "attrs": {
          "tone": "info",
          "title": "Also",
          "body": "Serves 2; Serves 4; ½ large; 1 large."
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to  425 F (220 C / 200 Fan / Gas 7)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Prepare the spice mix by mixing the following in a large bowl: garlic, ginger, ground almonds, tomato puree, ground cumin, garam masala, ground coriander, turmeric, paprika, ground cardamom, ground cinnamon, white sugar and salt. Put aside."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put chicken breast on an oven tray and bake in the oven for 10-12 minutes. It should be nearly cooked through but not quite."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Meanwhile, fry the onion in a pan for 5 minutes with the oil, stirring often until softened."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove chicken from the oven and put onto a clean plate. Use two forks to shred."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add shredded chicken to the frying pan with the onion. Fry for approx 5 minutes until the chicken is cooked through and slightly browning."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the spice mix to the frying pan and stir to coat."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add the yoghurt, ground almonds, coconut cream and sugar."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Stir everything together and bring to a gentle oil."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Simmer gently for 5-10 minutes to deepen the flavors. Add a little water to thin if it gets too thick. Taste to check seasoning and add salt & pepper as needed."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Serve with rice as desired."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "If something goes wrong",
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "symptom": "Curry tastes raw or harsh",
              "cause": "Spices weren't bloomed in oil long enough before the wet ingredients went in.",
              "fix": "Fry whole spices first, then ground spices for a minute in hot oil before adding onions or liquid. The aroma changes when it's ready."
            },
            {
              "symptom": "Sauce is split or oily",
              "cause": "Cooked too hard after adding dairy, or yoghurt added straight from the fridge.",
              "fix": "Bring yoghurt to room temperature first and stir it in off the heat. Don't boil curries with yoghurt or cream — simmer only."
            },
            {
              "symptom": "Meat is tough",
              "cause": "Cut too lean, or cooked at a rolling boil.",
              "fix": "Use cuts with connective tissue (thigh, shoulder, shin). Keep the curry at a gentle simmer for the long-cook cuts — bubbles barely breaking the surface."
            },
            {
              "symptom": "Heat is uneven — fiery in places, mild elsewhere",
              "cause": "Chilli added late and not stirred through.",
              "fix": "Add chillies early with the aromatics so the heat distributes. Taste before serving and adjust with chilli flakes if needed."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Vegetarian: swap meat for paneer cubes or chickpeas. Add at the simmer stage so they take on the sauce."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Coconut version: replace half the stock with coconut milk for a milder, richer curry."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Make a day ahead; the flavour deepens overnight in the fridge."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "The dish belongs to the layered tradition of Indian home cooking — spices bloomed in fat, aromatics built up, the long simmer that pulls everything together. Every household tunes the heat and the sweetness; this is one version."
          }
        ]
      }
    ]
  }
