              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "1.5 litres water1 orange, studded with 10 cloves2 oranges and 2 lemons, sliced"
