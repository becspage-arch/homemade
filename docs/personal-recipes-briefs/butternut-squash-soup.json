      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Preheat the oven to 400 degrees F. Lightly oil a baking sheet or coat with nonstick spray."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place butternut squash, onion, bell pepper and bacon in a single layer onto the prepared baking sheet. Add olive oil and garlic; season with salt and pepper, to taste. Gently toss to combine."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place into the oven and bake for 25-30 minutes, or until butternut squash is tender, stirring at halftime.*"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat a large skillet over medium high heat. Add bacon and cook until brown and crispy, about 6-8 minutes. Transfer to a paper towel-lined plate."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Heat a large stockpot or Dutch oven over medium heat. Add butternut squash mixture and thyme, and cook, stirring occasionally, until fragrant, about 1-2 minutes; season with salt and pepper, to taste. Stir in chicken stock and puree with an immersion blender."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bring to a boil; reduce heat and simmer until slightly thickened, about 5-10 minutes. If the soup is too thick, add more chicken stock as needed until desired consistency is reached."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Serve immediately, garnished with bacon, goat cheese and chives, if desired."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "If something goes wrong",
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "symptom": "The soup tastes flat",
              "cause": "Underseasoned, or the aromatics weren't sweated long enough.",
              "fix": "Add salt a pinch at a time, tasting. If still flat, finish with a squeeze of lemon or a splash of vinegar to lift it."
            },
            {
              "symptom": "Cream-based soup splits",
              "cause": "Dairy added at too high a heat, or left to simmer after.",
              "fix": "Stir cream in off the heat, or use crème fraîche, which doesn't split. Don't reboil after adding."
            },
            {
              "symptom": "Blended soup is too thick",
              "cause": "Reduced too far, or the starch in the veg sets up on cooling.",
              "fix": "Loosen with hot stock or water, a ladle at a time, until it pours from the spoon in a ribbon."
            },
            {
              "symptom": "Blended soup is too thin",
              "cause": "Stock-to-veg ratio too high.",
              "fix": "Simmer uncovered to reduce, or blitz in another roasted veg (potato, parsnip) to thicken."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Vegan version: swap dairy cream for cashew cream (soak 100 g cashews in hot water, blend smooth) or oat cream."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Smokier finish: stir in a teaspoon of smoked paprika at the end, or top with crispy chorizo."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Make a day ahead; the flavour deepens overnight in the fridge."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A British home cook's dish. It sits among the recipes families remember without thinking about — the kind that gets adjusted across generations and never quite the same twice."
          }
        ]
      }
    ]
