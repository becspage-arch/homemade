      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cream all ingredients for filling.  Set aside."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Combine flour, sugar, baking powder and salt in food processor bowl.  Cut in butter until crumbly (or cut in by hand or prepare with a pastry blender)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Whisk egg and milk together.  Add all at once to the dry ingredients and whirl briefly to combine."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Turn dough out onto a floured surface and roll or pat into a 9 or 10 inch square.  Spread filling over, and roll up like a jelly roll.  Cut into 12 slices."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Arrange rolls in a greased 9 inch square baking pan.  Bake at 400 degrees F for 20 to 25 minutes.  Remove from pan."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Icing – Combine icing sugar with enough milk or cream to make a thin glaze.  Drizzle over the rolls."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "If something goes wrong",
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "symptom": "Bread is dense and didn't rise",
              "cause": "Yeast was stale, or the dough was too cold.",
              "fix": "Check yeast in warm water with a pinch of sugar — it should froth in five minutes. Prove in a warm spot (airing cupboard or oven with the light on)."
            },
            {
              "symptom": "Crust is pale and soft",
              "cause": "Oven not hot enough, or no steam.",
              "fix": "Preheat to 220°C with a tray on the bottom. Throw a cup of water into the tray when the loaf goes in — steam gives crust."
            },
            {
              "symptom": "Open crumb wasn't open",
              "cause": "Underproved, or the dough was knocked back too hard.",
              "fix": "Give it longer — until the dough doesn't spring back when poked. Shape gently so the bubbles survive."
            },
            {
              "symptom": "Bottom burnt before top browned",
              "cause": "Tray was too thin, or rack too low.",
              "fix": "Bake on a heavier tray on the middle shelf. Lining with baking paper helps."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Seeded crust: brush the top with water and roll in mixed seeds before the final prove."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Wholemeal: replace 100 g of the flour with wholemeal for a denser, nuttier loaf."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A British home cook's dish. It sits among the recipes families remember without thinking about — the kind that gets adjusted across generations and never quite the same twice."
          }
        ]
      }
    ]
