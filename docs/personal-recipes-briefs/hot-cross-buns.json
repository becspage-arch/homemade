      {
        "type": "infoPanel",
        "attrs": {
          "tone": "info",
          "title": "Also",
          "body": "Crosses."
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bring milk to boil."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Let it cool to ‘hand’ temperature…. do this first. It takes AGES to cool!!"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mix flour, sugar, salt, butter, yeast and egg together whilst slowly adding milk until soft, sticky dough forms."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Add sultanas, peel, apple, zest & cinnamon."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Knead for 10 mins."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Put in a greased bowl & cover."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Prove for 1 hour."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Divide into round balls (75-80g each) on a paper-lined baking tray."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cover and allow to prove for another hour."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Mix flour and water for crosses until a thick runny paste forms."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spoon into a round 3 mm piping bag or small ziplock bag then snip the corner."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Remove the cling wrap from the buns and pipe crosses onto the buns. Go slow so it hugs the curves."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Bake at 200 C for 15-20 minutes"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Glaze with apricot jam."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "troubleshooter",
        "attrs": {
          "heading": "If something goes wrong",
          "intro": "A few of the more common issues, and what tends to fix them.",
          "items": [
            {
              "symptom": "Bread is dense and didn't rise",
              "cause": "Yeast was stale, or the dough was too cold.",
              "fix": "Check yeast in warm water with a pinch of sugar — it should froth in five minutes. Prove in a warm spot (airing cupboard or oven with the light on)."
            },
            {
              "symptom": "Crust is pale and soft",
              "cause": "Oven not hot enough, or no steam.",
              "fix": "Preheat to 220°C with a tray on the bottom. Throw a cup of water into the tray when the loaf goes in — steam gives crust."
            },
            {
              "symptom": "Open crumb wasn't open",
              "cause": "Underproved, or the dough was knocked back too hard.",
              "fix": "Give it longer — until the dough doesn't spring back when poked. Shape gently so the bubbles survive."
            },
            {
              "symptom": "Bottom burnt before top browned",
              "cause": "Tray was too thin, or rack too low.",
              "fix": "Bake on a heavier tray on the middle shelf. Lining with baking paper helps."
            }
          ]
        }
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Variations"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Seeded crust: brush the top with water and roll in mixed seeds before the final prove."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Wholemeal: replace 100 g of the flour with wholemeal for a denser, nuttier loaf."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Make ahead, freezing, leftovers"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Best fresh. Leftovers keep two days in the fridge; reheat covered with a splash of liquid."
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Where this dish lives"
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "A British home cook's dish. It sits among the recipes families remember without thinking about — the kind that gets adjusted across generations and never quite the same twice."
          }
        ]
      }
    ]
  }
