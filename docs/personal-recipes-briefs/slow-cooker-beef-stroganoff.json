        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 2
        },
        "content": [
          {
            "type": "text",
            "text": "Method"
          }
        ]
      },
      {
        "type": "orderedList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Spray the inside of a large slow cooker with cooking spray (I use a 7 quart size slow cooker)."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Place the stew meat, mushrooms (if using), onion soup mix, beef broth and Worcestershire sauce in a slow cooker. Cover with lid and cook on low heat for 5 to 6 hours."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "In a medium bowl combine sour cream, cream cheese and heavy whipping cream. Whisk to combine then stir into meat mixture. Season with a little pepper."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cover with lid and let it warm up for another 20 minutes."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Serve over cooked egg noodles and enjoy!"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
