// Homemade Prisma schema.
//
// Conventions:
// - cuid IDs everywhere
// - createdAt + updatedAt timestamps on every mutable row
// - soft-delete-by-status rather than physical deletes for content tables
// - body fields are JSON (TipTap document)
//
// Schema is incremental — start with the tutorial spine; add Recipe / Pattern /
// Review / Q&A / UserProject / Marketplace / Creator / Errata models in later
// phases as they become needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────────────────────────────────────────
// Users — Clerk shadow + role
// ────────────────────────────────────────────────────────────────────────────

model User {
  id      String   @id @default(cuid())
  clerkId String   @unique
  email   String   @unique
  name    String?
  role    UserRole @default(MEMBER)

  // Reader-side preferences and profile
  beginnerMode  Boolean @default(false)
  displayHandle String? @unique
  bio           String?

  // Suspension state (Phase 5). `isSuspended` is the convenience flag the
  // moderation flow toggles; `suspendedUntil` mirrors the active UserSuspension's
  // end. Both are denormalised so filtering doesn't need a join.
  isSuspended    Boolean   @default(false)
  suspendedUntil DateTime?

  // Legal compliance (Phase 8a). `cookieConsent` is the persisted version of
  // the cookie banner's decision (mirrored to localStorage); null = the
  // banner hasn't been answered for this account yet. `deletionScheduledFor`
  // is set while a 30-day deletion grace period is in flight. `deletedAt`
  // marks the row as soft-deleted (PII scrubbed, audit-log entries retained).
  // `hardDeletedAt` is the bookkeeping stamp the daily hard-delete cron sets
  // when it actually scrubs the account — distinct from `deletedAt` so we
  // can differentiate "scrubbed by user request via the cron" from any
  // future admin-initiated soft-delete that might reuse `deletedAt`.
  cookieConsent        Json?
  deletionScheduledFor DateTime?
  deletedAt            DateTime?
  hardDeletedAt        DateTime?

  // Creator program (Phase 6). `isCreator` is the denormalised flag set when
  // an application is approved; the full profile lives in `CreatorProfile`.
  // `isPatternTester` flips on when a member opts in to the tester pool.
  isCreator         Boolean   @default(false)
  creatorVerifiedAt DateTime?
  isPatternTester   Boolean   @default(false)

  // Analytics — acquisition + cohort plumbing. All nullable: existing users
  // pre-date the capture and that's fine. Captured client-side on first visit
  // (localStorage) and persisted here on first signup (Clerk webhook).
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmContent          String?
  utmTerm             String?
  acquisitionChannel  String?
  signupCohortWeek    String?
  country             String?
  deviceClass         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutorialsAuthored Tutorial[]        @relation("TutorialAuthor")
  tutorialsCreated  Tutorial[]        @relation("TutorialCreator")
  versions          TutorialVersion[] @relation("VersionAuthor")
  auditLogs         AuditLog[]
  bookmarks         Bookmark[]
  projects          UserProject[]

  reviews            Review[]
  reviewHelpfuls     ReviewHelpful[]
  ugcPhotos          UGCPhoto[]
  questions          Question[]
  answers            Answer[]
  questionUpvotes    QuestionUpvote[]
  errata             Errata[]         @relation("ErrataAuthor")
  errataResolved     Errata[]         @relation("ErrataResolver")
  reportsFiled       Report[]         @relation("ReportReporter")
  reportsResolved    Report[]         @relation("ReportResolver")
  suspensions        UserSuspension[] @relation("SuspensionSubject")
  suspensionsApplied UserSuspension[] @relation("SuspensionActor")
  suspensionsLifted  UserSuspension[] @relation("SuspensionLifter")
  notifications      Notification[]
  reviewsModerated   Review[]         @relation("ReviewModerator")
  photosModerated    UGCPhoto[]       @relation("PhotoModerator")

  creatorProfile   CreatorProfile?  @relation("CreatorProfileOwner")
  creatorDecisions CreatorProfile[] @relation("CreatorProfileDecider")
  patternTests     PatternTest[]
  testAssignments  TestAssignment[]

  dataExportRequests       DataExportRequest[]
  accountDeletionRequest   AccountDeletionRequest?
  dmcaResolutions          DmcaTakedownRequest[]   @relation("DmcaResolver")
  signupAllowlistAdded     SignupAllowlist[]       @relation("SignupAllowlistAddedBy")

  @@index([role])
  @@index([isSuspended])
  @@index([isCreator])
}

enum UserRole {
  ANONYMOUS
  MEMBER
  CREATOR
  TESTER
  EDITOR
  ADMIN
}

// ────────────────────────────────────────────────────────────────────────────
// Taxonomy — Category / SubCategory / Tag
// ────────────────────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  introBody   Json? // Rich content (TipTap) for the editorial intro
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subCategories SubCategory[]
  tutorials     Tutorial[]
}

model SubCategory {
  id          String  @id @default(cuid())
  slug        String
  name        String
  description String?
  order       Int     @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  tutorials Tutorial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
}

model Tag {
  id   String @id @default(cuid())
  slug String @unique
  name String

  tutorials Tutorial[]

  createdAt DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────────────────
// Glossary — per-category technical terms
// ────────────────────────────────────────────────────────────────────────────

model GlossaryTerm {
  id         String @id @default(cuid())
  slug       String @unique
  term       String
  definition String // Short plain-text definition for tooltips
  body       Json? // Optional longer rich content for the term's own page

  categoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

// ────────────────────────────────────────────────────────────────────────────
// Tutorials — the heart of the platform
// ────────────────────────────────────────────────────────────────────────────

model Tutorial {
  id       String  @id @default(cuid())
  slug     String  @unique
  title    String
  subtitle String?
  excerpt  String? // Short summary used on cards and meta description

  // RECIPE | TECHNIQUE discriminator (Phase 8 Step 2). Recipes lead, techniques
  // support — see `project_content_pipeline.md`. Existing rows default to
  // TECHNIQUE; the migration backfills strawberry jam to RECIPE.
  type TutorialType @default(TECHNIQUE)

  // Categorisation
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  tags          Tag[]

  // Metadata shown in the info bar
  difficulty  Difficulty @default(BEGINNER)
  timeMinutes Int? // Total time the tutorial takes (sum of all steps)
  season      Season?
  sourceType  SourceType @default(SYNTHESISED)
  sourceNotes String? // Reference list / attribution notes

  // ──────────────────────────────────────────────────────────────────────────
  // Phase 8 Step 2 — recipe metadata. Null on TECHNIQUE rows. Authors set
  // these per recipe in the admin form; the public renderer surfaces the
  // values in the info bar + footer asides when `type === RECIPE`.
  // ──────────────────────────────────────────────────────────────────────────

  servings             Int? // Default yield (4 → "Serves 4")
  yieldDescription     String? // "1 loaf" / "12 muffins" — overrides "Serves N" when set
  prepMinutes          Int?
  cookMinutes          Int?
  restingMinutes       Int? // Dough rising, marinating
  chillingMinutes      Int? // Fridge / freezer rests (distinct from resting for filters)
  totalMinutes         Int? // Denormalised: prep + cook + resting + chilling. Recomputed on save.
  scalable             Boolean @default(true)
  freezable            Boolean @default(false)
  freezeNotes          String?
  batchable            Boolean @default(false)
  batchNotes           String?
  makeAheadNotes       String?
  dietaryFlags         String[] // vegetarian / vegan / glutenFree / dairyFree / halal / kosher / nutFree / pescatarian
  cuisine              String? // Italian / British / French / etc. Single-valued.
  mealType             String? // breakfast / lunch / dinner / snack / dessert / drink / side
  mood                 String[] // multi: comfortFood / weeknight / party / kidFriendly / freezerFriendly / healthy
  temperatureCelsius   Int?
  temperatureNote      String? // "fan oven", "low and slow"
  nutritionalInfoPerServing Json?

  // Foundational technique flag — drives the "Foundational technique" info-bar
  // badge for the ~500–700 core techniques (knife skills, mother sauces, etc.).
  // Always false on RECIPE rows.
  foundational Boolean @default(false)

  // Editorial pointer used by the recipe-page "Leftover bridge" block —
  // "when you've cooked this, here's what to do with the leftovers".
  leftoverTutorialId String?
  leftoverTutorial   Tutorial?  @relation("LeftoverBridge", fields: [leftoverTutorialId], references: [id], onDelete: SetNull)
  leftoverFor        Tutorial[] @relation("LeftoverBridge")

  // Content
  heroMediaId String?
  hero        Media?  @relation(fields: [heroMediaId], references: [id])
  body        Json // TipTap document — the article body

  // Lifecycle
  status       TutorialStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledFor DateTime?

  // Authorship
  authorId String
  author   User   @relation("TutorialAuthor", fields: [authorId], references: [id])

  // Creator attribution (Phase 6). Null = Homemade-authored. When set, the
  // tutorial is shown with a "By {creator}" byline that links to /makers/[handle].
  creatorId String?
  creator   User?   @relation("TutorialCreator", fields: [creatorId], references: [id])

  versions     TutorialVersion[]
  bookmarks    Bookmark[]
  projects     UserProject[]
  reviews      Review[]
  ugcPhotos    UGCPhoto[]
  questions    Question[]
  errata       Errata[]
  patternTests PatternTest[]
  recipeIngredients RecipeIngredient[]
  recipeTools       RecipeTool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([slug])
  @@index([creatorId, status, publishedAt])
  @@index([type])
  @@index([type, cuisine])
  @@index([type, mealType])
  @@index([type, totalMinutes])
  @@index([type, freezable])
  @@index([type, batchable])
  @@index([type, foundational])
}

enum TutorialType {
  RECIPE
  TECHNIQUE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
  YEAR_ROUND
}

enum SourceType {
  TESTED // Tested in Homemade kitchen/garden/etc
  CLASSIC // Classic precedent, cross-referenced across 5+ sources
  SYNTHESISED // Synthesised from public domain / extension service sources
  PUBLIC_DOMAIN // Direct public domain (e.g. Victorian crochet pattern)
  CREATOR // From an external creator (post Phase 6)
}

enum TutorialStatus {
  DRAFT
  IN_REVIEW
  PENDING_MODERATION
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

// One row per save in the admin editor. Used for version history + rollback.
model TutorialVersion {
  id         String   @id @default(cuid())
  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  // Snapshot of the editable fields at this version
  title    String
  subtitle String?
  excerpt  String?
  body     Json
  status   TutorialStatus

  authorId   String
  author     User    @relation("VersionAuthor", fields: [authorId], references: [id])
  changeNote String?

  createdAt DateTime @default(now())

  @@index([tutorialId, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Media — photos, videos, diagrams, illustrations
// ────────────────────────────────────────────────────────────────────────────

model Media {
  id String @id @default(cuid())

  // Cloudflare identifiers (one or both depending on type)
  cloudflareId String? @unique // Cloudflare Images / Stream ID
  r2Key        String? // R2 raw asset key

  type        MediaType
  mimeType    String?
  filename    String?
  alt         String?
  caption     String?
  attribution String? // Wikimedia / Unsplash / Pexels credit

  width  Int?
  height Int?
  bytes  Int?

  status MediaStatus @default(UPLOADING)

  tutorialsHero Tutorial[]
  ugcPhotos     UGCPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
}

enum MediaType {
  PHOTO
  VIDEO
  DIAGRAM
  ILLUSTRATION
}

enum MediaStatus {
  UPLOADING
  READY
  FAILED
}

// ────────────────────────────────────────────────────────────────────────────
// User state — bookmarks + projects (Phase 4)
// ────────────────────────────────────────────────────────────────────────────

model Bookmark {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tutorialId])
  @@index([userId])
}

// One UserProject per (user, tutorial). Tracks "I'm making this" lifecycle plus
// the reader's private notes, supplies tick-list, and reading progress.
model UserProject {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  status      UserProjectStatus @default(IN_PROGRESS)
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  abandonedAt DateTime?

  notes                  String   @default("")
  suppliesChecked        Json     @default("[]")
  readingProgressPercent Int      @default(0)
  lastViewedAt           DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tutorialId])
  @@index([userId])
  @@index([status])
}

enum UserProjectStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ────────────────────────────────────────────────────────────────────────────
// Audit log — every admin action recorded
// ────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id      String @id @default(cuid())
  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  action   String // e.g. "tutorial.create", "tutorial.publish", "category.update"
  resource String // e.g. "Tutorial:abc123"
  metadata Json? // Action-specific data (diff, before/after, etc.)

  createdAt DateTime @default(now())

  @@index([resource])
  @@index([actorId])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 5 — UGC: reviews, photos, Q&A, errata, reports, suspensions
// ────────────────────────────────────────────────────────────────────────────

model Review {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  rating Int // 1..5
  title  String?
  body   String

  helpfulCount Int             @default(0)
  helpfuls     ReviewHelpful[]

  status ReviewStatus @default(PENDING_MODERATION)

  moderatedAt    DateTime?
  moderatedById  String?
  moderatedBy    User?     @relation("ReviewModerator", fields: [moderatedById], references: [id])
  moderationNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tutorialId])
  @@index([tutorialId, status, createdAt])
  @@index([status, createdAt])
}

enum ReviewStatus {
  PENDING_MODERATION
  PUBLISHED
  HIDDEN
  REMOVED
}

model ReviewHelpful {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, reviewId])
  @@index([reviewId])
}

model UGCPhoto {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  caption String?

  status UGCPhotoStatus @default(PENDING_MODERATION)

  // NSFW pre-screen results. Null means the scanner hasn't run (or no permission).
  nsfwScore          Float?
  nsfwClassification String?

  rejectionReason String?

  moderatedAt   DateTime?
  moderatedById String?
  moderatedBy   User?     @relation("PhotoModerator", fields: [moderatedById], references: [id])

  createdAt DateTime @default(now())

  @@index([tutorialId, status])
  @@index([status, createdAt])
  @@index([userId])
}

enum UGCPhotoStatus {
  PENDING_MODERATION
  APPROVED
  REJECTED
}

model Question {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  body String

  status      UGCStatus        @default(PENDING_MODERATION)
  upvoteCount Int              @default(0)
  upvotes     QuestionUpvote[]
  answers     Answer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, status, upvoteCount])
  @@index([userId])
}

enum UGCStatus {
  PENDING_MODERATION
  PUBLISHED
  HIDDEN
  REMOVED
}

model Answer {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  body String

  /// True when the author has role ADMIN or EDITOR at write time.
  isAuthorAnswer Boolean @default(false)

  status       UGCStatus @default(PENDING_MODERATION)
  helpfulCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId, status])
}

model QuestionUpvote {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, questionId])
  @@index([questionId])
}

model Errata {
  id String @id @default(cuid())

  /// Nullable so future anonymous reports can flow through. In practice the
  /// splash gate means every reporter has a session.
  userId String?
  user   User?   @relation("ErrataAuthor", fields: [userId], references: [id], onDelete: SetNull)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  body String

  status ErrataStatus @default(OPEN)

  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?     @relation("ErrataResolver", fields: [resolvedById], references: [id])
  resolutionNote String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([tutorialId])
}

enum ErrataStatus {
  OPEN
  ADDRESSED
  DISMISSED
}

model Report {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType ReportTargetType
  /// Generic ID into the target table. Not a FK because the target type varies.
  targetId   String

  reason      ReportReason
  description String?

  status           ReportStatus @default(OPEN)
  resolutionAction String?

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("ReportResolver", fields: [resolvedById], references: [id])

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

enum ReportTargetType {
  REVIEW
  PHOTO
  QUESTION
  ANSWER
  USER
}

enum ReportReason {
  SPAM
  ABUSE
  MISINFORMATION
  COPYRIGHT
  NSFW
  OTHER
}

enum ReportStatus {
  OPEN
  RESOLVED_ACTION_TAKEN
  RESOLVED_NO_ACTION
  DISMISSED
}

model UserSuspension {
  id String @id @default(cuid())

  userId String
  user   User   @relation("SuspensionSubject", fields: [userId], references: [id], onDelete: Cascade)

  suspendedById String
  suspendedBy   User   @relation("SuspensionActor", fields: [suspendedById], references: [id])

  reason String

  startedAt DateTime  @default(now())
  /// Null means indefinite / permanent.
  endsAt    DateTime?

  liftedAt   DateTime?
  liftedById String?
  liftedBy   User?     @relation("SuspensionLifter", fields: [liftedById], references: [id])

  status SuspensionStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([status, endsAt])
}

enum SuspensionStatus {
  ACTIVE
  LIFTED
  EXPIRED
}

/// In-app notifications surfaced under /me. Intentionally small — moderation
/// outcomes + a couple of system messages. Email + push are deferred.
model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type NotificationType
  body String
  /// Optional URL the user can click through to (e.g. the published review).
  href String?

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum NotificationType {
  REVIEW_PUBLISHED
  REVIEW_HIDDEN
  REVIEW_REMOVED
  PHOTO_APPROVED
  PHOTO_REJECTED
  QUESTION_PUBLISHED
  QUESTION_HIDDEN
  ANSWER_PUBLISHED
  ANSWER_HIDDEN
  ERRATA_ADDRESSED
  ERRATA_DISMISSED
  ACCOUNT_SUSPENDED
  ACCOUNT_UNSUSPENDED
  CREATOR_APPLICATION_APPROVED
  CREATOR_APPLICATION_REJECTED
  CREATOR_TUTORIAL_PUBLISHED
  CREATOR_TUTORIAL_REJECTED
  CREATOR_TUTORIAL_SUBMITTED
  PATTERN_TEST_APPLICATION_ACCEPTED
  PATTERN_TEST_APPLICATION_REJECTED
  PATTERN_TEST_FEEDBACK_RECEIVED
  SYSTEM
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 6 — Creator program + pattern testing
// ────────────────────────────────────────────────────────────────────────────

/// One row per user who has applied for or holds the creator role. The
/// application + decision history lives on the row; once decidedAt is set,
/// `applicationStatus` reflects the outcome. The owning user's `isCreator`
/// flag is set on approval so role checks don't need a join.
model CreatorProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation("CreatorProfileOwner", fields: [userId], references: [id], onDelete: Cascade)

  bio       String
  specialty String

  // Optional social links surfaced on the public maker profile.
  websiteUrl      String?
  instagramHandle String?
  youtubeHandle   String?
  tiktokHandle    String?
  substackUrl     String?
  pinterestHandle String?

  applicationStatus CreatorApplicationStatus @default(APPLIED)
  applicationNote   String?
  appliedAt         DateTime                 @default(now())
  decidedAt         DateTime?
  decidedById       String?
  decidedBy         User?                    @relation("CreatorProfileDecider", fields: [decidedById], references: [id])
  rejectionReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationStatus, appliedAt])
}

enum CreatorApplicationStatus {
  NONE
  APPLIED
  APPROVED
  REJECTED
}

/// A pattern test is run by a creator (or future Homemade staff) on a tutorial
/// they own. Members opt in via `TestAssignment`. Once feedback is in, the
/// creator sees aggregated form data on the `feedback` page.
model PatternTest {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  status PatternTestStatus @default(DRAFT)

  /// Title shown on the public board — can differ from the tutorial title.
  title           String
  briefForTesters String
  maxTesters      Int    @default(5)

  recruitingClosesAt DateTime?
  completedAt        DateTime?

  assignments TestAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([creatorId, status])
  @@index([tutorialId])
}

enum PatternTestStatus {
  DRAFT
  RECRUITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// One row per (test, tester). Tracks lifecycle from APPLIED through
/// COMPLETED and stores the structured feedback JSON blob the tester submits.
model TestAssignment {
  id String @id @default(cuid())

  patternTestId String
  patternTest   PatternTest @relation(fields: [patternTestId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status          TestAssignmentStatus @default(APPLIED)
  applicationNote String?

  /// Structured feedback form output. Shape:
  /// {
  ///   patternClarity: { score: 1..5, comment: string },
  ///   instructionClarity: { score: 1..5, comment: string },
  ///   photoAccuracy: { score: 1..5, comment: string },
  ///   suppliesAccuracy: { score: 1..5, comment: string },
  ///   timeTakenMinutes: number | null,
  ///   estimatedTimeMinutes: number | null,
  ///   whatWorked: string,
  ///   whatDidnt: string,
  /// }
  feedback Json?

  appliedAt       DateTime  @default(now())
  decidedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  withdrawnAt     DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patternTestId, userId])
  @@index([userId, status])
  @@index([patternTestId, status])
}

enum TestAssignmentStatus {
  APPLIED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  WITHDRAWN
  REJECTED
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 8a — Legal compliance: GDPR data rights + DMCA takedowns
// ────────────────────────────────────────────────────────────────────────────

/// One row per data-export request a user has fired. Holds the bundle URL
/// once produced. `expiresAt` is enforced at read time — once past, the
/// download link 410s and the row is marked EXPIRED.
model DataExportRequest {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status DataExportStatus @default(REQUESTED)

  /// Public URL the user can fetch the bundle from (R2 custom domain).
  fileUrl String?
  /// R2 object key — kept so we can delete the bundle after expiry.
  fileKey String?
  bytes   Int?

  error String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime?

  @@index([userId, createdAt])
  @@index([status, expiresAt])
}

enum DataExportStatus {
  REQUESTED
  PROCESSING
  READY
  EXPIRED
  FAILED
}

/// One active row per user — `userId` is unique. While SCHEDULED, the user
/// is also flagged `isSuspended = true` so the account can't be used during
/// the grace period; cancelling lifts the suspension. After
/// `scheduledFor` passes a follow-up job (manual for now) runs the hard
/// delete: scrubs PII, sets `User.deletedAt`, preserves audit log entries.
model AccountDeletionRequest {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason String?

  status DeletionStatus @default(SCHEDULED)

  /// 30 days after `requestedAt`. A scheduled hard-delete job picks up rows
  /// past this date; until then the user can cancel.
  scheduledFor DateTime
  requestedAt  DateTime @default(now())
  cancelledAt  DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledFor])
}

enum DeletionStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

/// DMCA / takedown notices from outside the platform. We never want to
/// trust the claimant blindly — every record stores their sworn-statement
/// acceptance and a contact trail. Admin actions are audit-logged via the
/// shared `audit()` helper.
model DmcaTakedownRequest {
  id String @id @default(cuid())

  claimantName     String
  claimantEmail    String
  claimantAddress  String?

  /// The URL or location of the allegedly infringing content. Free text
  /// because claimants don't always send a clean URL.
  contentUrl         String
  /// Description of the work being infringed and how it's being infringed.
  contentDescription String

  /// The DMCA notice requires the claimant to swear under penalty of perjury
  /// that the information is accurate and they are authorised to act. We
  /// don't accept a notice without this box ticked.
  swornStatementAccepted Boolean @default(false)

  status DmcaStatus @default(RECEIVED)

  actionTakenNote String?

  createdAt DateTime @default(now())
  resolvedAt DateTime?
  resolvedById String?
  resolvedBy   User?   @relation("DmcaResolver", fields: [resolvedById], references: [id])

  @@index([status, createdAt])
}

enum DmcaStatus {
  RECEIVED
  UNDER_REVIEW
  ACTION_TAKEN
  REJECTED
  COUNTER_NOTICED
}

// ────────────────────────────────────────────────────────────────────────────
// Pre-launch signup allowlist
// ────────────────────────────────────────────────────────────────────────────

/// Pre-launch gate that pairs with the Clerk dashboard Restrictions feature.
/// While `SIGNUP_ALLOWLIST_ENABLED` is true (in the webhook handler), any
/// Clerk signup whose primary email isn't on this table is deleted via the
/// Clerk Backend API immediately and the Prisma mirror row is rolled back.
/// Flipped off on launch day — see `project_pre_launch_checklist.md`.
model SignupAllowlist {
  id String @id @default(cuid())

  /// Lowercased before write. Unique so we can't have stale duplicates.
  email String @unique

  /// The admin who added the entry. ON DELETE SET NULL so removing an admin
  /// account doesn't drop allowlist rows.
  addedById String?
  addedBy   User?   @relation("SignupAllowlistAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  /// Optional free-text context, e.g. "Phase 6 creator test account".
  note String?

  /// Set when an allowlisted user actually signs up. Lets us spot stale
  /// entries that were never used.
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([addedById])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 8 — Master ingredient + tool tables. Recipes link to these via
// RecipeIngredient / RecipeTool join rows. The Ingredient table is the single
// source of truth for dietary flags, allergens, UK/US naming, substitutes —
// so "plain flour" carries its own gluten flag once and every recipe inherits.
// ────────────────────────────────────────────────────────────────────────────

model Ingredient {
  id   String @id @default(cuid())
  slug String @unique
  name String

  /// Optional explicit plural (used in summaries / titles). Falls back to the
  /// English `name + "s"` heuristic at render time when null.
  pluralName String?

  /// Free-form string enum: flour / dairy / meat / fish / vegetable / fruit /
  /// herb / spice / condiment / baking / pulse / grain / nut / seed / oil /
  /// vinegar / sweetener / alcohol / other. Kept as a string rather than a
  /// Prisma enum so authors can add categories without a follow-up migration.
  category String

  /// g / ml / each / tbsp / tsp / cup / pinch. Authors may override per
  /// RecipeIngredient via RecipeIngredient.unit.
  defaultUnit String

  /// Per-ingredient dietary flags — recipes derive their own dietaryFlags
  /// from the AND of their ingredient flags at index time.
  dietaryFlags String[]

  /// Slugs of other Ingredient rows that work as 1:1 substitutes.
  commonSubstitutes String[]

  /// Alternative names (UK ↔ US, regional). Indexed at search time so
  /// "rapeseed oil" finds "canola oil" and similar.
  aliases String[]

  /// Free-form notes — UK/US naming, prep tips, sourcing hints.
  notes String?

  /// Beginner-mode helper line surfaced in the structured-ingredients block
  /// when the reader has beginnerMode on. Per docs/page-design.md § 7.1.
  beginnerNote String?

  /// Cupboard-mode flag — items the average kitchen will already have
  /// (salt, pepper, plain flour, olive oil, …). Phase 8 cupboard-mode UI hooks
  /// off this so recipes that need 90% staples surface first.
  isStaple Boolean @default(false)

  /// UK 14-allergen list. When true, `allergenType` carries which group.
  isAllergen   Boolean @default(false)
  /// gluten / crustaceans / eggs / fish / peanuts / soybeans / milk / nuts /
  /// celery / mustard / sesame / sulphites / lupin / molluscs.
  allergenType String?

  /// Months when fresh-and-in-season, e.g. `["june", "july", "august"]`.
  /// Empty for pantry items.
  seasonality String[]

  /// Typical shelf life in days (fridge / cupboard depending on `storage`).
  shelfLifeDays Int?
  /// "fridge", "cool dark cupboard", "freezer".
  storage       String?

  /// Per-100g nutritional info. Flexible Json shape so we can refine later
  /// without re-migrating; stays null until populated.
  nutritionalInfoPer100g Json?

  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isStaple])
  @@index([isAllergen])
}

model Tool {
  id   String @id @default(cuid())
  slug String @unique
  name String

  /// knife / pan / pot / oven / mixer / processor / measuring / bowl / tray /
  /// tin / board / utensil / appliance / electrical / thermometer / scale /
  /// other. Free-form string for the same forwards-compat reason.
  category String

  /// Alternative names ("stand mixer" alias for "KitchenAid", "loaf tin"
  /// alias for "bread pan").
  aliases String[]

  /// Flips false for tools we'll never sell (e.g. a sink). Lets the future
  /// marketplace filter out non-purchasable rows up-front.
  isPurchasable Boolean @default(true)

  /// Typical price in pennies (GBP). Phase 7 marketplace sorts the buy panel
  /// by this. Stays null until Rebecca sets one.
  typicalPriceGbp Int?

  notes String?

  recipeTools RecipeTool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPurchasable])
}

/// One row per (recipe, ingredient). Derived from the `ingredientsList` block
/// in the recipe body on every save — see `syncRecipeIngredientsFromBody` in
/// `apps/web/src/lib/recipe-ingredients-sync.ts`.
model RecipeIngredient {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  /// Null means "to taste" / "as needed".
  amount Float?
  /// Overrides Ingredient.defaultUnit when set.
  unit   String?

  /// "finely chopped", "at room temperature", "zest only".
  prepNote String?

  isOptional Boolean @default(false)

  /// Sub-heading the row sits under in the rendered list ("For the dough",
  /// "For the topping"). Null = renders under the recipe's main "Ingredients".
  groupLabel String?

  /// Display order within the group.
  position Int

  /// When false, the scale selector and "swap with substitute" affordance
  /// are suppressed for this row (e.g. flour percentages in bakery).
  substitutionAllowed Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, position])
  @@index([ingredientId])
}

/// One row per (recipe, tool). The `equipmentList` TipTap block is deferred to
/// a future small session; for now these rows can be seeded directly when
/// recipes are authored, even though there's no editor block writing them yet.
model RecipeTool {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Restrict)

  isOptional Boolean @default(false)
  /// "or any oven-safe non-stick pan".
  notes      String?

  position Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, position])
  @@index([toolId])
}
