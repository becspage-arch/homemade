// Homemade Prisma schema.
//
// Conventions:
// - cuid IDs everywhere
// - createdAt + updatedAt timestamps on every mutable row
// - soft-delete-by-status rather than physical deletes for content tables
// - body fields are JSON (TipTap document)
//
// Schema is incremental — start with the tutorial spine; add Recipe / Pattern /
// Review / Q&A / UserProject / Marketplace / Creator / Errata models in later
// phases as they become needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────────────────────────────────────────
// Users — Clerk shadow + role
// ────────────────────────────────────────────────────────────────────────────

model User {
  id      String   @id @default(cuid())
  clerkId String   @unique
  email   String   @unique
  name    String?
  role    UserRole @default(MEMBER)

  // Reader-side preferences and profile
  beginnerMode  Boolean @default(false)
  displayHandle String? @unique
  bio           String?

  // Suspension state (Phase 5). `isSuspended` is the convenience flag the
  // moderation flow toggles; `suspendedUntil` mirrors the active UserSuspension's
  // end. Both are denormalised so filtering doesn't need a join.
  isSuspended    Boolean   @default(false)
  suspendedUntil DateTime?

  // Legal compliance (Phase 8a). `cookieConsent` is the persisted version of
  // the cookie banner's decision (mirrored to localStorage); null = the
  // banner hasn't been answered for this account yet. `deletionScheduledFor`
  // is set while a 30-day deletion grace period is in flight. `deletedAt`
  // marks the row as soft-deleted (PII scrubbed, audit-log entries retained).
  // `hardDeletedAt` is the bookkeeping stamp the daily hard-delete cron sets
  // when it actually scrubs the account — distinct from `deletedAt` so we
  // can differentiate "scrubbed by user request via the cron" from any
  // future admin-initiated soft-delete that might reuse `deletedAt`.
  cookieConsent        Json?
  deletionScheduledFor DateTime?
  deletedAt            DateTime?
  hardDeletedAt        DateTime?

  // Creator program (Phase 6). `isCreator` is the denormalised flag set when
  // an application is approved; the full profile lives in `CreatorProfile`.
  // `isPatternTester` flips on when a member opts in to the tester pool.
  isCreator         Boolean   @default(false)
  creatorVerifiedAt DateTime?
  isPatternTester   Boolean   @default(false)

  // Analytics — acquisition + cohort plumbing. All nullable: existing users
  // pre-date the capture and that's fine. Captured client-side on first visit
  // (localStorage) and persisted here on first signup (Clerk webhook).
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  utmContent         String?
  utmTerm            String?
  acquisitionChannel String?
  signupCohortWeek   String?
  country            String?
  deviceClass        String?

  // Phase 8 Homepage rebuild — onboarding + personalisation. `onboardedAt`
  // null = the onboarding card still shows on the homepage. `primaryCategoryIds`
  // / `experienceLevel` / `dietaryFlags` come from the onboarding card and
  // weight the personalised rails. `homeCountryCode` is captured from
  // Cloudflare's `cf-ipcountry` header at signup and steers the seasonality
  // engine; the user can override later from settings. `lastSeenAt` powers
  // the "New since you last visited" rail.
  onboardedAt        DateTime?
  primaryCategoryIds String[]         @default([])
  experienceLevel    ExperienceLevel?
  homeCountryCode    String?
  dietaryFlags       String[]         @default([])
  lastSeenAt         DateTime?

  // Mobile rebuild — push + cooking mode preferences. `pushNotificationsEnabled`
  // is the master toggle (false until the user accepts the opt-in prompt that
  // appears after their first started UserProject). Per-category opt-outs live
  // on the individual PushSubscription rows so a user can be opted in on iOS
  // and not on Android, or opted in for project reminders but not the weekly
  // digest. `cookingModeAutoEnable` makes recipe pages open straight into the
  // stripped-down cooking-mode reader on mobile.
  pushNotificationsEnabled Boolean @default(false)
  cookingModeAutoEnable    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutorialsAuthored Tutorial[]        @relation("TutorialAuthor")
  tutorialsCreated  Tutorial[]        @relation("TutorialCreator")
  versions          TutorialVersion[] @relation("VersionAuthor")
  auditLogs         AuditLog[]
  bookmarks         Bookmark[]
  projects          UserProject[]

  reviews            Review[]
  reviewHelpfuls     ReviewHelpful[]
  ugcPhotos          UGCPhoto[]
  questions          Question[]
  answers            Answer[]
  questionUpvotes    QuestionUpvote[]
  errata             Errata[]         @relation("ErrataAuthor")
  errataResolved     Errata[]         @relation("ErrataResolver")
  reportsFiled       Report[]         @relation("ReportReporter")
  reportsResolved    Report[]         @relation("ReportResolver")
  suspensions        UserSuspension[] @relation("SuspensionSubject")
  suspensionsApplied UserSuspension[] @relation("SuspensionActor")
  suspensionsLifted  UserSuspension[] @relation("SuspensionLifter")
  notifications      Notification[]
  reviewsModerated   Review[]         @relation("ReviewModerator")
  photosModerated    UGCPhoto[]       @relation("PhotoModerator")

  creatorProfile   CreatorProfile?  @relation("CreatorProfileOwner")
  creatorDecisions CreatorProfile[] @relation("CreatorProfileDecider")
  patternTests     PatternTest[]
  testAssignments  TestAssignment[]

  dataExportRequests     DataExportRequest[]
  accountDeletionRequest AccountDeletionRequest?
  dmcaResolutions        DmcaTakedownRequest[]   @relation("DmcaResolver")
  signupAllowlistAdded   SignupAllowlist[]       @relation("SignupAllowlistAddedBy")

  // Admin overhaul — saved filters + cmd-K command history.
  savedFilters        SavedFilter[]         @relation("SavedFilterOwner")
  adminCommandHistory AdminCommandHistory[] @relation("AdminCommandActor")

  // Phase 8 Step 13 — Mindset
  mindsetPlans      UserPlan[]
  mindsetDailyPicks DailyPick[]
  practiceFavorites UserPracticeFavorite[]
  practiceUses      UserPracticeUse[]

  // Mobile rebuild — registered push devices (one per platform per install).
  pushSubscriptions PushSubscription[]

  @@index([role])
  @@index([isSuspended])
  @@index([isCreator])
  @@index([onboardedAt])
  @@index([lastSeenAt])
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  CONFIDENT
}

enum UserRole {
  ANONYMOUS
  MEMBER
  CREATOR
  TESTER
  EDITOR
  ADMIN
}

// ────────────────────────────────────────────────────────────────────────────
// Taxonomy — Category / SubCategory / Tag
// ────────────────────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  introBody   Json? // Rich content (TipTap) for the editorial intro
  order       Int     @default(0)

  // Multi-category fill plan (phase_categories_targets_001).
  // `targetTutorialCount` is the eventual library size for this category from
  // `BUILD_PROGRESS.md` § "Multi-category fill plan". Null = no target set.
  // `isPublicVisible` controls whether the category surfaces in public nav,
  // browse grids, and category pages. New categories with < 10 published
  // tutorials default to false; the publish path flips it to true once the
  // threshold is crossed. Admin sees every category regardless.
  // `launchOrder` orders the public nav rotation (1 = first spine, …) — used
  // by the "5 spine + overflow" header pattern.
  targetTutorialCount Int?
  isPublicVisible     Boolean @default(true)
  launchOrder         Int?

  // Single-queue autopilot (phase_autopilot_single_queue_001).
  // `pipelineStatus` gates whether the round-robin queue cron picks this
  // category. NOT_READY = no authoring prompt / master entities yet;
  // READY = the queue may fire batches against it; PAUSED = temporarily
  // skipped without disabling the cron; COMPLETE = published count has
  // hit `targetTutorialCount` and the publish path auto-flipped it.
  // `lastAutopilotRunAt` is set to now() at the start of each batch so
  // the round-robin sort picks the least-recently-fired READY category
  // next. `autopilotWeight` is reserved for future weighted round-robin
  // (each weight unit = one slot per cycle); default 1 means strict
  // round-robin.
  pipelineStatus     PipelineStatus @default(NOT_READY)
  lastAutopilotRunAt DateTime?
  autopilotWeight    Int            @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subCategories SubCategory[]
  tutorials     Tutorial[]

  @@index([pipelineStatus, lastAutopilotRunAt])
}

model SubCategory {
  id          String  @id @default(cuid())
  slug        String
  name        String
  description String?
  order       Int     @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  tutorials Tutorial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
}

model Tag {
  id   String @id @default(cuid())
  slug String @unique
  name String

  tutorials Tutorial[]

  createdAt DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────────────────
// Glossary — per-category technical terms
// ────────────────────────────────────────────────────────────────────────────

model GlossaryTerm {
  id         String @id @default(cuid())
  slug       String @unique
  term       String
  definition String // Short plain-text definition for tooltips
  body       Json? // Optional longer rich content for the term's own page

  categoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

// ────────────────────────────────────────────────────────────────────────────
// Tutorials — the heart of the platform
// ────────────────────────────────────────────────────────────────────────────

model Tutorial {
  id       String  @id @default(cuid())
  slug     String  @unique
  title    String
  subtitle String?
  excerpt  String? // Short summary used on cards and meta description

  // RECIPE | TECHNIQUE discriminator (Phase 8 Step 2). Recipes lead, techniques
  // support — see `project_content_pipeline.md`. Existing rows default to
  // TECHNIQUE; the migration backfills strawberry jam to RECIPE.
  type TutorialType @default(TECHNIQUE)

  // Categorisation
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  tags          Tag[]

  // Metadata shown in the info bar
  difficulty  Difficulty @default(BEGINNER)
  timeMinutes Int? // Total time the tutorial takes (sum of all steps)
  season      Season?
  sourceType  SourceType @default(SYNTHESISED)
  sourceNotes String? // Reference list / attribution notes

  // ──────────────────────────────────────────────────────────────────────────
  // Phase 8 Step 2 — recipe metadata. Null on TECHNIQUE rows. Authors set
  // these per recipe in the admin form; the public renderer surfaces the
  // values in the info bar + footer asides when `type === RECIPE`.
  // ──────────────────────────────────────────────────────────────────────────

  servings                  Int? // Default yield (4 → "Serves 4")
  yieldDescription          String? // "1 loaf" / "12 muffins" — overrides "Serves N" when set
  prepMinutes               Int?
  cookMinutes               Int?
  restingMinutes            Int? // Dough rising, marinating
  chillingMinutes           Int? // Fridge / freezer rests (distinct from resting for filters)
  totalMinutes              Int? // Denormalised: prep + cook + resting + chilling. Recomputed on save.
  scalable                  Boolean  @default(true)
  freezable                 Boolean  @default(false)
  freezeNotes               String?
  batchable                 Boolean  @default(false)
  batchNotes                String?
  makeAheadNotes            String?
  dietaryFlags              String[] // vegetarian / vegan / glutenFree / dairyFree / halal / kosher / nutFree / pescatarian
  cuisine                   String? // Italian / British / French / etc. Single-valued.
  mealType                  String? // breakfast / lunch / dinner / snack / dessert / drink / side
  mood                      String[] // multi: comfortFood / weeknight / party / kidFriendly / freezerFriendly / healthy
  temperatureCelsius        Int?
  temperatureNote           String? // "fan oven", "low and slow"
  nutritionalInfoPerServing Json?

  // Foundational technique flag — drives the "Foundational technique" info-bar
  // badge for the ~500–700 core techniques (knife skills, mother sauces, etc.).
  // Always false on RECIPE rows.
  foundational Boolean @default(false)

  // Editorial pointer used by the recipe-page "Leftover bridge" block —
  // "when you've cooked this, here's what to do with the leftovers".
  leftoverTutorialId String?
  leftoverTutorial   Tutorial?  @relation("LeftoverBridge", fields: [leftoverTutorialId], references: [id], onDelete: SetNull)
  leftoverFor        Tutorial[] @relation("LeftoverBridge")

  // Content
  heroMediaId String?
  hero        Media?  @relation(fields: [heroMediaId], references: [id])
  body        Json // TipTap document — the article body

  // Phase 8 Homepage rebuild — heroImageStrategy tracks where the current
  // hero came from. PROCEDURAL_CARD = the renderer should show the
  // category-tinted SVG card built at request time from title + category.
  // REAL_PHOTO / AI_GENERATED = there's a Media row attached (`heroMediaId`).
  // UNSET = default for new rows until the editor / backfill resolves the
  // strategy. The public renderer falls through to PROCEDURAL_CARD whenever
  // no Media row exists, regardless of stored strategy, so callers stay safe.
  heroImageStrategy HeroStrategy @default(UNSET)

  // Lifecycle
  status       TutorialStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledFor DateTime?

  // Authorship
  authorId String
  author   User   @relation("TutorialAuthor", fields: [authorId], references: [id])

  // Creator attribution (Phase 6). Null = Homemade-authored. When set, the
  // tutorial is shown with a "By {creator}" byline that links to /makers/[handle].
  creatorId String?
  creator   User?   @relation("TutorialCreator", fields: [creatorId], references: [id])

  versions          TutorialVersion[]
  bookmarks         Bookmark[]
  projects          UserProject[]
  reviews           Review[]
  ugcPhotos         UGCPhoto[]
  questions         Question[]
  errata            Errata[]
  patternTests      PatternTest[]
  recipeIngredients RecipeIngredient[]
  recipeTools       RecipeTool[]

  weeklyEditorialPicks WeeklyEditorialPick[]
  projectSchedule      ProjectSchedule[]

  // ──────────────────────────────────────────────────────────────────────────
  // Phase 8 Step 13 — Mindset practice metadata. Null on rows where
  // type != PRACTICE. The `whenToUse` matcher string is the one-sentence
  // signal the "I'm feeling..." surface and the plan generator both read
  // when deciding which library row to surface. `alternativePracticeIds`
  // is a free-form string array (not a Prisma relation) so practices can
  // point at sibling slugs without needing a join row — same pattern as
  // `Ingredient.commonSubstitutes`.
  // ──────────────────────────────────────────────────────────────────────────

  practiceType           PracticeType?
  practiceTargets        PracticeTarget[] @default([])
  timeBand               TimeBand?
  bestTime               BestTime?
  practiceDepth          Difficulty?
  whenToUse              String?
  whenNotToUse           String?
  alternativePracticeIds String[]         @default([])

  // ──────────────────────────────────────────────────────────────────────────
  // Phase 8 Baking pipeline — Baking-specific recipe metadata. Null on rows
  // where `type != RECIPE` or where the recipe is not in the Baking category.
  // Cooking recipes ignore these columns (they continue to use the existing
  // `temperatureCelsius` / `temperatureNote` for oven cook temperatures).
  // Bread + pastry + cake + biscuit + pie + scone + confectionery +
  // cake-decorating live under one set of optional columns so all eight
  // sub-categories share a single migration. See `docs/baking-author.md`.
  // ──────────────────────────────────────────────────────────────────────────

  // Hydration metadata — baker's-percentage anchored. All percentages are
  // relative to flour weight; the flour weight itself anchors the whole
  // recipe so the public renderer can show derived totals.
  flourWeightGrams Int?
  hydrationPercent Float?
  saltPercent      Float?
  yeastPercent     Float?
  levainPercent    Float?

  // Proofing metadata. All in minutes; null when the bake doesn't use that
  // stage (a biscuit dough has no bulk ferment; a tin loaf has no levain
  // build). `retardingMinutes` distinct from `chillingMinutes` (recipe-wide
  // cold rest, e.g. a pastry chill) so bread workflows surface separately.
  bulkFermentMinutes Int?
  proofMinutes       Int?
  retardingMinutes   Int?
  levainBuildMinutes Int?

  // Lamination metadata. Puff, croissant, and Danish carry fold + rest
  // counts; shortcrust / filo skip these.
  laminationFolds Int?
  laminationRests Int?

  // Oven + steam. Baking-specific oven settings: distinct from cooking's
  // `temperatureCelsius` so bake-specific surfaces (steam method, etc.)
  // can group together. Authors may still set the cooking field for
  // legacy compatibility — the renderer prefers `bakeTemperatureCelsius`
  // when the recipe is in the Baking category.
  bakeTemperatureCelsius Int?
  bakeTemperatureNote    String?
  steamMethod            String?

  // Decorating. Surfaces in the info bar on cake-decorating tutorials.
  decoratingTechnique String?

  // Pre-ferment type. NONE on straight doughs; one of the structured
  // variants for breads that build flavour through a separate ferment.
  preFermentType PreFermentType?

  // ──────────────────────────────────────────────────────────────────────────
  // Phase Garden pipeline — Garden-specific growing-guide metadata. Null on
  // rows where `type != GROWING_GUIDE`. Growing difficulty reuses the existing
  // `difficulty` column (BEGINNER / INTERMEDIATE / ADVANCED ladder is shared
  // across categories). See `docs/garden-author.md` for per-sub-topic guidance
  // on which fields to set.
  // ──────────────────────────────────────────────────────────────────────────

  // Months when the plant is sown / planted (lower-case 'march',
  // 'april', ...). Drives the "what to sow in April" public filter.
  plantingMonths String[] @default([])

  // Months when the plant is harvested / picked.
  harvestMonths String[] @default([])

  // Container + indoor friendliness — drive the "grows on a balcony" and
  // "windowsill-friendly" filters. Nullable on purpose: null means "not a
  // growing guide" / not applicable, distinct from explicit false.
  containerFriendly Boolean?
  indoorFriendly    Boolean?

  // Regional applicability. The author writes UK-default schedules; this flag
  // expands readership where the same schedule applies. Values:
  // 'UK' / 'EU' / 'US_NORTH' / 'US_SOUTH' / 'AU_NZ' / 'ZA'.
  // Defaults to ['UK'] at upload time when the author leaves it empty.
  regionsApplicable String[] @default([])

  planDayMornings    UserPlanDay[]          @relation("PlanDayMorningPractice")
  planDayEvenings    UserPlanDay[]          @relation("PlanDayEveningPractice")
  planDayAnchors     UserPlanDay[]          @relation("PlanDayAnchorPractice")
  planDayReflections UserPlanDay[]          @relation("PlanDayReflectionPrompt")
  dailyPicks         DailyPick[]
  practiceFavorites  UserPracticeFavorite[]
  practiceUses       UserPracticeUse[]
  feelingMatches     UserFeeling[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([slug])
  @@index([creatorId, status, publishedAt])
  @@index([type])
  @@index([type, cuisine])
  @@index([type, mealType])
  @@index([type, totalMinutes])
  @@index([type, freezable])
  @@index([type, batchable])
  @@index([type, foundational])
  @@index([type, practiceType])
  @@index([type, timeBand])
  @@index([type, bestTime])
  @@index([practiceTargets], type: Gin)
  @@index([type, preFermentType])
  @@index([type, decoratingTechnique])
  @@index([type, containerFriendly])
  @@index([type, indoorFriendly])
  @@index([plantingMonths], type: Gin)
  @@index([harvestMonths], type: Gin)
  @@index([regionsApplicable], type: Gin)
}

enum TutorialType {
  RECIPE
  TECHNIQUE
  PRACTICE
  READING
  GROWING_GUIDE
}

enum HeroStrategy {
  REAL_PHOTO
  PROCEDURAL_CARD
  PUBLIC_DOMAIN_PLATE
  AI_GENERATED
  UNSET
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

/// Single-queue autopilot (phase_autopilot_single_queue_001).
/// Gates whether the round-robin queue cron picks the category.
enum PipelineStatus {
  NOT_READY // No authoring prompt / master entities yet; queue skips.
  READY // Queue may fire bulk batches against this category.
  PAUSED // Temporarily skipped (e.g. quality drift) without disabling cron.
  COMPLETE // Published count has reached targetTutorialCount.
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
  YEAR_ROUND
}

enum SourceType {
  TESTED // Tested in Homemade kitchen/garden/etc
  CLASSIC // Classic precedent, cross-referenced across 5+ sources
  SYNTHESISED // Synthesised from public domain / extension service sources
  PUBLIC_DOMAIN // Direct public domain (e.g. Victorian crochet pattern)
  CREATOR // From an external creator (post Phase 6)
}

enum TutorialStatus {
  DRAFT
  IN_REVIEW
  PENDING_MODERATION
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

// One row per save in the admin editor. Used for version history + rollback.
model TutorialVersion {
  id         String   @id @default(cuid())
  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  // Snapshot of the editable fields at this version
  title    String
  subtitle String?
  excerpt  String?
  body     Json
  status   TutorialStatus

  authorId   String
  author     User    @relation("VersionAuthor", fields: [authorId], references: [id])
  changeNote String?

  createdAt DateTime @default(now())

  @@index([tutorialId, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Media — photos, videos, diagrams, illustrations
// ────────────────────────────────────────────────────────────────────────────

model Media {
  id String @id @default(cuid())

  // Cloudflare identifiers (one or both depending on type)
  cloudflareId String? @unique // Cloudflare Images / Stream ID
  r2Key        String? // R2 raw asset key

  type        MediaType
  mimeType    String?
  filename    String?
  alt         String?
  caption     String?
  attribution String? // Legacy free-text credit. Prefer the structured fields below.

  width  Int?
  height Int?
  bytes  Int?

  status MediaStatus @default(UPLOADING)

  // ──────────────────────────────────────────────────────────────────────────
  // Phase 8 content integration — structured sourcing + attribution metadata.
  // Set by the image-sourcing orchestrator (`apps/web/src/lib/image-sourcing/`).
  // The public renderer reads `requiresAttribution` to decide whether to show
  // the discreet attribution tooltip on the hero.
  // ──────────────────────────────────────────────────────────────────────────

  /// Source identifier — unsplash / pexels / wikimedia / pixabay / usda / nlm /
  /// flux-schnell / procedural-card / original / manual-upload.
  source String?

  /// URL of the original asset (for our records — never displayed).
  sourceUrl String?

  /// Photographer / illustrator name for attribution display.
  creatorName String?

  /// Licence code — CC-BY / CC-BY-SA / CC0 / PD / PROPRIETARY / UNSPLASH /
  /// PEXELS / PIXABAY etc. PROPRIETARY-but-permissive licences (Unsplash /
  /// Pexels / Pixabay) don't require attribution; CC-BY / CC-BY-SA do.
  licenceCode String?

  /// Link to the full licence text (e.g. https://creativecommons.org/licenses/by/4.0/).
  licenceUrl String?

  /// Computed at insert time from licenceCode. When true, the public renderer
  /// surfaces a discreet attribution tooltip on the hero.
  requiresAttribution Boolean @default(false)

  /// Verification verdict from the image-sourcing pipeline. A worker session
  /// (Claude Code, using its built-in multimodal Read capability) compares the
  /// image against the tutorial title / key ingredients / cuisine and decides
  /// whether the image is a plausible match. UNVERIFIED rows are picked up by
  /// the sweep script. REJECTED_USED_PROCEDURAL means the orchestrator could
  /// not find a plausible image even from Flux fallback and the tutorial fell
  /// back to its procedural card.
  verificationStatus MediaVerificationStatus @default(UNVERIFIED)
  verificationReason String?
  verifiedAt         DateTime?

  tutorialsHero Tutorial[]
  ugcPhotos     UGCPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([source])
  @@index([verificationStatus])
}

enum MediaType {
  PHOTO
  VIDEO
  DIAGRAM
  ILLUSTRATION
}

enum MediaStatus {
  UPLOADING
  READY
  FAILED
}

enum MediaVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
  REJECTED_USED_PROCEDURAL
}

// ────────────────────────────────────────────────────────────────────────────
// User state — bookmarks + projects (Phase 4)
// ────────────────────────────────────────────────────────────────────────────

model Bookmark {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tutorialId])
  @@index([userId])
}

// One UserProject per (user, tutorial). Tracks "I'm making this" lifecycle plus
// the reader's private notes, supplies tick-list, and reading progress.
model UserProject {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  status      UserProjectStatus @default(IN_PROGRESS)
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  abandonedAt DateTime?

  notes                  String   @default("")
  suppliesChecked        Json     @default("[]")
  readingProgressPercent Int      @default(0)
  lastViewedAt           DateTime @default(now())

  // Phase 8 Homepage rebuild — multi-day arc tracker. Long-arc tutorials
  // (sourdough starters, fermentation, growing) register `ProjectSchedule`
  // rows; when the user starts a project these denormalised fields snapshot
  // the next step that should surface so the homepage scheduled-actions
  // rail and the hero state-machine can read without joining ProjectSchedule
  // on every request.
  nextScheduledStepNumber Int?
  nextScheduledAt         DateTime?
  scheduledStepsCompleted Int[]     @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tutorialId])
  @@index([userId])
  @@index([status])
  @@index([nextScheduledAt])
}

enum UserProjectStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ────────────────────────────────────────────────────────────────────────────
// Audit log — every admin action recorded
// ────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id      String @id @default(cuid())
  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  action   String // e.g. "tutorial.create", "tutorial.publish", "category.update"
  resource String // e.g. "Tutorial:abc123"
  metadata Json? // Action-specific data (diff, before/after, etc.)

  createdAt DateTime @default(now())

  @@index([resource])
  @@index([actorId])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 5 — UGC: reviews, photos, Q&A, errata, reports, suspensions
// ────────────────────────────────────────────────────────────────────────────

model Review {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  rating Int // 1..5
  title  String?
  body   String

  helpfulCount Int             @default(0)
  helpfuls     ReviewHelpful[]

  status ReviewStatus @default(PENDING_MODERATION)

  moderatedAt    DateTime?
  moderatedById  String?
  moderatedBy    User?     @relation("ReviewModerator", fields: [moderatedById], references: [id])
  moderationNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tutorialId])
  @@index([tutorialId, status, createdAt])
  @@index([status, createdAt])
}

enum ReviewStatus {
  PENDING_MODERATION
  PUBLISHED
  HIDDEN
  REMOVED
}

model ReviewHelpful {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, reviewId])
  @@index([reviewId])
}

model UGCPhoto {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  caption String?

  status UGCPhotoStatus @default(PENDING_MODERATION)

  // NSFW pre-screen results. Null means the scanner hasn't run (or no permission).
  nsfwScore          Float?
  nsfwClassification String?

  rejectionReason String?

  moderatedAt   DateTime?
  moderatedById String?
  moderatedBy   User?     @relation("PhotoModerator", fields: [moderatedById], references: [id])

  createdAt DateTime @default(now())

  @@index([tutorialId, status])
  @@index([status, createdAt])
  @@index([userId])
}

enum UGCPhotoStatus {
  PENDING_MODERATION
  APPROVED
  REJECTED
}

model Question {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  body String

  status      UGCStatus        @default(PENDING_MODERATION)
  upvoteCount Int              @default(0)
  upvotes     QuestionUpvote[]
  answers     Answer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, status, upvoteCount])
  @@index([userId])
}

enum UGCStatus {
  PENDING_MODERATION
  PUBLISHED
  HIDDEN
  REMOVED
}

model Answer {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  body String

  /// True when the author has role ADMIN or EDITOR at write time.
  isAuthorAnswer Boolean @default(false)

  status       UGCStatus @default(PENDING_MODERATION)
  helpfulCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId, status])
}

model QuestionUpvote {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, questionId])
  @@index([questionId])
}

model Errata {
  id String @id @default(cuid())

  /// Nullable so future anonymous reports can flow through. In practice the
  /// splash gate means every reporter has a session.
  userId String?
  user   User?   @relation("ErrataAuthor", fields: [userId], references: [id], onDelete: SetNull)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  body String

  status ErrataStatus @default(OPEN)

  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?     @relation("ErrataResolver", fields: [resolvedById], references: [id])
  resolutionNote String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([tutorialId])
}

enum ErrataStatus {
  OPEN
  ADDRESSED
  DISMISSED
}

model Report {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType ReportTargetType
  /// Generic ID into the target table. Not a FK because the target type varies.
  targetId   String

  reason      ReportReason
  description String?

  status           ReportStatus @default(OPEN)
  resolutionAction String?

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("ReportResolver", fields: [resolvedById], references: [id])

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

enum ReportTargetType {
  REVIEW
  PHOTO
  QUESTION
  ANSWER
  USER
}

enum ReportReason {
  SPAM
  ABUSE
  MISINFORMATION
  COPYRIGHT
  NSFW
  OTHER
}

enum ReportStatus {
  OPEN
  RESOLVED_ACTION_TAKEN
  RESOLVED_NO_ACTION
  DISMISSED
}

model UserSuspension {
  id String @id @default(cuid())

  userId String
  user   User   @relation("SuspensionSubject", fields: [userId], references: [id], onDelete: Cascade)

  suspendedById String
  suspendedBy   User   @relation("SuspensionActor", fields: [suspendedById], references: [id])

  reason String

  startedAt DateTime  @default(now())
  /// Null means indefinite / permanent.
  endsAt    DateTime?

  liftedAt   DateTime?
  liftedById String?
  liftedBy   User?     @relation("SuspensionLifter", fields: [liftedById], references: [id])

  status SuspensionStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([status, endsAt])
}

enum SuspensionStatus {
  ACTIVE
  LIFTED
  EXPIRED
}

/// In-app notifications surfaced under /me. Intentionally small — moderation
/// outcomes + a couple of system messages. Email + push are deferred.
model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type NotificationType
  body String
  /// Optional URL the user can click through to (e.g. the published review).
  href String?

  readAt DateTime?

  /// Mobile rebuild — set when this notification was also pushed to one of
  /// the user's `PushSubscription` devices. `pushedAt` records when the
  /// dispatch ran (may differ from `createdAt` because some categories are
  /// batched into the daily 09:00 cron). `pushed = true && pushedAt = null`
  /// shouldn't happen; treat it as "scheduled, not yet sent."
  pushed   Boolean   @default(false)
  pushedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum NotificationType {
  REVIEW_PUBLISHED
  REVIEW_HIDDEN
  REVIEW_REMOVED
  PHOTO_APPROVED
  PHOTO_REJECTED
  QUESTION_PUBLISHED
  QUESTION_HIDDEN
  ANSWER_PUBLISHED
  ANSWER_HIDDEN
  ERRATA_ADDRESSED
  ERRATA_DISMISSED
  ACCOUNT_SUSPENDED
  ACCOUNT_UNSUSPENDED
  CREATOR_APPLICATION_APPROVED
  CREATOR_APPLICATION_REJECTED
  CREATOR_TUTORIAL_PUBLISHED
  CREATOR_TUTORIAL_REJECTED
  CREATOR_TUTORIAL_SUBMITTED
  PATTERN_TEST_APPLICATION_ACCEPTED
  PATTERN_TEST_APPLICATION_REJECTED
  PATTERN_TEST_FEEDBACK_RECEIVED
  SYSTEM
}

/// Mobile rebuild — one row per registered push-token (per platform per
/// install). When a user uninstalls and reinstalls the app, Capacitor's
/// per-install UUID changes, so a fresh row is created and the previous one
/// is marked `revokedAt` lazily when delivery fails. `enabledCategories`
/// stores which notification categories the user has opted into; an empty
/// array means "all enabled categories at registration time"; the per-category
/// settings page rewrites this list.
model PushSubscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform    PushPlatform
  deviceToken String
  deviceId    String?
  userAgent   String?

  enabledCategories String[] @default([])

  lastActiveAt DateTime  @default(now())
  revokedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, platform])
  @@index([deviceToken])
  @@index([revokedAt])
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 6 — Creator program + pattern testing
// ────────────────────────────────────────────────────────────────────────────

/// One row per user who has applied for or holds the creator role. The
/// application + decision history lives on the row; once decidedAt is set,
/// `applicationStatus` reflects the outcome. The owning user's `isCreator`
/// flag is set on approval so role checks don't need a join.
model CreatorProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation("CreatorProfileOwner", fields: [userId], references: [id], onDelete: Cascade)

  bio       String
  specialty String

  // Optional social links surfaced on the public maker profile.
  websiteUrl      String?
  instagramHandle String?
  youtubeHandle   String?
  tiktokHandle    String?
  substackUrl     String?
  pinterestHandle String?

  applicationStatus CreatorApplicationStatus @default(APPLIED)
  applicationNote   String?
  appliedAt         DateTime                 @default(now())
  decidedAt         DateTime?
  decidedById       String?
  decidedBy         User?                    @relation("CreatorProfileDecider", fields: [decidedById], references: [id])
  rejectionReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationStatus, appliedAt])
}

enum CreatorApplicationStatus {
  NONE
  APPLIED
  APPROVED
  REJECTED
}

/// A pattern test is run by a creator (or future Homemade staff) on a tutorial
/// they own. Members opt in via `TestAssignment`. Once feedback is in, the
/// creator sees aggregated form data on the `feedback` page.
model PatternTest {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  status PatternTestStatus @default(DRAFT)

  /// Title shown on the public board — can differ from the tutorial title.
  title           String
  briefForTesters String
  maxTesters      Int    @default(5)

  recruitingClosesAt DateTime?
  completedAt        DateTime?

  assignments TestAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([creatorId, status])
  @@index([tutorialId])
}

enum PatternTestStatus {
  DRAFT
  RECRUITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// One row per (test, tester). Tracks lifecycle from APPLIED through
/// COMPLETED and stores the structured feedback JSON blob the tester submits.
model TestAssignment {
  id String @id @default(cuid())

  patternTestId String
  patternTest   PatternTest @relation(fields: [patternTestId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status          TestAssignmentStatus @default(APPLIED)
  applicationNote String?

  /// Structured feedback form output. Shape:
  /// {
  ///   patternClarity: { score: 1..5, comment: string },
  ///   instructionClarity: { score: 1..5, comment: string },
  ///   photoAccuracy: { score: 1..5, comment: string },
  ///   suppliesAccuracy: { score: 1..5, comment: string },
  ///   timeTakenMinutes: number | null,
  ///   estimatedTimeMinutes: number | null,
  ///   whatWorked: string,
  ///   whatDidnt: string,
  /// }
  feedback Json?

  appliedAt       DateTime  @default(now())
  decidedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  withdrawnAt     DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patternTestId, userId])
  @@index([userId, status])
  @@index([patternTestId, status])
}

enum TestAssignmentStatus {
  APPLIED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  WITHDRAWN
  REJECTED
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 8a — Legal compliance: GDPR data rights + DMCA takedowns
// ────────────────────────────────────────────────────────────────────────────

/// One row per data-export request a user has fired. Holds the bundle URL
/// once produced. `expiresAt` is enforced at read time — once past, the
/// download link 410s and the row is marked EXPIRED.
model DataExportRequest {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status DataExportStatus @default(REQUESTED)

  /// Public URL the user can fetch the bundle from (R2 custom domain).
  fileUrl String?
  /// R2 object key — kept so we can delete the bundle after expiry.
  fileKey String?
  bytes   Int?

  error String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime?

  @@index([userId, createdAt])
  @@index([status, expiresAt])
}

enum DataExportStatus {
  REQUESTED
  PROCESSING
  READY
  EXPIRED
  FAILED
}

/// One active row per user — `userId` is unique. While SCHEDULED, the user
/// is also flagged `isSuspended = true` so the account can't be used during
/// the grace period; cancelling lifts the suspension. After
/// `scheduledFor` passes a follow-up job (manual for now) runs the hard
/// delete: scrubs PII, sets `User.deletedAt`, preserves audit log entries.
model AccountDeletionRequest {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason String?

  status DeletionStatus @default(SCHEDULED)

  /// 30 days after `requestedAt`. A scheduled hard-delete job picks up rows
  /// past this date; until then the user can cancel.
  scheduledFor DateTime
  requestedAt  DateTime  @default(now())
  cancelledAt  DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledFor])
}

enum DeletionStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

/// DMCA / takedown notices from outside the platform. We never want to
/// trust the claimant blindly — every record stores their sworn-statement
/// acceptance and a contact trail. Admin actions are audit-logged via the
/// shared `audit()` helper.
model DmcaTakedownRequest {
  id String @id @default(cuid())

  claimantName    String
  claimantEmail   String
  claimantAddress String?

  /// The URL or location of the allegedly infringing content. Free text
  /// because claimants don't always send a clean URL.
  contentUrl         String
  /// Description of the work being infringed and how it's being infringed.
  contentDescription String

  /// The DMCA notice requires the claimant to swear under penalty of perjury
  /// that the information is accurate and they are authorised to act. We
  /// don't accept a notice without this box ticked.
  swornStatementAccepted Boolean @default(false)

  status DmcaStatus @default(RECEIVED)

  actionTakenNote String?

  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("DmcaResolver", fields: [resolvedById], references: [id])

  @@index([status, createdAt])
}

enum DmcaStatus {
  RECEIVED
  UNDER_REVIEW
  ACTION_TAKEN
  REJECTED
  COUNTER_NOTICED
}

// ────────────────────────────────────────────────────────────────────────────
// Pre-launch signup allowlist
// ────────────────────────────────────────────────────────────────────────────

/// Pre-launch gate that pairs with the Clerk dashboard Restrictions feature.
/// While `SIGNUP_ALLOWLIST_ENABLED` is true (in the webhook handler), any
/// Clerk signup whose primary email isn't on this table is deleted via the
/// Clerk Backend API immediately and the Prisma mirror row is rolled back.
/// Flipped off on launch day — see `project_pre_launch_checklist.md`.
model SignupAllowlist {
  id String @id @default(cuid())

  /// Lowercased before write. Unique so we can't have stale duplicates.
  email String @unique

  /// The admin who added the entry. ON DELETE SET NULL so removing an admin
  /// account doesn't drop allowlist rows.
  addedById String?
  addedBy   User?   @relation("SignupAllowlistAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  /// Optional free-text context, e.g. "Phase 6 creator test account".
  note String?

  /// Set when an allowlisted user actually signs up. Lets us spot stale
  /// entries that were never used.
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([addedById])
}

// ────────────────────────────────────────────────────────────────────────────
// Admin overhaul — SavedFilter + AdminCommandHistory. SavedFilter persists
// the content-list filter chips an editor wants to reuse (e.g. "RECIPE drafts
// with no hero"). AdminCommandHistory feeds the cmd-K palette's "recent
// commands" rail.
// ────────────────────────────────────────────────────────────────────────────

model SavedFilter {
  id String @id @default(cuid())

  userId String
  user   User   @relation("SavedFilterOwner", fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?

  /// JSON blob mirroring the URL query string the content list uses. Shape
  /// is owned by the content-list page; persisted opaquely so we can iterate
  /// the filter UI without migrations.
  filterQuery Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model AdminCommandHistory {
  id String @id @default(cuid())

  userId String
  user   User   @relation("AdminCommandActor", fields: [userId], references: [id], onDelete: Cascade)

  /// Free-form command identifier — "publish_current", "goto_glossary",
  /// "search_tutorial:<id>", etc. The palette decides how to interpret it
  /// when surfacing it back in the Recent rail.
  command String

  /// Optional context (current route, tutorialId, etc.) captured at fire time.
  context Json?

  executedAt DateTime @default(now())

  @@index([userId, executedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 8 — Master ingredient + tool tables. Recipes link to these via
// RecipeIngredient / RecipeTool join rows. The Ingredient table is the single
// source of truth for dietary flags, allergens, UK/US naming, substitutes —
// so "plain flour" carries its own gluten flag once and every recipe inherits.
// ────────────────────────────────────────────────────────────────────────────

model Ingredient {
  id   String @id @default(cuid())
  slug String @unique
  name String

  /// Optional explicit plural (used in summaries / titles). Falls back to the
  /// English `name + "s"` heuristic at render time when null.
  pluralName String?

  /// Free-form string enum: flour / dairy / meat / fish / vegetable / fruit /
  /// herb / spice / condiment / baking / pulse / grain / nut / seed / oil /
  /// vinegar / sweetener / alcohol / other. Kept as a string rather than a
  /// Prisma enum so authors can add categories without a follow-up migration.
  category String

  /// g / ml / each / tbsp / tsp / cup / pinch. Authors may override per
  /// RecipeIngredient via RecipeIngredient.unit.
  defaultUnit String

  /// Per-ingredient dietary flags — recipes derive their own dietaryFlags
  /// from the AND of their ingredient flags at index time.
  dietaryFlags String[]

  /// Slugs of other Ingredient rows that work as 1:1 substitutes.
  commonSubstitutes String[]

  /// Alternative names (UK ↔ US, regional). Indexed at search time so
  /// "rapeseed oil" finds "canola oil" and similar.
  aliases String[]

  /// Free-form notes — UK/US naming, prep tips, sourcing hints.
  notes String?

  /// Beginner-mode helper line surfaced in the structured-ingredients block
  /// when the reader has beginnerMode on. Per docs/page-design.md § 7.1.
  beginnerNote String?

  /// Cupboard-mode flag — items the average kitchen will already have
  /// (salt, pepper, plain flour, olive oil, …). Phase 8 cupboard-mode UI hooks
  /// off this so recipes that need 90% staples surface first.
  isStaple Boolean @default(false)

  /// UK 14-allergen list. When true, `allergenType` carries which group.
  isAllergen   Boolean @default(false)
  /// gluten / crustaceans / eggs / fish / peanuts / soybeans / milk / nuts /
  /// celery / mustard / sesame / sulphites / lupin / molluscs.
  allergenType String?

  /// Months when fresh-and-in-season, e.g. `["june", "july", "august"]`.
  /// Empty for pantry items.
  seasonality String[]

  /// Typical shelf life in days (fridge / cupboard depending on `storage`).
  shelfLifeDays Int?
  /// "fridge", "cool dark cupboard", "freezer".
  storage       String?

  /// Per-100g nutritional info. Flexible Json shape so we can refine later
  /// without re-migrating; stays null until populated.
  nutritionalInfoPer100g Json?

  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isStaple])
  @@index([isAllergen])
}

model Tool {
  id   String @id @default(cuid())
  slug String @unique
  name String

  /// knife / pan / pot / oven / mixer / processor / measuring / bowl / tray /
  /// tin / board / utensil / appliance / electrical / thermometer / scale /
  /// other. Free-form string for the same forwards-compat reason.
  category String

  /// Alternative names ("stand mixer" alias for "KitchenAid", "loaf tin"
  /// alias for "bread pan").
  aliases String[]

  /// Flips false for tools we'll never sell (e.g. a sink). Lets the future
  /// marketplace filter out non-purchasable rows up-front.
  isPurchasable Boolean @default(true)

  /// Typical price in pennies (GBP). Phase 7 marketplace sorts the buy panel
  /// by this. Stays null until Rebecca sets one.
  typicalPriceGbp Int?

  notes String?

  recipeTools RecipeTool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPurchasable])
}

/// One row per (recipe, ingredient). Derived from the `ingredientsList` block
/// in the recipe body on every save — see `syncRecipeIngredientsFromBody` in
/// `apps/web/src/lib/recipe-ingredients-sync.ts`.
model RecipeIngredient {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  /// Null means "to taste" / "as needed".
  amount Float?
  /// Overrides Ingredient.defaultUnit when set.
  unit   String?

  /// "finely chopped", "at room temperature", "zest only".
  prepNote String?

  isOptional Boolean @default(false)

  /// Sub-heading the row sits under in the rendered list ("For the dough",
  /// "For the topping"). Null = renders under the recipe's main "Ingredients".
  groupLabel String?

  /// Display order within the group.
  position Int

  /// When false, the scale selector and "swap with substitute" affordance
  /// are suppressed for this row (e.g. flour percentages in bakery).
  substitutionAllowed Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, position])
  @@index([ingredientId])
}

/// One row per (recipe, tool). The `equipmentList` TipTap block is deferred to
/// a future small session; for now these rows can be seeded directly when
/// recipes are authored, even though there's no editor block writing them yet.
model RecipeTool {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Restrict)

  isOptional Boolean @default(false)
  /// "or any oven-safe non-stick pan".
  notes      String?

  position Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, position])
  @@index([toolId])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 8 Step 13 — Mindset pipeline schema.
//
// Adds the practice-library taxonomy (PracticeType, PracticeTarget, TimeBand,
// BestTime) plus the user-side surfaces — UserPlan / UserPlanDay for the
// 30-day plan generator (free daily pick + paid custom), DailyPick for the
// free Today view, UserPracticeFavorite / UserPracticeUse for saved + done
// state, and UserFeeling for the anonymised "I'm feeling..." matcher.
//
// Practices themselves are Tutorial rows with `type = PRACTICE` and the
// columns added on the Tutorial model above. Long-form reading articles are
// Tutorial rows with `type = READING`. No master entity table for Mindset
// (practices are self-contained; no equivalent of Ingredient / Tool).
//
// See `docs/mindset-pipeline.md` for the rationale + page mapping, and
// `docs/mindset-brainstorm.md` for the matrix that drives the library.
// ────────────────────────────────────────────────────────────────────────────

enum PracticeType {
  TAPPING
  ENERGY_STATEMENT
  AFFIRMATION
  SPELL
  RITUAL
  ACTIVITY
  JOURNAL_PROMPT
  VISUALISATION
  MEDITATION
  EMBODIMENT
  READING
}

enum PracticeTarget {
  MONEY
  BODY
  RELATIONSHIPS
  SLEEP
  ANXIETY
  CONFIDENCE
  ABUNDANCE
  STUCK
  GRIEF
  FEAR
  MOTHERHOOD
  PURPOSE
  TIME
  ENERGY
  JOY
  SPIRITUALITY
  HEALTH
  SELF_WORTH
  FORGIVENESS
  AGEING
}

enum TimeBand {
  THREE_MIN
  FIVE_MIN
  TEN_MIN
  TWENTY_MIN
  THIRTY_PLUS
}

enum BestTime {
  MORNING
  EVENING
  ANYTIME
  AS_NEEDED
}

enum PlanTier {
  FREE_DAILY_PICK
  PAID_CUSTOM
}

enum PlanStatus {
  PENDING_GENERATION
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum PlanSlotSource {
  LIBRARY_REF
  GENERATED
}

// Pre-ferment type for breads. Straight doughs are `NONE`; flavour-building
// breads use one of the structured variants. `OTHER` for niche cultures
// (rye sour, tangzhong-style scalds repurposed as flavour-build, etc.) —
// document in the recipe body when used.
enum PreFermentType {
  NONE
  POOLISH
  BIGA
  LEVAIN
  SPONGE
  OTHER
}

/// One row per user-generated plan. `inputText` is the Path A "pour it out"
/// free-text; `inputFields` is the Path B structured JSON. Either is null
/// depending on which path the user picked. `tierAtCreation` snapshots the
/// user's tier when the plan was created — a free user who later upgrades
/// keeps their original plan as FREE_DAILY_PICK (the daily-pick surface),
/// any subsequent plan they create is PAID_CUSTOM (the 30-day custom plan).
model UserPlan {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  inputText   String?
  inputFields Json?

  /// Default daily minutes the user has for practices. The generator
  /// matches library rows whose `timeBand` falls within these budgets.
  timeMorning Int @default(5)
  timeEvening Int @default(5)

  /// Free-text anti-tags ("nothing too woo", "nothing involving the body").
  /// The generator avoids library rows that match these patterns.
  antiTags String[] @default([])

  tierAtCreation PlanTier   @default(FREE_DAILY_PICK)
  status         PlanStatus @default(PENDING_GENERATION)

  startDate   DateTime?
  currentDay  Int       @default(1)
  completedAt DateTime?

  /// Personalised paragraph from the generator addressing the user's
  /// specific situation — paid tier only.
  generatorIntro String?

  days UserPlanDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

/// One row per (UserPlan, dayNumber). Each day has three optional slots —
/// morning, evening, anchor — plus an optional reflection prompt and a
/// weekly theme. Each slot points at either a library Tutorial row
/// (`LIBRARY_REF`) or stores generated TipTap content inline (`GENERATED`).
/// Generated content is private to the user — it never enters the public
/// library and never surfaces in search or browse.
model UserPlanDay {
  id String @id @default(cuid())

  userPlanId String
  userPlan   UserPlan @relation(fields: [userPlanId], references: [id], onDelete: Cascade)

  dayNumber Int

  morningSource           PlanSlotSource @default(LIBRARY_REF)
  morningPracticeId       String?
  morningPractice         Tutorial?      @relation("PlanDayMorningPractice", fields: [morningPracticeId], references: [id], onDelete: SetNull)
  morningGeneratedContent Json?
  morningDoneAt           DateTime?

  eveningSource           PlanSlotSource @default(LIBRARY_REF)
  eveningPracticeId       String?
  eveningPractice         Tutorial?      @relation("PlanDayEveningPractice", fields: [eveningPracticeId], references: [id], onDelete: SetNull)
  eveningGeneratedContent Json?
  eveningDoneAt           DateTime?

  /// Anchor slot — the weekly ritual / activity slot. Nullable on days
  /// that don't have one. `anchorSource` is null when no anchor is set.
  anchorSource           PlanSlotSource?
  anchorPracticeId       String?
  anchorPractice         Tutorial?       @relation("PlanDayAnchorPractice", fields: [anchorPracticeId], references: [id], onDelete: SetNull)
  anchorGeneratedContent Json?
  anchorDoneAt           DateTime?

  /// Optional journal prompt for the day — typically a JOURNAL_PROMPT
  /// library row. Generated journal prompts live in
  /// `morning_generated_content` / `evening_generated_content` instead
  /// (the slot they were generated into).
  dailyReflectionPromptId String?
  dailyReflectionPrompt   Tutorial? @relation("PlanDayReflectionPrompt", fields: [dailyReflectionPromptId], references: [id], onDelete: SetNull)

  weeklyTheme String?

  /// Private. The plaintext is encrypted at the app layer before write —
  /// the column stores ciphertext only. Excluded from analytics.
  reflectionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userPlanId, dayNumber])
  @@index([userPlanId, dayNumber])
}

/// One row per (user, day). The free-tier "Today view" pick — the library
/// row surfaced for that user on that date. Unique on (userId, pickDate)
/// so the same user can't get two picks for the same day.
model DailyPick {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The calendar date the pick is for (user's local day — stored as a
  /// DATE without time so it survives time-zone changes).
  pickDate DateTime @db.Date

  practiceId String
  practice   Tutorial @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  shownAt       DateTime  @default(now())
  viewedAt      DateTime?
  markedHelpful Boolean   @default(false)
  markedDoneAt  DateTime?

  createdAt DateTime @default(now())

  @@unique([userId, pickDate])
  @@index([userId, pickDate])
}

model UserPracticeFavorite {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceId String
  practice   Tutorial @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@unique([userId, practiceId])
  @@index([userId])
}

/// One row per "I did this practice" event. Powers the user's history view
/// + feeds back into the free-tier daily pick rotation so the same row
/// doesn't surface repeatedly.
model UserPracticeUse {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  practiceId String
  practice   Tutorial @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  usedAt        DateTime        @default(now())
  contextTarget PracticeTarget?

  @@index([userId, usedAt])
  @@index([practiceId])
}

/// One row per "I'm feeling..." matcher event. `userIdHashed` is a salted
/// hash of the userId so analytics aggregates don't tie back to a single
/// account — the matcher is anonymised by default. The matched practice
/// is captured (nullable; null = no good match found) for analytics on
/// library coverage gaps.
model UserFeeling {
  id String @id @default(cuid())

  userIdHashed String

  feelingAt    DateTime       @default(now())
  targetAtTime PracticeTarget

  matchedPracticeId String?
  matchedPractice   Tutorial? @relation(fields: [matchedPracticeId], references: [id], onDelete: SetNull)

  @@index([userIdHashed, feelingAt])
  @@index([targetAtTime])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 8 Homepage rebuild — WeeklyEditorialPick + ProjectSchedule.
//
// Editorial picks: Sunday-22:00-UTC Inngest cron seeds five AUTO_SELECTED
// picks per (Mon 00:00 UTC) week-anchor four weeks ahead. Admins can pin a
// row (status -> MANUALLY_PINNED) so subsequent cron runs leave it alone, or
// replace a single position (status -> MANUALLY_REPLACED) keeping the
// original auto-pick's id on `replacedAutoPickId` for audit.
//
// ProjectSchedule rows are per-tutorial multi-day step definitions for the
// long-arc workflows (sourdough starters, fermenting, preserving, growing).
// `surfaceAs` decides whether the user's homepage hero takes over for the
// day, a rail card surfaces under "Today's scheduled project actions", or
// only an in-app notification fires.
// ────────────────────────────────────────────────────────────────────────────

enum EditorialPickStatus {
  AUTO_SELECTED
  MANUALLY_PINNED
  MANUALLY_REPLACED
}

enum ScheduleSurface {
  HERO
  RAIL_CARD
  NOTIFICATION_ONLY
}

model WeeklyEditorialPick {
  id String @id @default(cuid())

  /// Monday 00:00 UTC of the week this pick is for. The Sunday-night cron
  /// generates rows for the next four weeks.
  weekStarting DateTime

  /// 1..5. The first position is the hero pick.
  position Int

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  status EditorialPickStatus @default(AUTO_SELECTED)

  /// Clerk userId (or User.id) when an admin pinned / replaced the row.
  selectedBy String?
  selectedAt DateTime?

  /// When an admin replaces an auto-pick, store the previous WeeklyEditorialPick
  /// id so audit-trail digging can reconstruct what was overridden.
  replacedAutoPickId String?

  /// Optional admin note when pinning / replacing.
  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([weekStarting, position])
  @@index([weekStarting])
}

// ────────────────────────────────────────────────────────────────────────────
// Autopilot halt signals — phase_8_content_integration_001
//
// Workers / scheduled tasks insert a row here when they halt mid-stream. An
// hourly Inngest cron reads unsent signals and emails Rebecca, then stamps
// `notifiedAt` so each signal sends once.
//
// Reason: BACKLOG_DRAINED | QUALITY_DRIFT | HARD_CAP_REACHED | MANUAL_PAUSE.
// ────────────────────────────────────────────────────────────────────────────

model AutopilotHaltSignal {
  id String @id @default(cuid())

  /// Stream the halt affects — cooking / baking / mindset.
  stream String

  reason String
  detail String?

  notifiedAt DateTime?

  /// Set by the admin "Acknowledge" button on /admin/system/autopilot, so the
  /// page can hide acknowledged rows from the default view.
  acknowledgedAt   DateTime?
  acknowledgedById String?

  createdAt DateTime @default(now())

  @@index([notifiedAt, createdAt])
  @@index([acknowledgedAt, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Autopilot pause state — phase_autopilot_status_001
//
// One row per stream (cooking / baking / mindset). When `pausedAt` is set, the
// preflight in `.claude/scheduled-tasks/autopilot-*/SKILL.md` writes a
// MANUAL_PAUSE halt signal and exits clean instead of running the batch. The
// scheduled-tasks cron stays enabled — pausing is reversible from the admin
// page without touching the MCP system.
// ────────────────────────────────────────────────────────────────────────────

model AutopilotPauseState {
  id String @id @default(cuid())

  /// Unique per stream — cooking / baking / mindset.
  streamName String @unique

  /// Null when the stream is running; set when an admin pauses it.
  pausedAt   DateTime?
  pausedById String?
  reason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectSchedule {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  /// 1, 2, 3, … In step-display order.
  stepNumber Int

  /// Days after `UserProject.startedAt` this step fires.
  offsetDays Int

  title String
  body  String

  surfaceAs ScheduleSurface @default(RAIL_CARD)

  /// Does the user need to mark this step done? When false, the step is
  /// information-only (e.g. "Your starter should smell mildly yeasty by now").
  requiresUserAction Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, stepNumber])
}

// ────────────────────────────────────────────────────────────────────────────
// Self-hosted analytics — phase_analytics_self_hosted_001
//
// Aura-pattern adapted: every event the app fires lands here as a row, plus
// summary tables that the nightly Inngest cron rolls up so the admin
// dashboards never aggregate over the raw table at read time.
//
// Dual-fired alongside PostHog. PostHog stays for session recordings,
// heatmaps, and ad-hoc event exploration; the dashboards under
// /admin/analytics read from these tables.
// ────────────────────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  /// Clerk id for signed-in events; null when the actor was signed out
  /// at fire time. Matches the same id PostHog stores as distinctId.
  clerkUserId String?

  /// Server-issued analytics session id (homemade-session cookie). Separate
  /// from Clerk's auth session — exists so we can stitch a single browsing
  /// session together for funnel + drop-off views regardless of auth state.
  sessionId String

  /// Event name from `docs/analytics-taxonomy.md` — e.g. tutorial_viewed.
  event String

  /// Top-level namespace derived from the event name on insert. Cheap
  /// pre-bucketing for category-level rollups. Examples: acquisition,
  /// activation, engagement, content, search, creator, account, friction.
  category String?

  /// Event payload — same shape as the PostHog properties bag.
  properties Json?

  /// Page URL the event fired on (full URL).
  url String?

  /// Just the path portion of url, denormalised so per-page rollups don't
  /// have to parse url at read time.
  pathname String?

  referrer  String?
  userAgent String?

  /// 2-letter ISO from Cloudflare CF-IPCountry header.
  country String?

  /// mobile / tablet / desktop, derived from UA at capture time.
  deviceClass String?

  /// Denormalised from User.signupCohortWeek so cohort retention queries
  /// don't have to join across tens of millions of rows. Captured at fire
  /// time — a cohort week is immutable once set on the user.
  cohortWeek String?

  /// Denormalised from User.acquisitionChannel / utm*. Same rationale —
  /// channel is set once at signup and doesn't change.
  acquisitionChannel String?
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?

  @@index([clerkUserId, createdAt])
  @@index([event, createdAt])
  @@index([sessionId, createdAt])
  @@index([category, createdAt])
  @@index([cohortWeek, event, createdAt])
  @@index([pathname, createdAt])
  @@index([country, createdAt])
  @@index([acquisitionChannel, createdAt])
}

/// Daily metric rollups. One row per (date, metric, dimension). dimension
/// is the literal string "__total__" for the unsplit row and a "key=value"
/// string for splits (e.g. country=GB, channel=organic, category=cooking).
/// Using a sentinel rather than null keeps the unique constraint canonical
/// — Postgres treats NULL as distinct in unique indexes, which would let
/// duplicate unsplit rows slip in past Prisma's upsert path.
model AnalyticsDailyRollup {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  metric    String
  dimension String
  value     BigInt
  createdAt DateTime @default(now())

  @@unique([date, metric, dimension])
  @@index([metric, date])
}

/// Per-(signupWeek, weeksAfterSignup) retention rollup. cohortSize is the
/// total users in the cohort; retainedCount is the count active that week;
/// retentionRate is the float ratio for fast read-side rendering of the
/// heatmap.
model AnalyticsCohortRollup {
  id               String   @id @default(cuid())
  cohortWeek       String
  weeksAfterSignup Int
  cohortSize       Int
  retainedCount    Int
  retentionRate    Float
  createdAt        DateTime @default(now())

  @@unique([cohortWeek, weeksAfterSignup])
  @@index([cohortWeek])
}

/// Idempotency tracker for the nightly rollup cron. One row per UTC date
/// processed; the cron skips dates already marked complete unless the
/// admin manually triggers a backfill.
model AnalyticsRollupRun {
  id              String    @id @default(cuid())
  date            DateTime  @unique @db.Date
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  eventsProcessed Int       @default(0)
  metricsWritten  Int       @default(0)
  error           String?
}

// ────────────────────────────────────────────────────────────────────────────
// Garden — master taxonomy (phase_garden_pipeline_001)
//
// PlantVariety is the Garden master entity (analogous to Ingredient for
// Cooking / Baking). PlantPest + CompanionPlanting are reference tables that
// growing-guide tutorials cross-link. Tutorials reference plants by slug in
// body prose rather than through a structured relation — same pattern as
// the existing ingredient / tool master tables.
// ────────────────────────────────────────────────────────────────────────────

/// Companion-planting relationship between two plant varieties.
enum CompanionRelationship {
  BENEFICIAL
  NEUTRAL
  HARMFUL
}

model PlantVariety {
  id            String  @id @default(cuid())
  slug          String  @unique
  commonName    String
  latinBinomial String?

  /// Self-referential pointer to the parent species when this row is a
  /// named variety ("Brandywine" → "tomato"). Null on species-level rows.
  parentSpeciesId String?
  parentSpecies   PlantVariety?  @relation("PlantVarietyChildren", fields: [parentSpeciesId], references: [id], onDelete: SetNull)
  varieties       PlantVariety[] @relation("PlantVarietyChildren")

  /// vegetable / fruit / herb / flower / shrub / tree / other. Free-form
  /// string so authors can add categories without a follow-up migration —
  /// same pattern as `Ingredient.category`.
  category String

  /// RHS hardiness — strings H1a..H7. Multi-valued because a single plant
  /// typically tolerates a range.
  rhsHardinessZone  String[] @default([])
  /// USDA zones '1'..'13' as strings.
  usdaHardinessZone String[] @default([])

  /// full-sun / partial-shade / shade.
  sunRequirement   String?
  /// low / moderate / high.
  waterRequirement String?

  /// clay / sandy / loamy / chalky / well-drained / boggy. Array because
  /// most plants tolerate more than one soil type.
  soilType String[] @default([])

  daysToMaturity Int?
  seedingDepthCm Float?
  spacingCm      Int?
  heightCm       Int?

  /// Which parts the kitchen uses: 'fruit' / 'leaf' / 'root' / 'stem' /
  /// 'flower' / 'seed'. Empty on purely ornamental rows; multi-valued where
  /// more than one part is edible.
  edibleParts String[] @default([])

  notes String?

  /// Cupboard-mode equivalent — true for plants the average UK garden
  /// already grows (tomato, strawberry, mint, ...). Surfaces in the
  /// "starter plot" filter.
  isStaple    Boolean @default(false)
  /// True for perennials (rosemary, asparagus, fruit trees, ...).
  isPerennial Boolean @default(false)

  /// Months when in season (sown / harvested / blooming depending on
  /// category). Lower-case month names matching `Ingredient.seasonality`.
  seasonality String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asPlant     CompanionPlanting[] @relation("CompanionAsPlant")
  asCompanion CompanionPlanting[] @relation("CompanionAsCompanion")

  @@index([category])
  @@index([isStaple])
  @@index([isPerennial])
  @@index([parentSpeciesId])
}

/// Common garden pest or disease. Reference table; the public
/// pest-management surfaces cross-link these rows from growing-guide
/// tutorials. `affectedPlants` is a free-form string array of PlantVariety
/// slugs (same pattern as `Ingredient.commonSubstitutes`).
model PlantPest {
  id   String @id @default(cuid())
  slug String @unique
  name String

  /// PlantVariety slugs the pest affects.
  affectedPlants String[] @default([])

  symptoms             String?
  /// Plain-text controls. The renderer prefers organic; the conventional
  /// column is shown factually with a "follow manufacturer instructions"
  /// voice line, not as endorsement.
  organicControls      String?
  conventionalControls String?

  /// low / moderate / high / catastrophic.
  severity String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([severity])
}

/// Pairwise companion-planting relationship. The seed enforces symmetry
/// where it exists ("tomato → basil = BENEFICIAL" implies the reverse).
/// HARMFUL pairs are folklore-strength claims; the author docs require a
/// citation in `notes` rather than a bare assertion.
model CompanionPlanting {
  id String @id @default(cuid())

  plantId String
  plant   PlantVariety @relation("CompanionAsPlant", fields: [plantId], references: [id], onDelete: Cascade)

  companionId String
  companion   PlantVariety @relation("CompanionAsCompanion", fields: [companionId], references: [id], onDelete: Cascade)

  relationship CompanionRelationship
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plantId, companionId])
  @@index([plantId])
  @@index([companionId])
}
