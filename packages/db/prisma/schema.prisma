// Homemade Prisma schema.
//
// Conventions:
// - cuid IDs everywhere
// - createdAt + updatedAt timestamps on every mutable row
// - soft-delete-by-status rather than physical deletes for content tables
// - body fields are JSON (TipTap document)
//
// Schema is incremental — start with the tutorial spine; add Recipe / Pattern /
// Review / Q&A / UserProject / Marketplace / Creator / Errata models in later
// phases as they become needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────────────────────────────────────────
// Users — Clerk shadow + role
// ────────────────────────────────────────────────────────────────────────────

model User {
  id      String   @id @default(cuid())
  clerkId String   @unique
  email   String   @unique
  name    String?
  role    UserRole @default(MEMBER)

  // Reader-side preferences and profile
  beginnerMode  Boolean @default(false)
  displayHandle String? @unique
  bio           String?

  // Suspension state (Phase 5). `isSuspended` is the convenience flag the
  // moderation flow toggles; `suspendedUntil` mirrors the active UserSuspension's
  // end. Both are denormalised so filtering doesn't need a join.
  isSuspended    Boolean   @default(false)
  suspendedUntil DateTime?

  // Creator program (Phase 6). `isCreator` is the denormalised flag set when
  // an application is approved; the full profile lives in `CreatorProfile`.
  // `isPatternTester` flips on when a member opts in to the tester pool.
  isCreator         Boolean   @default(false)
  creatorVerifiedAt DateTime?
  isPatternTester   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutorialsAuthored Tutorial[]        @relation("TutorialAuthor")
  tutorialsCreated  Tutorial[]        @relation("TutorialCreator")
  versions          TutorialVersion[] @relation("VersionAuthor")
  auditLogs         AuditLog[]
  bookmarks         Bookmark[]
  projects          UserProject[]

  reviews            Review[]
  reviewHelpfuls     ReviewHelpful[]
  ugcPhotos          UGCPhoto[]
  questions          Question[]
  answers            Answer[]
  questionUpvotes    QuestionUpvote[]
  errata             Errata[]         @relation("ErrataAuthor")
  errataResolved     Errata[]         @relation("ErrataResolver")
  reportsFiled       Report[]         @relation("ReportReporter")
  reportsResolved    Report[]         @relation("ReportResolver")
  suspensions        UserSuspension[] @relation("SuspensionSubject")
  suspensionsApplied UserSuspension[] @relation("SuspensionActor")
  suspensionsLifted  UserSuspension[] @relation("SuspensionLifter")
  notifications      Notification[]
  reviewsModerated   Review[]         @relation("ReviewModerator")
  photosModerated    UGCPhoto[]       @relation("PhotoModerator")

  creatorProfile   CreatorProfile?  @relation("CreatorProfileOwner")
  creatorDecisions CreatorProfile[] @relation("CreatorProfileDecider")
  patternTests     PatternTest[]
  testAssignments  TestAssignment[]

  @@index([role])
  @@index([isSuspended])
  @@index([isCreator])
}

enum UserRole {
  ANONYMOUS
  MEMBER
  CREATOR
  TESTER
  EDITOR
  ADMIN
}

// ────────────────────────────────────────────────────────────────────────────
// Taxonomy — Category / SubCategory / Tag
// ────────────────────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  introBody   Json? // Rich content (TipTap) for the editorial intro
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subCategories SubCategory[]
  tutorials     Tutorial[]
}

model SubCategory {
  id          String  @id @default(cuid())
  slug        String
  name        String
  description String?
  order       Int     @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  tutorials Tutorial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
}

model Tag {
  id   String @id @default(cuid())
  slug String @unique
  name String

  tutorials Tutorial[]

  createdAt DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────────────────
// Glossary — per-category technical terms
// ────────────────────────────────────────────────────────────────────────────

model GlossaryTerm {
  id         String @id @default(cuid())
  slug       String @unique
  term       String
  definition String // Short plain-text definition for tooltips
  body       Json? // Optional longer rich content for the term's own page

  categoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

// ────────────────────────────────────────────────────────────────────────────
// Tutorials — the heart of the platform
// ────────────────────────────────────────────────────────────────────────────

model Tutorial {
  id       String  @id @default(cuid())
  slug     String  @unique
  title    String
  subtitle String?
  excerpt  String? // Short summary used on cards and meta description

  // Categorisation
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  tags          Tag[]

  // Metadata shown in the info bar
  difficulty  Difficulty @default(BEGINNER)
  timeMinutes Int? // Total time the tutorial takes (sum of all steps)
  season      Season?
  sourceType  SourceType @default(SYNTHESISED)
  sourceNotes String? // Reference list / attribution notes

  // Content
  heroMediaId String?
  hero        Media?  @relation(fields: [heroMediaId], references: [id])
  body        Json // TipTap document — the article body

  // Lifecycle
  status       TutorialStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledFor DateTime?

  // Authorship
  authorId String
  author   User   @relation("TutorialAuthor", fields: [authorId], references: [id])

  // Creator attribution (Phase 6). Null = Homemade-authored. When set, the
  // tutorial is shown with a "By {creator}" byline that links to /makers/[handle].
  creatorId String?
  creator   User?   @relation("TutorialCreator", fields: [creatorId], references: [id])

  versions     TutorialVersion[]
  bookmarks    Bookmark[]
  projects     UserProject[]
  reviews      Review[]
  ugcPhotos    UGCPhoto[]
  questions    Question[]
  errata       Errata[]
  patternTests PatternTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([slug])
  @@index([creatorId, status, publishedAt])
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
  YEAR_ROUND
}

enum SourceType {
  TESTED // Tested in Homemade kitchen/garden/etc
  CLASSIC // Classic precedent, cross-referenced across 5+ sources
  SYNTHESISED // Synthesised from public domain / extension service sources
  PUBLIC_DOMAIN // Direct public domain (e.g. Victorian crochet pattern)
  CREATOR // From an external creator (post Phase 6)
}

enum TutorialStatus {
  DRAFT
  IN_REVIEW
  PENDING_MODERATION
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

// One row per save in the admin editor. Used for version history + rollback.
model TutorialVersion {
  id         String   @id @default(cuid())
  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  // Snapshot of the editable fields at this version
  title    String
  subtitle String?
  excerpt  String?
  body     Json
  status   TutorialStatus

  authorId   String
  author     User    @relation("VersionAuthor", fields: [authorId], references: [id])
  changeNote String?

  createdAt DateTime @default(now())

  @@index([tutorialId, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Media — photos, videos, diagrams, illustrations
// ────────────────────────────────────────────────────────────────────────────

model Media {
  id String @id @default(cuid())

  // Cloudflare identifiers (one or both depending on type)
  cloudflareId String? @unique // Cloudflare Images / Stream ID
  r2Key        String? // R2 raw asset key

  type        MediaType
  mimeType    String?
  filename    String?
  alt         String?
  caption     String?
  attribution String? // Wikimedia / Unsplash / Pexels credit

  width  Int?
  height Int?
  bytes  Int?

  status MediaStatus @default(UPLOADING)

  tutorialsHero Tutorial[]
  ugcPhotos     UGCPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
}

enum MediaType {
  PHOTO
  VIDEO
  DIAGRAM
  ILLUSTRATION
}

enum MediaStatus {
  UPLOADING
  READY
  FAILED
}

// ────────────────────────────────────────────────────────────────────────────
// User state — bookmarks + projects (Phase 4)
// ────────────────────────────────────────────────────────────────────────────

model Bookmark {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tutorialId])
  @@index([userId])
}

// One UserProject per (user, tutorial). Tracks "I'm making this" lifecycle plus
// the reader's private notes, supplies tick-list, and reading progress.
model UserProject {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  status      UserProjectStatus @default(IN_PROGRESS)
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  abandonedAt DateTime?

  notes                  String   @default("")
  suppliesChecked        Json     @default("[]")
  readingProgressPercent Int      @default(0)
  lastViewedAt           DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tutorialId])
  @@index([userId])
  @@index([status])
}

enum UserProjectStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ────────────────────────────────────────────────────────────────────────────
// Audit log — every admin action recorded
// ────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id      String @id @default(cuid())
  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  action   String // e.g. "tutorial.create", "tutorial.publish", "category.update"
  resource String // e.g. "Tutorial:abc123"
  metadata Json? // Action-specific data (diff, before/after, etc.)

  createdAt DateTime @default(now())

  @@index([resource])
  @@index([actorId])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 5 — UGC: reviews, photos, Q&A, errata, reports, suspensions
// ────────────────────────────────────────────────────────────────────────────

model Review {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  rating Int // 1..5
  title  String?
  body   String

  helpfulCount Int             @default(0)
  helpfuls     ReviewHelpful[]

  status ReviewStatus @default(PENDING_MODERATION)

  moderatedAt    DateTime?
  moderatedById  String?
  moderatedBy    User?     @relation("ReviewModerator", fields: [moderatedById], references: [id])
  moderationNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tutorialId])
  @@index([tutorialId, status, createdAt])
  @@index([status, createdAt])
}

enum ReviewStatus {
  PENDING_MODERATION
  PUBLISHED
  HIDDEN
  REMOVED
}

model ReviewHelpful {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, reviewId])
  @@index([reviewId])
}

model UGCPhoto {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  caption String?

  status UGCPhotoStatus @default(PENDING_MODERATION)

  // NSFW pre-screen results. Null means the scanner hasn't run (or no permission).
  nsfwScore          Float?
  nsfwClassification String?

  rejectionReason String?

  moderatedAt   DateTime?
  moderatedById String?
  moderatedBy   User?     @relation("PhotoModerator", fields: [moderatedById], references: [id])

  createdAt DateTime @default(now())

  @@index([tutorialId, status])
  @@index([status, createdAt])
  @@index([userId])
}

enum UGCPhotoStatus {
  PENDING_MODERATION
  APPROVED
  REJECTED
}

model Question {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  body String

  status      UGCStatus        @default(PENDING_MODERATION)
  upvoteCount Int              @default(0)
  upvotes     QuestionUpvote[]
  answers     Answer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorialId, status, upvoteCount])
  @@index([userId])
}

enum UGCStatus {
  PENDING_MODERATION
  PUBLISHED
  HIDDEN
  REMOVED
}

model Answer {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  body String

  /// True when the author has role ADMIN or EDITOR at write time.
  isAuthorAnswer Boolean @default(false)

  status       UGCStatus @default(PENDING_MODERATION)
  helpfulCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId, status])
}

model QuestionUpvote {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, questionId])
  @@index([questionId])
}

model Errata {
  id String @id @default(cuid())

  /// Nullable so future anonymous reports can flow through. In practice the
  /// splash gate means every reporter has a session.
  userId String?
  user   User?   @relation("ErrataAuthor", fields: [userId], references: [id], onDelete: SetNull)

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  body String

  status ErrataStatus @default(OPEN)

  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?     @relation("ErrataResolver", fields: [resolvedById], references: [id])
  resolutionNote String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([tutorialId])
}

enum ErrataStatus {
  OPEN
  ADDRESSED
  DISMISSED
}

model Report {
  id String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType ReportTargetType
  /// Generic ID into the target table. Not a FK because the target type varies.
  targetId   String

  reason      ReportReason
  description String?

  status           ReportStatus @default(OPEN)
  resolutionAction String?

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("ReportResolver", fields: [resolvedById], references: [id])

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

enum ReportTargetType {
  REVIEW
  PHOTO
  QUESTION
  ANSWER
  USER
}

enum ReportReason {
  SPAM
  ABUSE
  MISINFORMATION
  COPYRIGHT
  NSFW
  OTHER
}

enum ReportStatus {
  OPEN
  RESOLVED_ACTION_TAKEN
  RESOLVED_NO_ACTION
  DISMISSED
}

model UserSuspension {
  id String @id @default(cuid())

  userId String
  user   User   @relation("SuspensionSubject", fields: [userId], references: [id], onDelete: Cascade)

  suspendedById String
  suspendedBy   User   @relation("SuspensionActor", fields: [suspendedById], references: [id])

  reason String

  startedAt DateTime  @default(now())
  /// Null means indefinite / permanent.
  endsAt    DateTime?

  liftedAt   DateTime?
  liftedById String?
  liftedBy   User?     @relation("SuspensionLifter", fields: [liftedById], references: [id])

  status SuspensionStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([status, endsAt])
}

enum SuspensionStatus {
  ACTIVE
  LIFTED
  EXPIRED
}

/// In-app notifications surfaced under /me. Intentionally small — moderation
/// outcomes + a couple of system messages. Email + push are deferred.
model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type NotificationType
  body String
  /// Optional URL the user can click through to (e.g. the published review).
  href String?

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum NotificationType {
  REVIEW_PUBLISHED
  REVIEW_HIDDEN
  REVIEW_REMOVED
  PHOTO_APPROVED
  PHOTO_REJECTED
  QUESTION_PUBLISHED
  QUESTION_HIDDEN
  ANSWER_PUBLISHED
  ANSWER_HIDDEN
  ERRATA_ADDRESSED
  ERRATA_DISMISSED
  ACCOUNT_SUSPENDED
  ACCOUNT_UNSUSPENDED
  CREATOR_APPLICATION_APPROVED
  CREATOR_APPLICATION_REJECTED
  CREATOR_TUTORIAL_PUBLISHED
  CREATOR_TUTORIAL_REJECTED
  CREATOR_TUTORIAL_SUBMITTED
  PATTERN_TEST_APPLICATION_ACCEPTED
  PATTERN_TEST_APPLICATION_REJECTED
  PATTERN_TEST_FEEDBACK_RECEIVED
  SYSTEM
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 6 — Creator program + pattern testing
// ────────────────────────────────────────────────────────────────────────────

/// One row per user who has applied for or holds the creator role. The
/// application + decision history lives on the row; once decidedAt is set,
/// `applicationStatus` reflects the outcome. The owning user's `isCreator`
/// flag is set on approval so role checks don't need a join.
model CreatorProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation("CreatorProfileOwner", fields: [userId], references: [id], onDelete: Cascade)

  bio       String
  specialty String

  // Optional social links surfaced on the public maker profile.
  websiteUrl      String?
  instagramHandle String?
  youtubeHandle   String?
  tiktokHandle    String?
  substackUrl     String?
  pinterestHandle String?

  applicationStatus CreatorApplicationStatus @default(APPLIED)
  applicationNote   String?
  appliedAt         DateTime                 @default(now())
  decidedAt         DateTime?
  decidedById       String?
  decidedBy         User?                    @relation("CreatorProfileDecider", fields: [decidedById], references: [id])
  rejectionReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationStatus, appliedAt])
}

enum CreatorApplicationStatus {
  NONE
  APPLIED
  APPROVED
  REJECTED
}

/// A pattern test is run by a creator (or future Homemade staff) on a tutorial
/// they own. Members opt in via `TestAssignment`. Once feedback is in, the
/// creator sees aggregated form data on the `feedback` page.
model PatternTest {
  id String @id @default(cuid())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  status PatternTestStatus @default(DRAFT)

  /// Title shown on the public board — can differ from the tutorial title.
  title           String
  briefForTesters String
  maxTesters      Int    @default(5)

  recruitingClosesAt DateTime?
  completedAt        DateTime?

  assignments TestAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([creatorId, status])
  @@index([tutorialId])
}

enum PatternTestStatus {
  DRAFT
  RECRUITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// One row per (test, tester). Tracks lifecycle from APPLIED through
/// COMPLETED and stores the structured feedback JSON blob the tester submits.
model TestAssignment {
  id String @id @default(cuid())

  patternTestId String
  patternTest   PatternTest @relation(fields: [patternTestId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status          TestAssignmentStatus @default(APPLIED)
  applicationNote String?

  /// Structured feedback form output. Shape:
  /// {
  ///   patternClarity: { score: 1..5, comment: string },
  ///   instructionClarity: { score: 1..5, comment: string },
  ///   photoAccuracy: { score: 1..5, comment: string },
  ///   suppliesAccuracy: { score: 1..5, comment: string },
  ///   timeTakenMinutes: number | null,
  ///   estimatedTimeMinutes: number | null,
  ///   whatWorked: string,
  ///   whatDidnt: string,
  /// }
  feedback Json?

  appliedAt       DateTime  @default(now())
  decidedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  withdrawnAt     DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patternTestId, userId])
  @@index([userId, status])
  @@index([patternTestId, status])
}

enum TestAssignmentStatus {
  APPLIED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  WITHDRAWN
  REJECTED
}
